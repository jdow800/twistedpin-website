{
  "crons": [
    {
      "path": "/api/cron/rebuild",
      "schedule": "0 9 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/reserve",
      "destination": "https://ecom.roller.app/twistedpin/openbowl/en-us/home",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/hero/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
