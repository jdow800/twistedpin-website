---
import "../styles/global.css";
import StickyCTABar from "../components/StickyCTABar.astro";
import NavDrawer from "../components/NavDrawer.astro";
import SiteHeader from "../components/SiteHeader.astro";
import PromoBar from "../components/PromoBar.astro";
import Analytics from "@vercel/analytics/astro";
import { webPageSchema } from "../lib/schema";

interface Props {
  title?: string;
  description?: string;
  /** Override og:image / twitter:image. Path is relative to site root.
   *  Defaults to /og/og-default.jpg (catering buffet shot). Per-page
   *  overrides should be 1200x630 px, JPG or PNG. */
  ogImage?: string;
  /** og:image:alt — describes the image itself, not the page. */
  ogImageAlt?: string;
  /** og:type — defaults to "website". Use "article" for blog posts. */
  ogType?: string;
  /** Hide the global sticky CTA bar (e.g. on the booking flow). */
  hideStickyCTA?: boolean;
  /** Hide the persistent header (rare — full-bleed campaign pages). */
  hideHeader?: boolean;
  /** LCP preload: image href to preload with fetchpriority="high" so the
   *  browser preload-scanner kicks the fetch off immediately (before any JS
   *  parse or IntersectionObserver setup). Used by pages whose LCP element
   *  is a section-video poster that would otherwise lazy-load via
   *  `data-poster` and not paint until motion.client.ts promotes it.
   *
   *  Example (events.astro):
   *    lcpPreloadHref="/snap/buffet-poster.webp"
   *    lcpPreloadMedia="(max-width: 1024px)"
   *
   *  Pattern matches the homepage hero poster preload (Base.astro lines
   *  for /hero/hero-*-poster.webp). Pages that don't pass this prop get
   *  no extra preload — their existing LCP path is fine. */
  lcpPreloadHref?: string;
  /** Optional `media` attribute on the preload tag. Use to scope a poster
   *  preload to mobile only (e.g. `"(max-width: 1024px)"`) if desktop has
   *  a different visual layout that doesn't surface this poster as LCP. */
  lcpPreloadMedia?: string;
  /** Optional `type` attribute on the preload tag. Defaults to derived from
   *  the file extension (.avif → image/avif, .webp → image/webp). Override
   *  only if you know what you're doing — wrong type makes the browser
   *  refetch the resource. */
  lcpPreloadType?: string;
  /**
   * Opt-in `dateModified` on the auto-emitted WebPage schema. ONLY pass
   * this when the page's content truly refreshes — daily cron-driven
   * pages (menu pages) at `today()`, otherwise omit. See WebPage helper
   * comment in src/lib/schema.ts for the full "what counts as honest"
   * rationale. Emitting on slow-moving pages risks Google's
   * content-flapping detection. Default: undefined (no dateModified).
   */
  dateModified?: string;
  /**
   * Opt-in `speakable` selectors on the auto-emitted WebPage schema.
   * Identifies on-page content for voice-assistant read-aloud. Per
   * Google's Speakable spec, target content should be ~20-30 seconds
   * when spoken — keep selector list short and bounded.
   *
   * Examples:
   *   - /faq: ['.t2-faq-q-text', '.t2-faq-a']
   *   - homepage: ['.footer-address']
   * Default: undefined (no speakable property).
   */
  speakable?: string[];
}

const {
  title = "Twisted Pin — Plainfield, IL",
  description = "Cocktails, 28 self-serve taps, and a 6-lane VIP suite. Built for adults. Plainfield, IL.",
  ogImage = "/og/og-default.jpg",
  ogImageAlt = "A catering buffet set up at Twisted Pin in Plainfield, IL",
  ogType = "website",
  hideStickyCTA = false,
  hideHeader = false,
  lcpPreloadHref,
  lcpPreloadMedia,
  lcpPreloadType,
  dateModified,
  speakable,
} = Astro.props;

// Auto-derive preload type from file extension. AVIF is ~30% smaller than
// WebP for complex content (arcade lighting, busy textures) — worth shipping
// when the WebP version is the LCP outlier.
const derivedPreloadType = lcpPreloadType
  ?? (lcpPreloadHref?.endsWith('.avif') ? 'image/avif'
    : lcpPreloadHref?.endsWith('.webp') ? 'image/webp'
    : lcpPreloadHref?.endsWith('.jpg') || lcpPreloadHref?.endsWith('.jpeg') ? 'image/jpeg'
    : undefined);

// Absolute URLs for canonical + og:url + og:image. Reads from astro.config.mjs
// `site` field via Astro.site. At DNS cutover the `site` field flips to the
// production domain and every page's canonical follows automatically.
//
// Trailing-slash normalization: pair with astro.config.mjs trailingSlash:
// 'always' + vercel.json trailingSlash: true. Defensive — if a path ever
// comes through without trailing slash (dev mode edge cases, future config
// drift), canonical still emits the slash form so Google sees one canonical
// per page. Round-2 audit (2026-05-08) flagged duplicate-content pairs
// caused by per-request canonical that canonicalized each variant to itself.
const canonicalPath = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const canonicalURL = new URL(canonicalPath, Astro.site).href;
const ogImageURL = new URL(ogImage, Astro.site).href;

// Auto-detect inLanguage from canonical path. /es/* gets es-US; everything
// else gets en-US. Drives the WebPage entity below. When/if Spanish
// localization expands beyond /es/bowl/ (Phase 2 in spanish-localization.md),
// this single line handles all of it.
const inLanguage: "en-US" | "es-US" = canonicalPath.startsWith("/es/") ? "es-US" : "en-US";

// Auto-emit WebPage entity for every page (Stage 7 schema work,
// 2026-05-18). Provides inLanguage signal + entity-graph clarity
// for AI Overviews. dateModified + speakable opt-in via Base props
// — keep them empty unless the page genuinely qualifies; see the
// WebPage helper docstring in src/lib/schema.ts for the rules.
const webPage = webPageSchema({
  url: canonicalURL,
  name: title,
  description,
  inLanguage,
  dateModified,
  speakable,
});
---
<!doctype html>
<html lang={inLanguage}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0E0A1F" />

    {/* Favicons — Pin logo at multiple sizes (Favicon-100p source).
        Astro-default favicon.svg deleted 2026-05-08 — wrong brand. */}
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    {/* max-video-preview: allow Google to surface unlimited preview length
        in SERP for any video on the page. Our section videos are short
        loops (4-15s) — letting the full clip preview reads stronger than
        the default cropped preview, and there's no IP risk on ambient
        venue footage. Per Google's video best-practices doc, value "-1"
        means "no limit." Applies site-wide via Base.astro. */}
    <meta name="robots" content="max-video-preview:-1" />

    {/* Canonical URL — single source of truth for which URL Google indexes. */}
    <link rel="canonical" href={canonicalURL} />

    {/* Open Graph — controls preview cards on Facebook, LinkedIn, iMessage,
        Slack, Discord, etc. og:image is 1200x630 (1.91:1) for the
        large-image card layout. Per-page Props override the defaults. */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Twisted Pin" />
    <meta property="og:locale" content={inLanguage.replace("-", "_")} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />

    {/* Twitter Card — same content, Twitter-namespaced. summary_large_image
        is the big-image layout; falls back to summary if image fails. */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    {/* Auto-emitted WebPage entity (Stage 7 schema work, 2026-05-18).
        Every page gets one — provides inLanguage signal + entity-graph
        clarity for AI Overviews / ChatGPT / Perplexity. Pages opt in
        to dateModified + speakable via Base props (see prop docstrings
        + src/lib/schema.ts webPageSchema docstring for the rules on
        what counts as honest dateModified). */}
    <script type="application/ld+json" set:html={JSON.stringify(webPage)} />

    {/* Per-page head injection — used by draft / staging pages to add
        noindex, by article-style pages for canonical links, etc. */}
    <slot name="head" />

    {/* Microsoft Clarity — free UX heatmaps + session recordings.
        Async load (t.async=1) so it never blocks LCP. Cookieless by
        default; no consent banner needed. is:inline keeps Astro from
        processing the script — it ships exactly as Clarity provides. */}
    <script is:inline>
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "wq8e536e4r");
    </script>

    {/* ===========================================================
        Google Analytics 4 + Meta Pixel — queue-immediately, fetch-late
        ===========================================================
        Both tracking pixels follow the same two-stage pattern:
          1. Inline stub sets up the global function (gtag / fbq) and
             its queue array. This is tiny (~1KB total for both) and
             runs synchronously during head parse.
          2. The page calls config() / init() / track('PageView')
             immediately — these calls QUEUE into the stub's array,
             they do not fetch anything yet.
          3. The heavy script downloads (gtag.js ~50KB, fbevents.js
             ~70KB) defer until requestIdleCallback OR first user
             interaction (whichever fires first). When they load,
             they consume the queue and dispatch every queued event.

        Why this matters: a naive install with <script async> in head
        still competes for connection slots and CPU during LCP. This
        pattern keeps the heavy scripts entirely out of the LCP
        critical path while still tracking 100% of legitimate
        visitors (anyone who interacts OR stays past idle).

        Trade-off accepted: visitors who bounce in <1-2 seconds
        without any interaction won't be tracked. For ad attribution
        this is a feature — bouncers don't convert, so tracking
        them adds noise without value.

        Conversion attribution flow:
          - GA4 events marked as "Conversions" in GA4 admin
          - GA4 → auto-imports into Google Ads as conversion goals
          - Meta Pixel events match Meta's standard event vocabulary
            (PageView, Contact, Lead, InitiateCheckout, FindLocation)
          - Cross-domain linker preserves click_id across Roller,
            event.twistedpin.com, and Zite (when Avery is on).
        =========================================================== */}
    <script is:inline>
      // GA4 + Google Ads stubs — gtag() and dataLayer queue available
      // immediately. Both identifiers route through the same gtag.js
      // script, so a second config call just adds another tag to
      // dispatch to (no extra network request).
      window.dataLayer = window.dataLayer || [];
      window.gtag = function(){ window.dataLayer.push(arguments); };
      window.gtag('js', new Date());
      // GA4 — pageviews + custom interaction events (analytics + GA4-side
      // conversion goals that auto-import into Google Ads).
      window.gtag('config', 'G-R64WB0Y4VW', {
        // Cross-domain linker preserves Google click_id (gclid) across
        // referral hops. Add new destinations here when funnel changes:
        //   - ecom.roller.app: lane reservations
        //   - event.twistedpin.com: Heyflow event form (Avery OFF)
        //   - twistedevents.zite.so: Zite event form (Avery ON)
        linker: { domains: ['ecom.roller.app', 'event.twistedpin.com', 'twistedevents.zite.so'] }
      });
      // Google Ads (AW-) — enables native Ads conversion tracking +
      // remarketing audiences. Conversion actions configured in Google
      // Ads UI dispatch via gtag('event', 'conversion', { send_to: 'AW-961151619/LABEL' });
      // adding this config alongside the GA4 one means specific Ads
      // conversion sends can target either tag.
      window.gtag('config', 'AW-961151619');

      // Meta Pixel stub — defines fbq() function and queue. Does NOT
      // inject fbevents.js (that's deferred to interaction below).
      (function(f){
        if (f.fbq) return;
        var n = f.fbq = function(){ n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments); };
        if (!f._fbq) f._fbq = n;
        n.push = n; n.loaded = true; n.version = '2.0'; n.queue = [];
      })(window);
      window.fbq('init', '106774361588990');
      window.fbq('track', 'PageView');

      // Heavy script loader — fires once on first qualifying signal.
      (function(){
        var loaded = false;
        function loadAdScripts(){
          if (loaded) return;
          loaded = true;
          // GA4 gtag.js
          var ga = document.createElement('script');
          ga.async = true;
          ga.src = 'https://www.googletagmanager.com/gtag/js?id=G-R64WB0Y4VW';
          document.head.appendChild(ga);
          // Meta fbevents.js
          var fb = document.createElement('script');
          fb.async = true;
          fb.src = 'https://connect.facebook.net/en_US/fbevents.js';
          document.head.appendChild(fb);
        }

        // Defer to requestIdleCallback (Chrome/FF/Edge) when browser is idle,
        // OR to a setTimeout fallback (Safari), OR to first user interaction
        // (likely sooner than either). Whichever fires first wins.
        var idle = window.requestIdleCallback || function(cb){ setTimeout(cb, 2500); };
        function scheduleIdle(){ idle(loadAdScripts, { timeout: 4000 }); }
        if (document.readyState === 'complete') {
          scheduleIdle();
        } else {
          window.addEventListener('load', scheduleIdle, { once: true });
        }
        ['mousemove','touchstart','scroll','keydown','click'].forEach(function(t){
          window.addEventListener(t, loadAdScripts, { once: true, passive: true });
        });
      })();
    </script>
    <noscript>
      {/* Meta Pixel JS-disabled fallback — fires a PageView via pixel image. */}
      <img height="1" width="1" style="display:none"
           src="https://www.facebook.com/tr?id=106774361588990&ev=PageView&noscript=1"
           alt="" />
    </noscript>

    {/* Hero LCP preloads — poster image is the LCP element, not the video.
        ONLY emitted on the homepage. Was previously unconditional, which
        meant every pillar page (which has a TYPOGRAPHY hero, not a video
        hero) was preloading 104 KB + 176 KB of unused imagery at
        fetchpriority="high", starving the connection slots used by the
        per-page lcpPreloadHref poster. Caught 2026-05-17 after PSI
        variance showed pillar pages with cheap AVIF posters (24-79 KB)
        scoring worse than expected — the unused hero preload was
        outranking the real LCP element in the preload-scanner queue. */}
    {Astro.url.pathname === '/' && (
      <>
        <link
          rel="preload"
          as="image"
          href="/hero/hero-poster.webp"
          type="image/webp"
          fetchpriority="high"
          media="(max-width: 1024px)"
        />
        <link
          rel="preload"
          as="image"
          href="/hero/hero-desktop-poster.webp"
          type="image/webp"
          fetchpriority="high"
          media="(min-width: 1025px)"
        />
      </>
    )}

    {/* Per-page LCP poster preload — opt-in via Base.astro lcpPreloadHref
        prop. Pillar pages whose first section video poster lands inside
        the initial mobile viewport (typography hero is shorter than the
        viewport, so the section video frame's top is visible) need their
        poster preloaded with fetchpriority="high" — otherwise the lazy
        data-poster pattern (sectionVideo() in motion.client.ts) delays
        the poster fetch until after JS parses + module imports + double
        RAF + IntersectionObserver setup, which is what's pushing LCP to
        4-7s on /events /game /vip-suite /fundraisers in Lighthouse
        mobile synthetic tests.

        Same pattern as the homepage hero poster preload above; just
        per-page rather than global. */}
    {lcpPreloadHref && (
      <link
        rel="preload"
        as="image"
        href={lcpPreloadHref}
        type={derivedPreloadType}
        fetchpriority="high"
        media={lcpPreloadMedia}
      />
    )}
  </head>
  <body>
    {/* Persistent chrome — fixed to the top of the viewport.
        Coupon page lives in the NavDrawer (Visit section); no banner. */}
    {!hideHeader && (
      <div class="site-chrome">
        <SiteHeader />
      </div>
    )}

    {/* <main> landmark wraps every page's primary content (a11y +
        SEO). The homepage's old `<main class="snap">` was changed to
        `<div class="snap">` in the same change so we don't double-nest.
        `id="main"` is forward-looking for a future skip-to-content link
        — adding it now is harmless and saves a refactor later. */}
    <main id="main">
      <slot />
    </main>

    <NavDrawer />
    {!hideStickyCTA && <StickyCTABar />}
    <PromoBar />

    {/* Vercel Web Analytics — cookieless pageview beacon. Free tier on Pro.
        No PII, no consent banner needed. Auto-detects the project from
        the deployment environment. */}
    <Analytics />

    <script>
      import { initMotion } from "../scripts/motion.client.ts";
      import { initClickTracking } from "../scripts/track-clicks.client.ts";
      initMotion();
      initClickTracking();
    </script>

    <style is:global>
      /* The fixed chrome wrapper. Children flow normally inside it; banner
         collapse animates height → 0 and the header rises naturally. */
      .site-chrome {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 20;
      }
    </style>
  </body>
</html>
