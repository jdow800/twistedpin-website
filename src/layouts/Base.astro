---
import "../styles/global.css";
import StickyCTABar from "../components/StickyCTABar.astro";
import NavDrawer from "../components/NavDrawer.astro";
import SiteHeader from "../components/SiteHeader.astro";
import PromoBar from "../components/PromoBar.astro";
import Analytics from "@vercel/analytics/astro";

interface Props {
  title?: string;
  description?: string;
  /** Override og:image / twitter:image. Path is relative to site root.
   *  Defaults to /og/og-default.jpg (catering buffet shot). Per-page
   *  overrides should be 1200x630 px, JPG or PNG. */
  ogImage?: string;
  /** og:image:alt — describes the image itself, not the page. */
  ogImageAlt?: string;
  /** og:type — defaults to "website". Use "article" for blog posts. */
  ogType?: string;
  /** Hide the global sticky CTA bar (e.g. on the booking flow). */
  hideStickyCTA?: boolean;
  /** Hide the persistent header (rare — full-bleed campaign pages). */
  hideHeader?: boolean;
}

const {
  title = "Twisted Pin — Plainfield, IL",
  description = "Cocktails, 28 self-serve taps, and a 6-lane VIP suite. Built for adults. Plainfield, IL.",
  ogImage = "/og/og-default.jpg",
  ogImageAlt = "A catering buffet set up at Twisted Pin in Plainfield, IL",
  ogType = "website",
  hideStickyCTA = false,
  hideHeader = false,
} = Astro.props;

// Absolute URLs for canonical + og:url + og:image. Reads from astro.config.mjs
// `site` field via Astro.site. At DNS cutover the `site` field flips to the
// production domain and every page's canonical follows automatically.
//
// Trailing-slash normalization: pair with astro.config.mjs trailingSlash:
// 'always' + vercel.json trailingSlash: true. Defensive — if a path ever
// comes through without trailing slash (dev mode edge cases, future config
// drift), canonical still emits the slash form so Google sees one canonical
// per page. Round-2 audit (2026-05-08) flagged duplicate-content pairs
// caused by per-request canonical that canonicalized each variant to itself.
const canonicalPath = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const canonicalURL = new URL(canonicalPath, Astro.site).href;
const ogImageURL = new URL(ogImage, Astro.site).href;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0E0A1F" />

    {/* Favicons — Pin logo at multiple sizes (Favicon-100p source).
        Astro-default favicon.svg deleted 2026-05-08 — wrong brand. */}
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    {/* Canonical URL — single source of truth for which URL Google indexes. */}
    <link rel="canonical" href={canonicalURL} />

    {/* Open Graph — controls preview cards on Facebook, LinkedIn, iMessage,
        Slack, Discord, etc. og:image is 1200x630 (1.91:1) for the
        large-image card layout. Per-page Props override the defaults. */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Twisted Pin" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />

    {/* Twitter Card — same content, Twitter-namespaced. summary_large_image
        is the big-image layout; falls back to summary if image fails. */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    {/* Per-page head injection — used by draft / staging pages to add
        noindex, by article-style pages for canonical links, etc. */}
    <slot name="head" />

    {/* Microsoft Clarity — free UX heatmaps + session recordings.
        Async load (t.async=1) so it never blocks LCP. Cookieless by
        default; no consent banner needed. is:inline keeps Astro from
        processing the script — it ships exactly as Clarity provides. */}
    <script is:inline>
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "wq8e536e4r");
    </script>

    {/* Hero LCP preloads — poster image is the LCP element, not the video. */}
    <link
      rel="preload"
      as="image"
      href="/hero/hero-poster.webp"
      type="image/webp"
      fetchpriority="high"
      media="(max-width: 1024px)"
    />
    <link
      rel="preload"
      as="image"
      href="/hero/hero-desktop-poster.webp"
      type="image/webp"
      fetchpriority="high"
      media="(min-width: 1025px)"
    />
  </head>
  <body>
    {/* Persistent chrome — fixed to the top of the viewport.
        Coupon page lives in the NavDrawer (Visit section); no banner. */}
    {!hideHeader && (
      <div class="site-chrome">
        <SiteHeader />
      </div>
    )}

    {/* <main> landmark wraps every page's primary content (a11y +
        SEO). The homepage's old `<main class="snap">` was changed to
        `<div class="snap">` in the same change so we don't double-nest.
        `id="main"` is forward-looking for a future skip-to-content link
        — adding it now is harmless and saves a refactor later. */}
    <main id="main">
      <slot />
    </main>

    <NavDrawer />
    {!hideStickyCTA && <StickyCTABar />}
    <PromoBar />

    {/* Vercel Web Analytics — cookieless pageview beacon. Free tier on Pro.
        No PII, no consent banner needed. Auto-detects the project from
        the deployment environment. */}
    <Analytics />

    <script>
      import { initMotion } from "../scripts/motion.client.ts";
      initMotion();
    </script>

    <style is:global>
      /* The fixed chrome wrapper. Children flow normally inside it; banner
         collapse animates height → 0 and the header rises naturally. */
      .site-chrome {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 20;
      }
    </style>
  </body>
</html>
