---
/**
 * SiteHeader — persistent top header. Rendered globally by Base.astro,
 * lives inside the .site-chrome wrapper.
 *
 * Desktop (≥1025px):
 *   [Logo] [BAR EAT BOWL GAME EVENTS VIP SUITE]   [Reserve] [Plan] [☰]
 * Mobile (≤1024px):
 *   [Logo]                                                          [☰]
 *
 * Active-page indicator: 1px Glow underline below the active link only —
 * NOT applied on hover. Per locked decision (Phase 1 build spec round).
 *
 * MORE dropdown was retired 2026-05-05. The hamburger ☰ now appears at
 * ALL viewports and opens the same NavDrawer mobile uses — one drawer
 * surface for the long tail (Coupon / Waitlist / Leagues / Rewards /
 * Gift Cards / FAQ / Find Us / Careers / Upcoming Events). Drawer's
 * 3-section accordion (Experience / Visit / Info) earns the categorization
 * that the 260px-wide dropdown couldn't.
 *
 * Background: light translucent scrim + backdrop blur. One static recipe
 * that has to read on hero video, on Midnight Indigo solids, and on the
 * Indigo Deep footer — same pattern as the hamburger button.
 */
import NavToggle from "./NavToggle.astro";
import { PLAN_EVENT_URL } from "../lib/links";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

interface NavItem { href: string; label: string }

// Inline nav: 7 items. Menu added 2026-05-05 — the /menu/* pages (cocktails,
// taps, food) shipped earlier today are otherwise only reachable from /bar
// and /eat editorial CTAs, which makes them invisible to direct/search
// traffic. Slot between Eat and Bowl groups it with the F&B pillars
// (the user thinking about food/drinks finds the menu in the same cluster).
// VIP Suite stays at the right end as the natural events→suite pairing.
// The drawer (opened via the ☰ at the right of the header) carries the
// secondary utility surfaces.
const navItems: NavItem[] = [
  { href: "/bar/",       label: "Bar"       },
  { href: "/eat/",       label: "Eat"       },
  { href: "/menu/",      label: "Menu"      },
  { href: "/bowl/",      label: "Bowl"      },
  { href: "/game/",      label: "Game"      },
  { href: "/events/",    label: "Events"    },
  { href: "/vip-suite/", label: "VIP Suite" },
];

// Active match: exact path OR any sub-path under it. Deep match matters
// for /menu/ — the inline MENU item should stay highlighted on
// /menu/cocktails, /menu/taps, /menu/food. Other pillars don't have
// sub-pages today, so the subpath branch is a no-op for them.
const isActive = (href: string) => {
  const trimmed = href.replace(/\/$/, "");
  return currentPath === trimmed || currentPath.startsWith(trimmed + "/");
};
---
<header class="site-header" data-site-header>
  {/* Left group: logo + (desktop) inline nav */}
  <div class="header-left">
    <a class="site-logo" href="/" aria-label="Twisted Pin home">
      <picture>
        <source type="image/webp" srcset="/logo/twisted-pin-horizontal-white.webp" />
        <img
          src="/logo/twisted-pin-horizontal-white.png"
          alt="Twisted Pin"
          width="360"
          height="154"
          decoding="async"
          fetchpriority="high"
        />
      </picture>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <ul>
        {navItems.map(item => (
          <li>
            <a
              href={item.href}
              class={isActive(item.href) ? "active" : ""}
              aria-current={isActive(item.href) ? "page" : undefined}
            >{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>

  {/* Right group: (desktop) two CTAs + hamburger; (mobile) hamburger only.
      The hamburger sits to the right of the CTAs at desktop, opens the
      shared NavDrawer (the same surface mobile uses). Replaces the
      previous MORE ▼ dropdown — see header docstring for rationale. */}
  <div class="header-right">
    <div class="site-cta-cluster">
      <a class="btn btn-solid" href="https://ecom.roller.app/twistedpin/openbowl/en-us/home" target="_blank" rel="noopener">Reserve a lane</a>
      <a class="btn btn-outline" href={PLAN_EVENT_URL} target="_blank" rel="noopener">Plan an event</a>
    </div>
    <NavToggle />
  </div>
</header>

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    /* Vertical padding tightened 10→2 (2026-05-11) when logo bumped +40%.
       The logo itself now fills the band that used to have ~10px of empty
       blur on each side; band total height stays at ~original mobile
       height (~61px) instead of growing with the logo. */
    padding: 2px 22px;
    /* Light scrim so the header reads on video, on Midnight Indigo, and on
       Indigo Deep without ever feeling like a heavy clubhouse band. */
    background: rgba(14, 10, 31, 0.40);
    backdrop-filter: blur(12px) saturate(140%);
    -webkit-backdrop-filter: blur(12px) saturate(140%);
    border-bottom: 1px solid rgba(244, 239, 227, 0.08);
  }
  @media (min-width: 1025px) {
    .site-header { padding: 2px 40px; }
  }

  .header-left,
  .header-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  @media (min-width: 1025px) {
    .header-left { gap: 32px; }
    .header-right { gap: 16px; }
  }

  /* ---------- logo ---------- */
  .site-logo {
    line-height: 0;
    display: inline-flex;
    flex: 0 0 auto;
    filter: drop-shadow(0 1px 6px rgba(14, 10, 31, 0.5));
  }
  .site-logo img {
    height: 57px;
    width: auto;
    display: block;
  }
  @media (min-width: 1025px) {
    .site-logo img { height: 78px; }
  }

  /* ---------- inline nav (desktop only) ---------- */
  .site-nav { display: none; }
  @media (min-width: 1025px) { .site-nav { display: block; } }

  .site-nav > ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  /* Inline nav-link styling. Horizontal padding tightened from 12 → 10
     2026-05-05 to fit 7 items in the desktop chrome at the 1025px
     breakpoint without overflowing past the CTA cluster. Underline
     left/right matches the padding. */
  .site-nav > ul > li > a {
    display: inline-block;
    position: relative;
    padding: 10px 10px;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--warm-mid);
    background: transparent;
    border: 0;
    cursor: pointer;
    transition: color 150ms ease-out;
  }
  .site-nav > ul > li > a:hover { color: var(--glow); }

  /* Active-page underline — applies ONLY to the current page, never on
     hover. Per locked decision. The ::after sits 4px below the text,
     padded to the link's text edges (matches the link's horizontal padding). */
  .site-nav > ul > li > a.active { color: var(--warm-white); }
  .site-nav > ul > li > a.active::after {
    content: "";
    position: absolute;
    left: 10px;
    right: 10px;
    bottom: 4px;
    height: 1px;
    background: var(--glow);
  }

  /* ---------- CTA cluster (desktop only) ---------- */
  .site-cta-cluster {
    display: none;
    align-items: center;
    gap: 8px;
  }
  @media (min-width: 1025px) {
    .site-cta-cluster { display: inline-flex; }
  }
  .site-cta-cluster .btn { padding: 12px 18px; font-size: 12px; }
</style>
