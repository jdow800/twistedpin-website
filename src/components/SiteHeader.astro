---
/**
 * SiteHeader — persistent top header. Rendered globally by Base.astro,
 * lives inside the .site-chrome wrapper alongside CouponBanner.
 *
 * Desktop (≥1025px):
 *   [Logo] [BAR EAT BOWL GAME EVENTS MORE▼]   [Reserve] [Plan]
 * Mobile (≤1024px):
 *   [Logo]                                                [☰]
 *
 * Active-page indicator: 1px Glow underline below the active link only —
 * NOT applied on hover. Per locked decision (Phase 1 build spec round).
 *
 * MORE dropdown is click-only (no hover-open). Reasons logged in build spec:
 * hover dropdowns are unreliable on touch devices in 1024–1279px, click-only
 * is the accessibility default, and the ▼ caret is sufficient discoverability.
 *
 * Background: light translucent scrim + backdrop blur. One static recipe
 * that has to read on hero video, on Midnight Indigo solids, and on the
 * Indigo Deep footer — same pattern as the hamburger button.
 */
import NavToggle from "./NavToggle.astro";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

interface NavItem { href: string; label: string }

// Inline nav: 6 items (was 5). VIP Suite promoted to inline 2026-05-04 —
// it's the tier-1 conversion page (revenue engine), and the desktop chrome
// has plenty of room for a sixth label. Sits to the right of Events as
// the natural pairing (events → suite is the common journey). MORE
// dropdown carries the secondary utility surfaces only.
const navItems: NavItem[] = [
  { href: "/bar/",       label: "Bar"       },
  { href: "/eat/",       label: "Eat"       },
  { href: "/bowl/",      label: "Bowl"      },
  { href: "/game/",      label: "Game"      },
  { href: "/events/",    label: "Events"    },
  { href: "/vip-suite/", label: "VIP Suite" },
];

// MORE dropdown — grouped into 2 sections with labels + a divider
// (2026-05-04 polish). Splits the 7 items into "Programs & Events"
// (recurring engagement: leagues, rewards, what's on) vs "Useful"
// (utility surfaces: gift cards, FAQ, contact, careers). Section
// labels are aria-hidden — they're decoration for sighted scanning;
// each menuitem keeps its own role for screen readers.
interface MoreSection { label: string; items: NavItem[]; }
const moreSections: MoreSection[] = [
  {
    label: "Programs & Events",
    items: [
      { href: "/upcoming-events/", label: "Upcoming Events" },
      { href: "/leagues/",         label: "Leagues"         },
      { href: "/rewards/",         label: "Rewards"         },
    ],
  },
  {
    label: "Useful",
    items: [
      { href: "/gift-cards/", label: "Gift Cards" },
      { href: "/faq/",        label: "FAQ"        },
      { href: "/contact/",    label: "Contact"    },
      { href: "/careers/",    label: "Careers"    },
    ],
  },
];

const isActive = (href: string) =>
  currentPath === href.replace(/\/$/, "");
---
<header class="site-header" data-site-header>
  {/* Left group: logo + (desktop) inline nav */}
  <div class="header-left">
    <a class="site-logo" href="/" aria-label="Twisted Pin home">
      <picture>
        <source type="image/webp" srcset="/logo/twisted-pin-horizontal-white.webp" />
        <img
          src="/logo/twisted-pin-horizontal-white.png"
          alt="Twisted Pin"
          width="298"
          height="128"
          decoding="async"
          fetchpriority="high"
        />
      </picture>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <ul>
        {navItems.map(item => (
          <li>
            <a
              href={item.href}
              class={isActive(item.href) ? "active" : ""}
              aria-current={isActive(item.href) ? "page" : undefined}
            >{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>

  {/* Right group: (desktop) two CTAs + MORE meta-nav + (mobile) hamburger.
      MORE was previously the last item inside the inline nav UL. Moved out
      during 2C polish — its dropdown was overlapping content because the
      MORE button sat near the center of the header. As a meta-control
      (rather than a destination like BAR/EAT/BOWL/GAME/EVENTS), MORE
      belongs grouped with the action region anyway. Now sits after the
      CTAs; its dropdown right-aligns to its button which is at viewport-
      right, opening into the right gutter outside the content cluster. */}
  <div class="header-right">
    <div class="site-cta-cluster">
      <a class="btn btn-solid" href="/reserve">Reserve a lane</a>
      <a class="btn btn-outline" href="/events">Plan an event</a>
    </div>
    <div class="has-dropdown header-more">
      <button
        type="button"
        class="more-toggle"
        data-more-toggle
        aria-expanded="false"
        aria-haspopup="menu"
        aria-controls="site-more-menu"
      >
        More
        <span class="caret" aria-hidden="true">▼</span>
      </button>
      <ul
        id="site-more-menu"
        class="more-dropdown"
        data-more-menu
        role="menu"
        hidden
      >
        {moreSections.map((section, i) => (
          <>
            {i > 0 && <li role="separator" class="more-divider" aria-hidden="true"></li>}
            <li class="more-section-label" aria-hidden="true">{section.label}</li>
            {section.items.map(item => (
              <li role="none">
                <a
                  role="menuitem"
                  href={item.href}
                  class={isActive(item.href) ? "active" : ""}
                >{item.label}</a>
              </li>
            ))}
          </>
        ))}
      </ul>
    </div>
    <NavToggle />
  </div>
</header>

<script>
  /* MORE dropdown — click-only per locked decision.
     - Click toggle: opens/closes
     - Click outside: closes
     - Escape: closes and returns focus to the toggle */
  const moreToggle = document.querySelector<HTMLButtonElement>("[data-more-toggle]");
  const moreMenu = document.querySelector<HTMLElement>("[data-more-menu]");

  if (moreToggle && moreMenu) {
    const setOpen = (open: boolean) => {
      moreToggle.setAttribute("aria-expanded", String(open));
      if (open) moreMenu.removeAttribute("hidden");
      else moreMenu.setAttribute("hidden", "");
    };

    moreToggle.addEventListener("click", (e) => {
      e.stopPropagation();
      setOpen(moreToggle.getAttribute("aria-expanded") !== "true");
    });

    document.addEventListener("click", (e) => {
      const t = e.target as Element | null;
      if (!t?.closest(".has-dropdown")) setOpen(false);
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && moreToggle.getAttribute("aria-expanded") === "true") {
        setOpen(false);
        moreToggle.focus();
      }
    });
  }
</script>

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 10px 22px;
    /* Light scrim so the header reads on video, on Midnight Indigo, and on
       Indigo Deep without ever feeling like a heavy clubhouse band. */
    background: rgba(14, 10, 31, 0.40);
    backdrop-filter: blur(12px) saturate(140%);
    -webkit-backdrop-filter: blur(12px) saturate(140%);
    border-bottom: 1px solid rgba(244, 239, 227, 0.08);
  }
  @media (min-width: 1025px) {
    .site-header { padding: 10px 40px; }
  }

  .header-left,
  .header-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  @media (min-width: 1025px) {
    .header-left { gap: 32px; }
    .header-right { gap: 16px; }
  }

  /* ---------- logo ---------- */
  .site-logo {
    line-height: 0;
    display: inline-flex;
    flex: 0 0 auto;
    filter: drop-shadow(0 1px 6px rgba(14, 10, 31, 0.5));
  }
  .site-logo img {
    height: 41px;
    width: auto;
    display: block;
  }
  @media (min-width: 1025px) {
    .site-logo img { height: 56px; }
  }

  /* ---------- inline nav (desktop only) ---------- */
  .site-nav { display: none; }
  @media (min-width: 1025px) { .site-nav { display: block; } }

  /* Direct-child scope on the outer nav UL is critical — without `>`, this
     rule matches the MORE dropdown's inner UL too, turning the dropdown
     into a horizontal flex row that blows past 600px wide. (Verified via
     real overflow on the deploy.) */
  .site-nav > ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  /* Inline nav-link styling — scoped to direct children of the outer UL
     so the same rule doesn't bleed into dropdown anchors. */
  .site-nav > ul > li > a,
  .more-toggle {
    display: inline-block;
    position: relative;
    padding: 10px 12px;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--warm-mid);
    background: transparent;
    border: 0;
    cursor: pointer;
    transition: color 150ms ease-out;
  }
  .site-nav > ul > li > a:hover,
  .more-toggle:hover { color: var(--glow); }

  /* Active-page underline — applies ONLY to the current page, never on
     hover. Per locked decision. The ::after sits 4px below the text,
     padded to the link's text edges (matches the link's horizontal padding). */
  .site-nav > ul > li > a.active { color: var(--warm-white); }
  .site-nav > ul > li > a.active::after {
    content: "";
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 4px;
    height: 1px;
    background: var(--glow);
  }

  .more-toggle .caret {
    display: inline-block;
    margin-left: 6px;
    font-size: 0.7em;
    transition: transform 150ms ease-out;
  }
  .more-toggle[aria-expanded="true"] .caret { transform: rotate(180deg); }
  .more-toggle[aria-expanded="true"] { color: var(--warm-white); }

  /* ---------- MORE dropdown panel ---------- */
  .has-dropdown { position: relative; }
  .more-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    /* Anchor to the right edge of the MORE button and extend leftward.
       Width is content-driven (min-width 220px floor); fits inside the
       viewport at ≥1280px because the MORE button itself sits in the
       middle of the header. */
    right: 0;
    /* Explicit display:block so the dropdown isn't accidentally caught
       by `.site-nav ul { display: flex }` again (already scoped to
       direct child, but belt + suspenders). */
    display: block;
    /* Bumped 220 → 260 (2026-05-04 polish) — section labels + slightly
       wider items breathe better at 260px. */
    min-width: 260px;
    list-style: none;
    margin: 0;
    padding: 6px 0;

    /* Premium glass — picks up the header chrome but earns its own
       visual presence as a floating panel. The inset top highlight
       (1px warm-white at low opacity inside the box-shadow stack)
       simulates light catching the panel's top edge — the move that
       actually makes glass read as glass instead of as a flat tinted
       rectangle. Bg dropped to 0.55 so the blur clearly shows through
       (0.78 was still reading too solid against video). Stronger blur
       and saturate so the colors behind the panel come through with
       more life. */
    background: rgba(14, 10, 31, 0.55);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(244, 239, 227, 0.18);
    border-radius: var(--radius-button);
    box-shadow:
      /* inset top: lit edge — the move */
      inset 0 1px 0 rgba(244, 239, 227, 0.14),
      /* close: anchor against immediate background */
      0 4px 8px rgba(0, 0, 0, 0.20),
      /* mid: floating depth */
      0 12px 24px rgba(0, 0, 0, 0.30),
      /* far: lift off the surface */
      0 32px 64px rgba(0, 0, 0, 0.50);
    z-index: 25;
  }
  /* Hide when the trigger is closed — `[hidden]` from the HTML attribute
     gets overridden by display:block above without this. */
  .more-dropdown[hidden] { display: none; }
  .more-dropdown li { display: list-item; }
  .more-dropdown a {
    display: block;
    /* 10/18 → 11/20 (2026-05-04 polish) — slightly more breathing room. */
    padding: 11px 20px;
    font-family: var(--font-ui);
    font-weight: 600;
    /* Bumped 12 → 13 so each item lands a touch more confident. */
    font-size: 13px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--warm-mid);
    transition: color 150ms ease-out, background-color 150ms ease-out;
  }

  /* ---------- Section labels + dividers (2026-05-04) ---------- */
  /* Section label sits above each group as a tiny tracked eyebrow.
     Visually decorative — aria-hidden on the JSX side so screen readers
     skip it (each menuitem still self-identifies). Color is warm-dim so
     the label reads as label-not-link, no hover state. */
  .more-section-label {
    display: list-item;
    padding: 10px 20px 4px;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--warm-dim);
    /* Don't inherit the menu list-style; this isn't a navigable item. */
    pointer-events: none;
    user-select: none;
  }

  /* Section divider — thin warm-white line at low opacity between groups.
     Same opacity as the menuitem hover background underline so it reads
     as part of the system rather than an arbitrary rule. */
  .more-divider {
    display: list-item;
    margin: 6px 14px;
    padding: 0;
    height: 1px;
    background: rgba(244, 239, 227, 0.10);
    list-style: none;
    pointer-events: none;
  }
  .more-dropdown a:hover {
    color: var(--glow);
    background: rgba(244, 239, 227, 0.04);
  }
  .more-dropdown a.active { color: var(--warm-white); }

  /* ---------- CTA cluster (desktop only) ---------- */
  .site-cta-cluster {
    display: none;
    align-items: center;
    gap: 8px;
  }
  @media (min-width: 1025px) {
    .site-cta-cluster { display: inline-flex; }
  }
  .site-cta-cluster .btn { padding: 12px 18px; font-size: 12px; }

  /* ---------- MORE meta-nav (desktop only) ----------
     Sits in the right cluster after the CTAs. The 16px gap from
     .header-right's flex-gap separates it from the CTAs without a
     graphic divider — per locked decision: whitespace alone does the
     grouping work; a divider line would compete with the inline nav's
     1px Glow active-page underline (two thin-line treatments doing
     different jobs in the same header). */
  .header-more {
    display: none;
    align-items: center;
  }
  @media (min-width: 1025px) {
    .header-more { display: inline-flex; }
  }

  /* nav toggle responsive visibility lives in NavToggle.astro
     (scoped specificity beats `:global` from this component). */
</style>
