---
/**
 * Global navigation drawer — hamburger button (top-right of viewport) + slide-in overlay.
 *
 * Drawer header: Logo_Horizontal_GlowInTheDark image (replaces the earlier "The works." text).
 * Drawer body: placeholder section links with Lucide-style line icons, right-aligned.
 *
 * Icons: 4 lifted directly from Lucide (martini / calendar-days / utensils-crossed / map-pin)
 * and one hand-drawn bowling pin in matching stroke style — Lucide doesn't ship one.
 * `currentColor` lets the icons inherit the link's hover Glow without extra rules.
 */

type IconKey = 'martini' | 'bowling-pin' | 'calendar' | 'utensils' | 'map-pin';

interface Section {
  href: string;
  label: string;
  icon: IconKey;
}

const sections: Section[] = [
  { href: "/craft-bar/",  label: "Craft Bar", icon: "martini" },
  { href: "/vip-suite/",  label: "VIP Suite", icon: "bowling-pin" },
  { href: "/events/",     label: "Events",    icon: "calendar" },
  { href: "/menu/",       label: "Menu",      icon: "utensils" },
  { href: "/find-us/",    label: "Find Us",   icon: "map-pin" },
];

// Lucide stroke conventions: 24x24 viewBox, 2px stroke, round caps + joins, fill="none".
const ICON_PATHS: Record<IconKey, string> = {
  // lucide.dev/icons/martini
  'martini': '<path d="M8 22h8"/><path d="M12 11v11"/><path d="m19 3-7 8-7-8Z"/>',

  // hand-drawn — Lucide doesn't ship a bowling pin. Stylized: rounded head,
  // narrowing neck, wider body that tapers toward the base. Two short bands at the neck.
  'bowling-pin': '<path d="M12 3a3 3 0 0 0-3 3v1.5a3 3 0 0 1-.7 1.95C6.6 11.5 6 13.6 6 16c0 3 2.5 5 6 5s6-2 6-5c0-2.4-.6-4.5-2.3-6.55A3 3 0 0 1 15 7.5V6a3 3 0 0 0-3-3z"/><path d="M9.5 8h5"/><path d="M9 10h6"/>',

  // lucide.dev/icons/calendar-days
  'calendar': '<path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/>',

  // lucide.dev/icons/utensils-crossed
  'utensils': '<path d="m16 2-2.3 2.3a3 3 0 0 0 0 4.2l1.8 1.8a3 3 0 0 0 4.2 0L22 8"/><path d="M15 15 3.3 3.3a4.2 4.2 0 0 0 0 6l7.3 7.3c.7.7 2 .7 2.8 0L15 15Zm0 0 7 7"/><path d="m2.1 21.8 6.4-6.3"/><path d="m19 5-7 7"/>',

  // lucide.dev/icons/map-pin
  'map-pin': '<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>',
};
---
<button
  type="button"
  class="nav-toggle"
  data-nav-toggle
  aria-controls="nav-drawer"
  aria-expanded="false"
  aria-label="Open menu"
>
  <span class="bar" aria-hidden="true"></span>
  <span class="bar" aria-hidden="true"></span>
</button>

<div class="nav-backdrop" data-nav-backdrop aria-hidden="true"></div>

<aside
  class="nav-drawer"
  id="nav-drawer"
  data-nav-drawer
  role="dialog"
  aria-modal="true"
  aria-labelledby="nav-drawer-title"
  aria-hidden="true"
>
  <div class="nav-drawer-head">
    <a class="nav-drawer-brand" href="/" aria-label="Twisted Pin home" id="nav-drawer-title">
      <picture>
        <source type="image/webp" srcset="/logo/twisted-pin-horizontal-glow.webp" />
        <img
          src="/logo/twisted-pin-horizontal-glow.png"
          alt="Twisted Pin"
          width="373"
          height="160"
          decoding="async"
        />
      </picture>
    </a>
    <button
      type="button"
      class="nav-close"
      data-nav-close
      aria-label="Close menu"
    >
      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="1.6" stroke-linecap="round">
        <line x1="6" y1="6" x2="18" y2="18" />
        <line x1="18" y1="6" x2="6" y2="18" />
      </svg>
    </button>
  </div>

  <nav class="nav-drawer-list" aria-label="Site sections">
    <ul>
      {sections.map(s => (
        <li>
          <a href={s.href}>
            <span class="label">{s.label}</span>
            <svg
              class="icon"
              viewBox="0 0 24 24"
              width="24"
              height="24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              set:html={ICON_PATHS[s.icon]}
            />
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="nav-drawer-foot">
    <p class="nav-meta">15610 S Joliet Rd · Plainfield, IL</p>
  </div>
</aside>

<style>
  /* ---------- hamburger toggle ----------
     One static treatment that has to read on every background type the
     site puts behind it: video frames (bright + busy), solid Midnight
     Indigo (snap-test stubs), and the indigo-deep footer. The combination:
       1. Translucent dark fill (works against video and lighter solids)
       2. Subtle warm-white border (defines the shape against same-color
          dark backgrounds — fixes the snap-8 invisibility we saw)
       3. Backdrop blur (legibility over busy video frames)
     Same recipe as the back-to-top button so the corners share a vocabulary. */
  .nav-toggle {
    position: fixed;
    z-index: 40;
    top: calc(16px + var(--safe-top));
    right: 16px;
    width: 44px;
    height: 44px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    background: rgba(14, 10, 31, 0.62);
    border: 1px solid rgba(244, 239, 227, 0.18);
    backdrop-filter: blur(10px) saturate(140%);
    -webkit-backdrop-filter: blur(10px) saturate(140%);
    border-radius: var(--radius-button);
    transition: background-color 150ms ease-out, border-color 150ms ease-out;
  }
  .nav-toggle:hover {
    background: rgba(14, 10, 31, 0.82);
    border-color: rgba(244, 239, 227, 0.32);
  }
  .nav-toggle .bar {
    display: block;
    width: 22px;
    height: 1.6px;
    background: var(--warm-white);
    border-radius: 1px;
  }

  /* Hamburger stays at top-right on every viewport — the desktop CTA bar
     has been moved to top-center (see StickyCTABar.astro), so the right
     corner is free. The earlier brittle `right: 360px` desktop override
     broke when the bar grew wider than 336px; not coming back. */
  @media (min-width: 1025px) {
    .nav-toggle {
      top: calc(20px + var(--safe-top));
    }
  }

  /* ---------- backdrop + drawer ---------- */
  .nav-backdrop {
    position: fixed;
    inset: 0;
    z-index: 50;
    background: rgba(14, 10, 31, 0.65);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease-out;
  }

  .nav-drawer {
    position: fixed;
    z-index: 60;
    top: 0;
    right: 0;
    height: 100vh;
    height: 100dvh;
    width: min(420px, 92vw);
    background: var(--indigo-deep);
    border-left: 1px solid var(--indigo-lift);
    box-shadow: -24px 0 60px rgba(0, 0, 0, 0.5);
    transform: translateX(100%);
    transition: transform 250ms cubic-bezier(0.22, 0.61, 0.36, 1);
    display: flex;
    flex-direction: column;
    padding: calc(24px + var(--safe-top)) 28px calc(24px + var(--safe-bottom));
  }

  body.nav-open .nav-backdrop {
    opacity: 1;
    pointer-events: auto;
  }
  body.nav-open .nav-drawer {
    transform: translateX(0);
  }

  /* ---------- drawer chrome ---------- */
  .nav-drawer-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 36px;
  }
  .nav-drawer-brand {
    line-height: 0;
    flex: 0 1 auto;
    min-width: 0;
  }
  .nav-drawer-brand img {
    /* Round 4: +30% from round-3's 56/64 per request. */
    height: 73px;
    width: auto;
    display: block;
    /* Glow logo on dark indigo — subtle drop shadow keeps it from feeling flat. */
    filter: drop-shadow(0 1px 0 rgba(78, 236, 196, 0.18));
  }
  @media (min-width: 1025px) {
    .nav-drawer-brand img { height: 84px; }
  }
  .nav-close {
    width: 40px;
    height: 40px;
    color: var(--warm-mid);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-button);
    transition: color 150ms ease-out, background-color 150ms ease-out;
  }
  .nav-close:hover {
    color: var(--warm-white);
    background: rgba(244, 239, 227, 0.06);
  }

  .nav-drawer-list {
    flex: 1;
    overflow-y: auto;
  }
  .nav-drawer-list ul { list-style: none; }
  .nav-drawer-list li + li { margin-top: 4px; }
  .nav-drawer-list a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid var(--indigo-lift);
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(28px, 5vw, 36px);
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.005em;
    color: var(--warm-white);
    transition: color 150ms ease-out;
  }
  .nav-drawer-list a:hover { color: var(--glow); }
  .nav-drawer-list .label { flex: 1 1 auto; min-width: 0; }
  .nav-drawer-list .icon {
    flex: 0 0 24px;
    width: 24px;
    height: 24px;
    color: currentColor;
    /* Slightly muted at rest so the type leads; brightens with link hover. */
    opacity: 0.78;
    transition: opacity 150ms ease-out, transform 150ms ease-out;
  }
  .nav-drawer-list a:hover .icon {
    opacity: 1;
    transform: translateX(2px);
  }

  .nav-drawer-foot {
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid var(--indigo-lift);
  }
  .nav-meta {
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--warm-dim);
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-drawer { transition: opacity 100ms ease-out; }
    body.nav-open .nav-drawer { transform: translateX(0); }
    .nav-drawer-list a:hover .icon { transform: none; }
  }
</style>
