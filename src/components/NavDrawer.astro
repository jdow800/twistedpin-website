---
/**
 * Global navigation drawer — slide-in overlay from the right.
 *
 * The hamburger button extracted to NavToggle.astro (mounted inside SiteHeader's
 * flex flow). This component renders the backdrop + drawer panel + content.
 *
 * Mobile nav rebuild 2026-05-04 (round 3): drawer expanded from 5 flat items
 * to 17 items in 3 sections (Experience / Visit / Info). Closes the
 * mobile-nav gap — previously mobile users could only reach 5 of the
 * 15+ destinations the desktop nav offered. Section labels (eyebrow style)
 * + per-item dividers handle the scannability work; item type dropped
 * from display 28-36px → UI 15px since 17 items in display would scroll
 * forever and feel shouty.
 *
 * Reserve a Lane and Plan an Event are duplicated here from the sticky CTA
 * bar — intentional per sitemap-tldr.md ("some users hunt for the hamburger
 * by habit"). They're regular drawer items (not button-styled) — the section
 * label "Visit" plus their position at top of section signals the intent.
 *
 * Find Us is a #find-us anchor that scrolls to the SnapFooter on the
 * current page. Same destination as the desktop MORE "Contact" item.
 *
 * Drawer header: Logo_Horizontal_GlowInTheDark image. Address line in footer.
 *
 * Icons: shared from src/lib/icons.ts (hoisted from per-component records on
 * 2026-05-04 — three uses triggered the rule of three: SiteHeader MORE,
 * NavDrawer items, and any future icon-using surface).
 */
import { ICON_PATHS, type IconKey } from "../lib/icons";
import { activeSeasonalItems } from "../config/nav-seasonal";

import { PLAN_EVENT_URL } from "../lib/links";

const ROLLER_URL = "https://ecom.roller.app/twistedpin/openbowl/en-us/home";

interface DrawerItem {
  href: string;
  label: string;
  icon: IconKey;
  external?: boolean;
  seasonal?: boolean;
}

interface DrawerSection {
  label: "Experience" | "Visit" | "Info";
  items: DrawerItem[];
}

const drawerSections: DrawerSection[] = [
  {
    label: "Experience",
    items: [
      // Home at the top — added 2026-05-12 in response to V4 + V8
      // tester friction ("can't figure out how to get back home").
      // Clickable logo affordance isn't reading on mobile; the drawer
      // is where users go when they're stuck. Home as the first
      // Experience item gives them an obvious way back.
      { href: "/",           label: "Home",      icon: "home"        },
      { href: "/bar/",       label: "Bar",       icon: "martini"     },
      { href: "/eat/",       label: "Eat",       icon: "utensils"    },
      { href: "/menu/",      label: "Menu",      icon: "book-open"   },
      { href: "/bowl/",      label: "Bowl",      icon: "bowling-ball" },
      { href: "/game/",      label: "Game",      icon: "gamepad"     },
      { href: "/events/",    label: "Events",    icon: "calendar"    },
      { href: "/vip-suite/", label: "VIP Suite", icon: "crown"       },
    ],
  },
  {
    label: "Visit",
    items: [
      // Reserve / Plan duplicated from sticky CTA bar. Intentional —
      // hamburger-hunters expect to find primary CTAs in the menu too.
      { href: ROLLER_URL,                   label: "Reserve a Lane",  icon: "calendar-check", external: true },
      { href: PLAN_EVENT_URL,              label: "Plan an Event",   icon: "message-square", external: true },
      { href: "/birthday-parties-booking/", label: "Birthday Parties",icon: "cake"           },
      { href: "/corporate-events/",         label: "Corporate Events",icon: "building-2"     },
      { href: "/upcoming-events/",          label: "Upcoming Events", icon: "calendar"       },
      { href: "/coupon/",                   label: "Coupon",          icon: "ticket"         },
      { href: "/waitlist/",                 label: "Waitlist",        icon: "clock"          },
    ],
  },
  {
    label: "Info",
    items: [
      { href: "/pricing/",     label: "Pricing",     icon: "tag"             },
      { href: "/leagues/",     label: "Leagues",     icon: "trophy"          },
      { href: "/rewards/",     label: "Rewards",     icon: "star"            },
      { href: "/fundraisers/", label: "Fundraisers", icon: "heart-handshake" },
      { href: "/gift-cards/",  label: "Gift Cards",  icon: "gift"            },
      { href: "/faq/",        label: "FAQ",        icon: "help"      },
      { href: "/careers/",    label: "Careers",    icon: "briefcase" },
      // Find Us = the contact destination per 2026-05-04 decision —
      // scrolls in-place to the SnapFooter (#find-us) which has address,
      // hours, phone, email. No dedicated /contact page.
      { href: "#find-us",     label: "Find Us",    icon: "map-pin"   },
    ],
  },
];

// Merge active seasonal items into their target section. Seasonal items
// render at the TOP of their section (most recent / time-bound first),
// flagged with `.is-seasonal` so the CSS can lift them visually.
for (const seasonal of activeSeasonalItems()) {
  const section = drawerSections.find((s) => s.label === seasonal.section);
  if (!section) continue;
  section.items.unshift({
    href: seasonal.href,
    label: seasonal.label,
    icon: seasonal.icon as IconKey,
    seasonal: true,
  });
}
---
<div class="nav-backdrop" data-nav-backdrop aria-hidden="true"></div>

<aside
  class="nav-drawer"
  id="nav-drawer"
  data-nav-drawer
  role="dialog"
  aria-modal="true"
  aria-labelledby="nav-drawer-title"
  aria-hidden="true"
>
  <div class="nav-drawer-head">
    <a class="nav-drawer-brand" href="/" aria-label="Twisted Pin home" id="nav-drawer-title">
      <picture>
        <source type="image/webp" srcset="/logo/twisted-pin-horizontal-glow.webp" />
        <img
          src="/logo/twisted-pin-horizontal-glow.png"
          alt="Twisted Pin"
          width="373"
          height="160"
          decoding="async"
        />
      </picture>
    </a>
    <button
      type="button"
      class="nav-close"
      data-nav-close
      aria-label="Close menu"
    >
      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="1.6" stroke-linecap="round">
        <line x1="6" y1="6" x2="18" y2="18" />
        <line x1="18" y1="6" x2="6" y2="18" />
      </svg>
    </button>
  </div>

  <div class="nav-drawer-body" data-drawer-body>
    {/* Quick Actions strip — high-traffic shortcuts that surface when the
        drawer is in its default state (all sections collapsed). The CSS
        rule `.nav-drawer-body:has(details[open]) .nav-quick-actions`
        collapses this strip the moment a user expands any section, so
        the section content sits up immediately under their tap.

        Chips picked 2026-05-11: Pricing (V5 tester couldn't find it),
        Coupon (direct conversion intent), Waitlist (Saturday-night
        decision tool), Menu (replaces what would otherwise be a
        time-bound seasonal slot — high permanent value).

        Reserve / Plan an Event are NOT here — they stay primary at the
        drawer foot. This strip is for *secondary* high-impact intents. */}
    <ul class="nav-quick-actions" aria-label="Quick actions">
      <li>
        <a href="/pricing/">
          <svg class="icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={ICON_PATHS["tag"]} />
          <span class="label">Pricing/Hours</span>
        </a>
      </li>
      <li>
        <a href="/coupon/">
          <svg class="icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={ICON_PATHS["ticket"]} />
          <span class="label">Coupon</span>
        </a>
      </li>
      <li>
        <a href="/waitlist/">
          <svg class="icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={ICON_PATHS["clock"]} />
          <span class="label">Waitlist</span>
        </a>
      </li>
      <li>
        <a href="/menu/">
          <svg class="icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={ICON_PATHS["book-open"]} />
          <span class="label">Menu</span>
        </a>
      </li>
    </ul>

    <nav class="nav-drawer-list" aria-label="Site sections">
      {drawerSections.map(section => (
        <details class="nav-section" name="nav-section">
          <summary class="nav-section-header">
            <span class="nav-section-label">{section.label}</span>
            <svg
              class="nav-section-chevron"
              viewBox="0 0 24 24"
              width="18"
              height="18"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              set:html={ICON_PATHS["chevron-down"]}
            />
          </summary>
          <ul>
            {section.items.map(item => (
              <li class:list={[item.seasonal && "is-seasonal"]}>
                <a
                  href={item.href}
                  {...(item.external ? { target: "_blank", rel: "noopener" } : {})}
                >
                  <svg
                    class="icon"
                    viewBox="0 0 24 24"
                    width="18"
                    height="18"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    set:html={ICON_PATHS[item.icon]}
                  />
                  <span class="label">{item.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </details>
      ))}
    </nav>
  </div>

  <div class="nav-drawer-foot">
    {/* In-drawer CTAs (2026-05-04 round 5). ABC — Always Be Converting.
        The viewport sticky bar is hidden while the drawer is open (via
        body.nav-open in global.css) since the drawer covers the right
        92vw — these duplicate the same Reserve / Plan recipe so users
        can convert without closing the drawer first. */}
    <div class="nav-drawer-cta">
      <a class="btn btn-solid" href={ROLLER_URL} target="_blank" rel="noopener">Reserve a Lane</a>
      <a class="btn btn-outline" href={PLAN_EVENT_URL} target="_blank" rel="noopener">Plan an Event</a>
    </div>
    <p class="nav-meta">15610 Joliet Rd · Plainfield, IL</p>
  </div>
</aside>

<style>
  /* Hamburger toggle styles live in NavToggle.astro — extracted because the
     button is now a flex child of SiteHeader, not a fixed-position element. */

  /* ---------- backdrop + drawer ----------
     2026-05-05: backdrop blur removed, dim dropped from 0.65 → 0.30
     so the main site reads clearly behind the drawer instead of being
     muddied. The light dim is intentional — preserves the
     click-outside-to-dismiss affordance without obscuring content. */
  .nav-backdrop {
    position: fixed;
    inset: 0;
    z-index: 50;
    background: rgba(14, 10, 31, 0.30);
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease-out;
  }

  .nav-drawer {
    position: fixed;
    z-index: 60;
    top: 0;
    right: 0;
    height: 100vh;
    height: 100dvh;
    width: min(420px, 92vw);
    background: var(--indigo-deep);
    border-left: 1px solid var(--indigo-lift);
    box-shadow: -24px 0 60px rgba(0, 0, 0, 0.5);
    transform: translateX(100%);
    transition: transform 250ms cubic-bezier(0.22, 0.61, 0.36, 1);
    display: flex;
    flex-direction: column;
    /* Padding bumped down on mobile (was 24px top) since the rebuilt drawer
       holds 17 items + 3 section labels + chrome — needs every bit of
       vertical space. Footer pushed tighter against the bottom edge too. */
    padding: calc(20px + var(--safe-top)) 24px calc(16px + var(--safe-bottom));
  }

  body.nav-open .nav-backdrop {
    opacity: 1;
    pointer-events: auto;
  }
  body.nav-open .nav-drawer {
    transform: translateX(0);
  }

  /* ---------- drawer chrome ---------- */
  .nav-drawer-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    /* Tighter than the previous 36px since we now have 3 sections worth
       of content competing for vertical space. */
    margin-bottom: 20px;
  }
  .nav-drawer-brand {
    line-height: 0;
    flex: 0 1 auto;
    min-width: 0;
  }
  .nav-drawer-brand img {
    /* Reduced from 73px (the 5-item drawer's logo treatment) to 56px so
       the logo doesn't crowd the 17-item nav below. Desktop bumps back up. */
    height: 56px;
    width: auto;
    display: block;
    /* Glow logo on dark indigo — subtle drop shadow keeps it from feeling flat. */
    filter: drop-shadow(0 1px 0 rgba(78, 236, 196, 0.18));
  }
  @media (min-width: 1025px) {
    .nav-drawer-brand img { height: 72px; }
  }
  .nav-close {
    width: 40px;
    height: 40px;
    color: var(--warm-mid);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-button);
    transition: color 150ms ease-out, background-color 150ms ease-out;
  }
  .nav-close:hover {
    color: var(--warm-white);
    background: rgba(244, 239, 227, 0.06);
  }

  /* ---------- nav body (scrollable wrapper) ----------
     Wraps the Quick Actions strip + the section list so `:has()` can
     evaluate the section state from a common ancestor. */
  .nav-drawer-body {
    flex: 1;
    overflow-y: auto;
    margin-right: -8px;
    padding-right: 8px;
    display: flex;
    flex-direction: column;
  }
  .nav-drawer-list {
    /* Scroll moved up to .nav-drawer-body so the Quick Actions strip
       scrolls in tandem with the section list. */
  }

  /* ---------- Quick Actions strip (2026-05-11) ----------
     Surfaces high-traffic shortcuts in the empty real estate when all
     sections are collapsed. Picked chips: Pricing, Coupon, Waitlist,
     Menu. Reserve / Plan stay primary at the drawer foot.

     The strip collapses (max-height + opacity + margin animate to 0)
     the moment any section opens, so the user's tap takes them
     straight to that section's items with no chip-grid pushing it
     down. Re-expands when they close back to default state.

     CSS-only via :has() — supported in Safari 15.4+ / Chrome 105+ /
     Firefox 121+. On older browsers (negligible mobile share in 2026),
     the strip stays visible even when a section is open. Graceful. */
  .nav-quick-actions {
    list-style: none;
    margin: 0 0 18px;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    /* Animated collapse target. max-height needs to be generous enough
       to fit the 2x2 grid at the largest expected chip height. */
    max-height: 240px;
    opacity: 1;
    overflow: hidden;
    transition:
      max-height 250ms cubic-bezier(0.22, 0.61, 0.36, 1),
      opacity 200ms ease-out,
      margin-bottom 250ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .nav-drawer-body:has(details[open]) .nav-quick-actions {
    max-height: 0;
    opacity: 0;
    margin-bottom: 0;
    pointer-events: none;
  }

  .nav-quick-actions a {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
    padding: 14px 14px 12px;
    min-height: 84px;
    border-radius: var(--radius-button);
    background: rgba(244, 239, 227, 0.04);
    border: 1px solid rgba(78, 236, 196, 0.18);
    color: var(--warm-white);
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 12.5px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    transition:
      background-color 150ms ease-out,
      border-color 150ms ease-out,
      color 150ms ease-out;
  }
  .nav-quick-actions a:hover,
  .nav-quick-actions a:focus-visible {
    background: rgba(78, 236, 196, 0.08);
    border-color: rgba(78, 236, 196, 0.55);
    color: var(--warm-white);
  }
  .nav-quick-actions .icon {
    width: 20px;
    height: 20px;
    color: var(--glow);
    opacity: 0.95;
    flex: 0 0 auto;
  }
  .nav-quick-actions .label {
    line-height: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-quick-actions { transition: none; }
  }

  /* ---------- Accordion sections ----------
     All three sections start collapsed (changed from Experience-open
     2026-05-11 to make room for the Quick Actions strip above). User
     taps a section header to expand. `name="nav-section"` makes the
     three sections an exclusive group — opening one auto-closes others.

     Uses native <details>/<summary> — accessible by default (keyboard,
     screen reader), no JS needed. Animation is browser-default (instant)
     because animating native <details> height is unreliable; the chevron
     rotation is the affordance for state change. */
  .nav-section + .nav-section {
    border-top: 1px solid var(--indigo-lift);
  }

  .nav-section-header {
    /* Full-width tap target — easier on mobile than a label-only target. */
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 4px;
    cursor: pointer;
    color: var(--warm-white);
    /* Hide the default <summary> marker (the disclosure triangle). */
    list-style: none;
    transition: color 150ms ease-out;
  }
  .nav-section-header::-webkit-details-marker { display: none; }
  .nav-section-header::marker { content: ""; }
  .nav-section-header:hover { color: var(--glow); }

  .nav-section-label {
    /* Bigger than a typical eyebrow because it's now a tap target —
       16px UI font, all caps, tracked. Lands like a section title
       rather than a quiet label. */
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .nav-section-chevron {
    flex: 0 0 18px;
    width: 18px;
    height: 18px;
    color: currentColor;
    opacity: 0.7;
    transition: transform 200ms ease, opacity 150ms ease-out;
  }
  .nav-section[open] > .nav-section-header .nav-section-chevron {
    transform: rotate(180deg);
  }
  .nav-section-header:hover .nav-section-chevron { opacity: 1; }

  /* Items list collapses with the section. Slight indent so items read
     as nested under their section header. Bottom margin gives breathing
     room before the next section's header. */
  .nav-section[open] > ul {
    padding-bottom: 8px;
  }

  .nav-drawer-list ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-drawer-list a {
    /* Icon LEFT, label right (mirror the desktop MORE pattern — icon
       leads). The previous 5-item drawer had label-left / icon-right
       because items were big display type and the icon was a quiet
       coda; with smaller UI items the icon does identification work
       and reads better leading. */
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 11px 4px;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--warm-white);
    transition: color 150ms ease-out;
  }
  .nav-drawer-list a:hover { color: var(--glow); }
  /* Per-item divider (matches desktop MORE rhythm). */
  .nav-drawer-list li + li > a {
    border-top: 1px solid rgba(244, 239, 227, 0.06);
  }
  .nav-drawer-list .label {
    flex: 1 1 auto;
    min-width: 0;
  }
  .nav-drawer-list .icon {
    flex: 0 0 18px;
    width: 18px;
    height: 18px;
    color: currentColor;
    opacity: 0.7;
    transition: opacity 150ms ease-out;
  }
  .nav-drawer-list a:hover .icon {
    opacity: 1;
  }

  /* Seasonal items get a Glow-tinted icon at full opacity — subtle
     "this is time-bound" affordance without shouting. Driven by the
     activeSeasonalItems() merge in the frontmatter; only fires when
     today is inside the item's window. */
  .nav-drawer-list li.is-seasonal > a .icon {
    color: var(--glow);
    opacity: 1;
  }

  /* ---------- footer ---------- */
  .nav-drawer-foot {
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid var(--indigo-lift);
  }

  /* In-drawer CTA pair (2026-05-04 round 5). Same recipe as the
     viewport sticky bar (Glow primary + warm-white outlined alternate)
     so the conversion units feel of-a-piece across surfaces. */
  .nav-drawer-cta {
    display: flex;
    gap: 10px;
    margin-bottom: 14px;
  }
  .nav-drawer-cta .btn {
    flex: 1;
    padding: 12px 16px;
    font-size: 11.5px;
  }

  .nav-meta {
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--warm-dim);
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-drawer { transition: opacity 100ms ease-out; }
    body.nav-open .nav-drawer { transform: translateX(0); }
  }
</style>
