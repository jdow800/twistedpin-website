---
/**
 * Homepage hero.
 *
 * Mobile (≤1024): vertical 9:16 video, poster as LCP, copy stack at bottom.
 * Desktop (≥1025): 16:9 video, copy stack lower-left.
 *
 * Brand mark only — primary conversion lives in the global StickyCTABar.
 *
 * Copy is locked — see Context/voice.md "Locked Lines (Approved)".
 */
---
<section class="hero" data-hero>
  {/* Brand mark — top-left, on top of media */}
  <a class="hero-brand" href="/" aria-label="Twisted Pin home">
    <picture>
      <source type="image/webp" srcset="/logo/twisted-pin-horizontal-white.webp" />
      <img
        src="/logo/twisted-pin-horizontal-white.png"
        alt="Twisted Pin"
        width="298"
        height="128"
        decoding="async"
        fetchpriority="high"
      />
    </picture>
  </a>

  {/* MOBILE — vertical video.
      poster preloaded in Base.astro <head>; preload="metadata" defers byte-fetch. */}
  <video
    class="hero-video hero-video-mobile"
    preload="metadata"
    muted
    autoplay
    loop
    playsinline
    poster="/hero/hero-poster.webp"
    aria-hidden="true"
  >
    <source src="/hero/hero-mobile-av1-1080.mp4" type="video/mp4; codecs=av01.0.05M.08" />
    <source src="/hero/hero-mobile-h264-1080.mp4" type="video/mp4" />
  </video>

  {/* DESKTOP — 16:9 video (placeholder until final clip is shot). */}
  <video
    class="hero-video hero-video-desktop"
    preload="metadata"
    muted
    autoplay
    loop
    playsinline
    poster="/hero/hero-desktop-poster.webp"
    aria-hidden="true"
  >
    <source src="/hero/hero-desktop-av1.mp4" type="video/mp4; codecs=av01.0.05M.08" />
    <source src="/hero/hero-desktop-h264.mp4" type="video/mp4" />
  </video>

  {/* Scrim for legibility */}
  <div class="hero-scrim" aria-hidden="true"></div>

  {/* Copy stack — eyebrow, two-line headline, subhead. No CTA in hero. */}
  <div class="hero-copy">
    <p class="t-eyebrow hero-eyebrow hero-fade" data-delay-ms="0">Plainfield, IL</p>
    <h1 class="t-display hero-headline">
      <span class="hero-headline-line hero-fade" data-delay-ms="0">Built&nbsp;for&nbsp;adults.</span>
      <span class="hero-headline-line hero-fade" data-delay-ms="300">Fine,&nbsp;bring&nbsp;the&nbsp;kids.</span>
    </h1>
    <p class="hero-sub hero-fade" data-delay-ms="380">
      Built by America's Top Mixologist. <em>(Their words, not ours.)</em>
    </p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    height: 100svh;
    min-height: 560px;
    overflow: hidden;
    background: #000;
  }

  /* ---------- brand mark ---------- */
  .hero-brand {
    position: absolute;
    z-index: 4;
    top: calc(20px + var(--safe-top));
    left: 22px;
    /* Wrap a fixed-height image — width auto-scales via the image's aspect ratio. */
    line-height: 0;
    filter: drop-shadow(0 1px 6px rgba(14, 10, 31, 0.5));
  }
  .hero-brand img {
    height: 28px;
    width: auto;
    display: block;
  }
  @media (min-width: 1025px) {
    .hero-brand { top: calc(24px + var(--safe-top)); left: 32px; }
    .hero-brand img { height: 32px; }
  }

  /* ---------- media ---------- */
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-video-mobile  { display: block; }
  .hero-video-desktop { display: none; }
  @media (min-width: 1025px) {
    .hero-video-mobile  { display: none; }
    .hero-video-desktop { display: block; }
  }

  /* ---------- scrim ---------- */
  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg,
        rgba(14, 10, 31, 0.45) 0%,
        rgba(14, 10, 31, 0.05) 22%,
        rgba(14, 10, 31, 0.05) 50%,
        rgba(14, 10, 31, 0.92) 92%,
        rgba(14, 10, 31, 1) 100%);
  }
  @media (min-width: 1025px) {
    .hero-scrim {
      background:
        linear-gradient(90deg,
          rgba(14, 10, 31, 0.85) 0%,
          rgba(14, 10, 31, 0.55) 30%,
          rgba(14, 10, 31, 0.10) 65%,
          rgba(14, 10, 31, 0)    100%);
    }
  }

  /* ---------- copy stack ---------- */
  .hero-copy {
    position: absolute;
    z-index: 2;
    left: 22px;
    right: 22px;
    bottom: calc(var(--bar-pad) + 24px);
    color: var(--warm-white);
  }
  @media (min-width: 1025px) {
    .hero-copy {
      left: 64px;
      right: auto;
      bottom: 88px;
      max-width: 640px;
    }
  }

  /* ---------- eyebrow ----------
     No left-alignment compensator needed: at 360 / 390 / 412 the eyebrow's
     block left and the headline's block left both compute to 22px (verified
     in dev tools). letter-spacing only adds space *after* each character, so
     the first character ("P") sits flush against the block edge — same as the
     headline's "B". */

  /* Tight 12px gap from eyebrow to headline (was 14px from the generic > * + * rule). */
  .hero-headline {
    margin-top: 12px;
    color: var(--warm-white);
    /* Mobile: 11vw + -0.015em fits "FINE, BRING THE KIDS." inside the
       container at 360 / 390 / 412 with a small margin (verified via
       Range glyph-width measurement, not block width). Floor 34px catches
       sub-320 viewports. */
    font-size: clamp(34px, 11vw, 80px);
    letter-spacing: -0.015em;
  }
  .hero-headline-line {
    display: block;
  }
  .hero-headline-line + .hero-headline-line {
    /* Inter-line spacing inside the headline — visually tight, deliberate. */
    margin-top: 2px;
  }

  @media (min-width: 1025px) {
    .hero-headline {
      font-size: clamp(72px, 7vw, 110px);
      letter-spacing: 0.005em;
    }
  }

  /* Subhead sits 16px under the headline — slightly more breathing room than 14px. */
  .hero-sub {
    margin-top: 16px;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 16px;
    line-height: 1.45;
    color: #ece6d6;
    max-width: 22em;
  }
  .hero-sub em {
    font-style: italic;
    color: var(--warm-mid);
  }
  @media (min-width: 1025px) {
    .hero-sub {
      margin-top: 22px;
      font-size: 19px;
      line-height: 1.5;
      max-width: 32em;
    }
  }

  /* ---------- entry-stagger initial state ---------- */
  .hero-fade {
    opacity: 0;
    transform: translateY(12px);
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-fade {
      opacity: 1;
      transform: none;
    }
  }
</style>
