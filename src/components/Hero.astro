---
/**
 * Homepage hero.
 *
 * Mobile (≤1024): vertical 9:16 video, poster as LCP, copy stack at bottom.
 * Desktop (≥1025): cocktail-pour photograph (placeholder), copy stack lower-left.
 *
 * Copy is locked — see Context/voice.md "Locked Lines (Approved)".
 */
---
<section class="hero" data-hero>
  {/* Brand mark — top-left, on top of media */}
  <a class="hero-brand" href="/" aria-label="Twisted Pin home">Twisted&nbsp;Pin</a>

  {/* MOBILE — vertical video.
      poster is preloaded in Base.astro <head>; preload="metadata" defers byte-fetch.
      muted + autoplay + playsinline keeps mobile autoplay legal. */}
  <video
    class="hero-video"
    preload="metadata"
    muted
    autoplay
    loop
    playsinline
    poster="/hero/hero-poster.webp"
    aria-hidden="true"
  >
    <source src="/hero/hero-mobile-av1-1080.mp4" type="video/mp4; codecs=av01.0.05M.08" />
    <source src="/hero/hero-mobile-h264-1080.mp4" type="video/mp4" />
  </video>

  {/* DESKTOP — cocktail-pour photograph (placeholder until final shot is selected). */}
  <picture class="hero-photo" aria-hidden="true">
    <source
      type="image/webp"
      srcset="/hero/hero-desktop-960.webp 960w, /hero/hero-desktop-1280.webp 1280w, /hero/hero-desktop-1920.webp 1920w"
      sizes="100vw"
    />
    <img
      src="/hero/hero-desktop-1280.jpg"
      srcset="/hero/hero-desktop-960.jpg 960w, /hero/hero-desktop-1280.jpg 1280w, /hero/hero-desktop-1920.jpg 1920w"
      sizes="100vw"
      alt=""
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </picture>

  {/* Scrim — gradient ensures legibility of the bottom-anchored copy stack. */}
  <div class="hero-scrim" aria-hidden="true"></div>

  {/* Copy stack */}
  <div class="hero-copy">
    <p class="t-eyebrow hero-fade" data-fade-order="0">Plainfield, IL</p>
    <h1 class="t-display hero-headline hero-fade" data-fade-order="1">
      Built&nbsp;for&nbsp;adults.<br />Fine,&nbsp;bring&nbsp;the&nbsp;kids.
    </h1>
    <p class="hero-sub hero-fade" data-fade-order="2">
      Built by America's Top Mixologist. <em>(Their words, not ours.)</em>
    </p>
    <a href="/reserve" class="btn btn-solid hero-cta hero-fade" data-fade-order="3">
      Reserve a lane
    </a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    height: 100svh; /* small-viewport unit — accounts for mobile browser chrome */
    min-height: 560px;
    overflow: hidden;
    background: #000;
  }

  .hero-brand {
    position: absolute;
    top: calc(20px + var(--safe-top));
    left: 22px;
    z-index: 4;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 18px;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--warm-white);
    /* Subtle text shadow so the mark is legible over busy hero photography */
    text-shadow: 0 1px 8px rgba(14, 10, 31, 0.4);
  }

  /* ----- media ----- */
  .hero-video,
  .hero-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* default: show video (mobile-first), hide photo */
  .hero-video { display: block; }
  .hero-photo { display: none; }

  @media (min-width: 1025px) {
    .hero-video { display: none; }
    .hero-photo { display: block; }
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg,
        rgba(14, 10, 31, 0.45) 0%,
        rgba(14, 10, 31, 0.05) 22%,
        rgba(14, 10, 31, 0.05) 50%,
        rgba(14, 10, 31, 0.92) 92%,
        rgba(14, 10, 31, 1) 100%);
  }
  @media (min-width: 1025px) {
    .hero-scrim {
      background:
        linear-gradient(90deg,
          rgba(14, 10, 31, 0.85) 0%,
          rgba(14, 10, 31, 0.55) 30%,
          rgba(14, 10, 31, 0.10) 65%,
          rgba(14, 10, 31, 0)    100%);
    }
  }

  /* ----- copy stack ----- */
  .hero-copy {
    position: absolute;
    z-index: 2;
    left: 22px;
    right: 22px;
    /* Anchor above the sticky CTA bar so they don't fight for the same pixels. */
    bottom: calc(var(--bar-pad) + 24px);
    color: var(--warm-white);
  }
  @media (min-width: 1025px) {
    .hero-copy {
      left: 64px;
      right: auto;
      bottom: 88px;
      max-width: 640px;
    }
  }

  .hero-copy > * + * { margin-top: 14px; }

  .hero-headline {
    color: var(--warm-white);
    font-size: clamp(48px, 13vw, 80px);
    margin-top: 14px;
  }
  @media (min-width: 1025px) {
    .hero-headline {
      font-size: clamp(72px, 7vw, 110px);
    }
  }

  .hero-sub {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 16px;
    line-height: 1.45;
    color: #ece6d6;
    max-width: 22em;
  }
  .hero-sub em {
    font-style: italic;
    color: var(--warm-mid);
  }
  @media (min-width: 1025px) {
    .hero-sub {
      font-size: 19px;
      line-height: 1.5;
      max-width: 32em;
    }
  }

  .hero-cta {
    margin-top: 22px;
  }

  /* ----- entry-stagger initial state. Motion One animates these in. ----- */
  .hero-fade {
    opacity: 0;
    transform: translateY(12px);
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-fade {
      opacity: 1;
      transform: none;
    }
  }
</style>
