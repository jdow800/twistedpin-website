---
/**
 * SnapToday — daily "what's open / what it costs / what's special" module.
 *
 * Combines three by-day-variable beats into one snap:
 *   - hours (data/hours.ts)
 *   - walk-in pricing (data/pricing.ts)
 *   - active specials (content/specials/*.md)
 *
 * All 7 days pre-rendered server-side; only one is visible at a time.
 * The day-pill nav toggles which view is active via a data-active-day
 * attribute on the section root. No framework — vanilla JS for the pill
 * click handler, CSS attribute selectors for the view swap.
 *
 * Server-side defaults to today (in America/Chicago — see hours.ts).
 * Daily 4am cron rebuild keeps "today" fresh without intervention.
 *
 * Specials with replacesRate=true override the relevant tier cell —
 * Wed Traditional renders "✦ Penny A Pin" instead of "$35"; Wed Suite
 * stays $55. Additive specials (replacesRate=false) render only as a
 * callout above the table.
 */
import { getCollection } from "astro:content";
import { DAYS, hoursLabel, todayKey, type DayKey } from "../../data/hours";
import {
  PRICING,
  SHOE_RENTAL_LABEL,
  type PriceWindow,
} from "../../data/pricing";

const ROLLER_URL = "https://ecom.roller.app/twistedpin/openbowl/en-us/home";
const ZITE_EVENTS_URL = "https://twistedevents.zite.so/";

const today = todayKey();
const now = new Date();

// Pull active specials, filter out drafts + out-of-window.
const allSpecials = await getCollection("specials");
const activeSpecials = allSpecials
  .filter((s) => !s.data.draft)
  .filter((s) => {
    if (s.data.showFrom && now < s.data.showFrom) return false;
    if (s.data.showUntil && now > s.data.showUntil) return false;
    return true;
  });

/** Specials that apply on a given day (and any tier). */
function specialsForDay(day: DayKey) {
  return activeSpecials.filter((s) => s.data.days.includes(day));
}

/** Special that replaces a specific tier's rate on a day, if any. */
function rateReplacement(
  day: DayKey,
  tier: "traditional" | "suite",
) {
  return activeSpecials.find(
    (s) =>
      s.data.replacesRate &&
      s.data.days.includes(day) &&
      s.data.tiers.includes(tier),
  );
}

interface Props {
  /** Optional class to compose with — used for mobile-only / desktop-only gating. */
  class?: string;
}

const { class: extraClass = "" } = Astro.props;
---

<section
  class:list={["snap-section", "snap-today", extraClass]}
  data-snap-today
  data-active-day={today}
  aria-labelledby="snap-today-h2"
>
  {/* Day pill nav — fixed at the top of the snap. */}
  <nav class="today-pills" aria-label="Pick a day">
    {DAYS.map((d) => (
      <button
        type="button"
        class="today-pill"
        data-pill-day={d.key}
        data-is-today={d.key === today ? "" : null}
        aria-pressed={d.key === today ? "true" : "false"}
      >
        <span class="today-pill-label">{d.abbr3}</span>
        <span class="today-pill-dot" aria-hidden="true"></span>
      </button>
    ))}
  </nav>

  {/* Visually hidden h2 anchors the snap for a11y / aria-labelledby. */}
  <h2 id="snap-today-h2" class="visually-hidden">Hours, pricing, and today's specials</h2>

  {/* Per-day views — all rendered, only one visible (CSS toggle). */}
  {DAYS.map((d) => {
    const schedule = PRICING[d.key];
    const dailySpecials = specialsForDay(d.key);
    const additiveSpecials = dailySpecials.filter((s) => !s.data.replacesRate);
    const isToday = d.key === today;

    return (
      <article class="today-view" data-view-day={d.key} aria-hidden={isToday ? "false" : "true"}>
        {/* Day header */}
        <header class="today-header">
          <p class="today-eyebrow">
            {isToday && <span class="today-pill-today">Today</span>}
            <span class="today-day-name">{d.full}</span>
          </p>
          <p class="today-hours">
            Open {hoursLabel(d.key)}
            <span class="today-hours-caveat">
              {" · "}<a href="https://maps.google.com/?cid=12977050655706712680" target="_blank" rel="noopener">verify on Google</a>
            </span>
          </p>
        </header>

        {/* Special callouts — only the additive + replacement-with-context cases.
            Replacement specials still get a callout because users need to know
            WHAT Penny A Pin is before they can read it as a "$" replacement. */}
        {dailySpecials.length > 0 && (
          <div class="today-specials">
            {dailySpecials.map((s) => (
              <div class="today-special">
                <p class="today-special-head">
                  <span class="today-special-mark" aria-hidden="true">✦</span>
                  <span class="today-special-name">{s.data.name}</span>
                </p>
                <p class="today-special-tagline">{s.data.tagline}</p>
                {s.body && s.body.trim() && (
                  <p class="today-special-body">{s.body.trim()}</p>
                )}
              </div>
            ))}
          </div>
        )}

        {/* Pricing table */}
        <p class="today-table-label">Walk-in pricing</p>
        <table class="today-table">
          <thead>
            <tr>
              <th class="today-th-time">Time</th>
              <th class="today-th-tier">Traditional</th>
              <th class="today-th-tier">VIP Suite</th>
            </tr>
          </thead>
          <tbody>
            {schedule.windows.map((window: PriceWindow) => {
              const tradReplace = rateReplacement(d.key, "traditional");
              const suiteReplace = rateReplacement(d.key, "suite");
              return (
                <tr>
                  <td class="today-td-time">{window.label}</td>
                  <td class="today-td-rate">
                    {tradReplace ? (
                      <span class="today-rate-special">
                        <span aria-hidden="true">✦</span> {tradReplace.data.name}
                      </span>
                    ) : (
                      <>
                        <span class="today-rate-num">${window.traditional}</span>
                        <span class="today-rate-unit">/hr</span>
                      </>
                    )}
                  </td>
                  <td class="today-td-rate">
                    {suiteReplace ? (
                      <span class="today-rate-special">
                        <span aria-hidden="true">✦</span> {suiteReplace.data.name}
                      </span>
                    ) : (
                      <>
                        <span class="today-rate-num">${window.suite}</span>
                        <span class="today-rate-unit">/hr</span>
                      </>
                    )}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>

        <p class="today-capacity">
          Traditional {schedule.traditionalCapacity}
          {" · "}Suite {schedule.suiteCapacity}
          {" · "}Shoe rental {SHOE_RENTAL_LABEL}
        </p>

        <div class="today-actions">
          <a class="btn btn-solid today-cta" href={ROLLER_URL} target="_blank" rel="noopener">
            Reserve a lane
          </a>
          <p class="today-suite-note">
            Renting the whole suite?{" "}
            <a href={ZITE_EVENTS_URL} target="_blank" rel="noopener">Plan an event &rarr;</a>
          </p>
        </div>
      </article>
    );
  })}
</section>

<script>
  // Pill toggle — pure DOM. All views pre-rendered; flipping
  // data-active-day on the section root and aria-pressed on the
  // pills lets CSS handle the rest.
  const root = document.querySelector<HTMLElement>("[data-snap-today]");
  if (root) {
    const pills = root.querySelectorAll<HTMLButtonElement>("[data-pill-day]");
    const views = root.querySelectorAll<HTMLElement>("[data-view-day]");
    pills.forEach((pill) => {
      pill.addEventListener("click", () => {
        const day = pill.getAttribute("data-pill-day");
        if (!day) return;
        root.setAttribute("data-active-day", day);
        pills.forEach((p) =>
          p.setAttribute(
            "aria-pressed",
            p.getAttribute("data-pill-day") === day ? "true" : "false",
          ),
        );
        views.forEach((v) =>
          v.setAttribute(
            "aria-hidden",
            v.getAttribute("data-view-day") === day ? "false" : "true",
          ),
        );
      });
    });
  }
</script>

<style>
  /* ============================================================
     Section shell — locks to viewport on mobile (snap mechanic),
     adapts to a normal long-scroll height on desktop.
     ============================================================ */
  .snap-today {
    background: var(--indigo-deep);
    color: var(--warm-white);
    display: flex;
    flex-direction: column;
    padding: 24px 20px 32px;
    /* Snap-section sizing comes from global .snap-section rules on
       mobile. Desktop track override below. */
  }
  @media (min-width: 1025px) {
    .snap-today {
      min-height: auto;
      padding: 80px 64px;
      max-width: 960px;
      margin: 0 auto;
    }
  }

  /* ============================================================
     Day pill nav — sticky at the top of the snap.
     ============================================================ */
  .today-pills {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
    margin: 0 auto 20px;
    width: 100%;
    max-width: 480px;
    padding: 4px;
    background: rgba(255, 252, 245, 0.04);
    border: 1px solid rgba(255, 252, 245, 0.10);
    border-radius: 999px;
  }
  .today-pill {
    appearance: none;
    background: transparent;
    border: 0;
    color: rgba(255, 252, 245, 0.65);
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.10em;
    padding: 10px 0 8px;
    border-radius: 999px;
    cursor: pointer;
    position: relative;
    transition: color 150ms ease, background-color 150ms ease;
  }
  .today-pill:hover {
    color: var(--warm-white);
  }
  .today-pill[aria-pressed="true"] {
    background: var(--glow);
    color: var(--indigo-deep);
  }
  .today-pill-label {
    display: block;
    line-height: 1;
  }
  /* Tiny dot under today's pill — visible even when not active, so
     "where am I in the week" is always answerable at a glance. */
  .today-pill-dot {
    display: block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: transparent;
    margin: 4px auto 0;
  }
  .today-pill[data-is-today] .today-pill-dot {
    background: var(--glow);
  }
  .today-pill[data-is-today][aria-pressed="true"] .today-pill-dot {
    background: var(--indigo-deep);
  }

  /* ============================================================
     Per-day views — only one visible at a time.
     ============================================================ */
  .today-view {
    display: none;
    flex: 1;
    flex-direction: column;
  }
  .today-view[aria-hidden="false"] {
    display: flex;
  }

  /* ============================================================
     Day header — eyebrow / day name / hours line
     ============================================================ */
  .today-header {
    text-align: center;
    margin-bottom: 16px;
  }
  .today-eyebrow {
    margin: 0 0 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }
  .today-pill-today {
    display: inline-block;
    background: var(--glow);
    color: var(--indigo-deep);
    font-family: var(--font-ui);
    font-weight: 800;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 4px 9px;
    border-radius: 999px;
    line-height: 1;
  }
  .today-day-name {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(28px, 7vw, 40px);
    line-height: 1;
    letter-spacing: 0.005em;
    text-transform: uppercase;
    color: var(--warm-white);
  }
  .today-hours {
    margin: 0;
    font-family: var(--font-body);
    font-size: 14px;
    color: rgba(255, 252, 245, 0.78);
    line-height: 1.3;
  }
  .today-hours-caveat a {
    color: inherit;
    border-bottom: 1px solid rgba(255, 252, 245, 0.3);
    text-decoration: none;
  }
  .today-hours-caveat a:hover {
    color: var(--glow);
    border-bottom-color: var(--glow);
  }

  /* ============================================================
     Specials callout
     ============================================================ */
  .today-specials {
    margin: 8px 0 16px;
    display: grid;
    gap: 10px;
  }
  .today-special {
    border: 1px solid rgba(159, 245, 202, 0.42); /* Glow @ 42% */
    background: rgba(159, 245, 202, 0.06);
    border-radius: 12px;
    padding: 14px 16px;
  }
  .today-special-head {
    margin: 0 0 4px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .today-special-mark {
    color: var(--glow);
    font-size: 14px;
  }
  .today-special-name {
    font-family: var(--font-ui);
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--glow);
  }
  .today-special-tagline {
    margin: 0 0 6px;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.4;
    color: var(--warm-white);
  }
  .today-special-body {
    margin: 0;
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.45;
    color: rgba(255, 252, 245, 0.65);
  }

  /* ============================================================
     Pricing table
     ============================================================ */
  .today-table-label {
    margin: 8px 0 8px;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: rgba(255, 252, 245, 0.55);
    text-align: center;
  }
  .today-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 12px;
  }
  .today-table th {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 252, 245, 0.55);
    padding: 8px 6px;
    text-align: right;
    border-bottom: 1px solid rgba(255, 252, 245, 0.10);
  }
  .today-th-time {
    text-align: left;
  }
  .today-table td {
    padding: 14px 6px;
    border-bottom: 1px solid rgba(255, 252, 245, 0.06);
    text-align: right;
    vertical-align: middle;
  }
  .today-table tr:last-child td {
    border-bottom: 0;
  }
  .today-td-time {
    text-align: left;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 252, 245, 0.78);
  }
  .today-rate-num {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 22px;
    color: var(--glow);
    line-height: 1;
  }
  .today-rate-unit {
    font-family: var(--font-body);
    font-size: 12px;
    color: rgba(255, 252, 245, 0.55);
    margin-left: 2px;
  }
  .today-rate-special {
    font-family: var(--font-ui);
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--glow);
    line-height: 1.2;
    display: inline-block;
  }

  /* ============================================================
     Capacity / footnote line
     ============================================================ */
  .today-capacity {
    margin: 4px 0 18px;
    font-family: var(--font-body);
    font-size: 11px;
    line-height: 1.45;
    color: rgba(255, 252, 245, 0.5);
    text-align: center;
  }

  /* ============================================================
     Actions — Reserve CTA + suite note
     ============================================================ */
  .today-actions {
    margin-top: auto;
    text-align: center;
  }
  .today-cta {
    display: inline-block;
    padding: 12px 28px;
    font-size: 12px;
    letter-spacing: 0.16em;
  }
  .today-suite-note {
    margin: 12px 0 0;
    font-family: var(--font-body);
    font-size: 12px;
    color: rgba(255, 252, 245, 0.55);
  }
  .today-suite-note a {
    color: rgba(255, 252, 245, 0.78);
    border-bottom: 1px solid rgba(255, 252, 245, 0.3);
    text-decoration: none;
  }
  .today-suite-note a:hover {
    color: var(--glow);
    border-bottom-color: var(--glow);
  }

  /* ============================================================
     a11y — visually-hidden helper
     ============================================================ */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
