---
/**
 * SnapStub — full-viewport mobile snap section with optional photo
 * background. Two modes:
 *
 *   1. No `image` prop  → solid Midnight Indigo with subtle gradient.
 *      Original "placeholder until visuals land" treatment.
 *   2. With `image` slug → full-bleed <picture> behind a dark bottom
 *      scrim, copy floats above. Same composition pattern as the
 *      mobile snap-tapwall (which uses video instead of a still).
 *
 * Used for snaps 2, 4, 5, 6, 7 in the homepage architecture (Events,
 * Cocktails, Food, Bowl, Arcade). Mobile-only — desktop track has
 * its own cluster sections.
 *
 * Layout: bottom-anchored, centered text. Title in UI font (substitute for
 * Proxima Nova Bold), subhead in body font, "Learn more →" Glow link.
 *
 * Sized to fit inside a 100dvh snap section that already supplies its own
 * `.snap-section` wrapper. This component renders the inner content only.
 */
interface Props {
  /** Section title — shown all-caps. e.g. "EVENTS THAT DON'T SUCK" */
  title: string;
  /** Subhead main line. */
  subhead: string;
  /** Optional aside — rendered on a second line wrapped in parens, dimmer.
   *  Use for the "(their words, not ours)" pattern. */
  subheadParen?: string;
  /** Learn-more href; "#" while routes don't exist. */
  href?: string;
  /** Optional aria-label override for the section. */
  label?: string;
  /** Optional image slug — e.g. "vip-energy" pulls /snap/vip-energy-{540,900}
   *  in AVIF + WebP + JPG. When provided, the section renders with a full-
   *  bleed photo background + scrim instead of the solid-Indigo treatment. */
  image?: string;
  /** Optional video slug — e.g. "cocktails-hero" pulls /snap/cocktails-hero-
   *  mobile-{av1,h264}-{540,1080}.mp4 + /snap/cocktails-hero-poster.webp.
   *  Takes precedence over `image` when both are set. Lazy-loaded via the
   *  same sectionVideo() motion module that powers the homepage Tap Wall. */
  video?: string;
  /** Optional alt / aria-label for the background media (a11y). Defaults to
   *  empty since the media is decorative — the section title carries the
   *  meaning. Used as `alt` for image and `aria-label` for video. */
  imageAlt?: string;
  /** Extra classes applied to the snap-section root. Used by index.astro to
   *  flag stubs as `mobile-only` so they collapse on desktop while the
   *  desktop-track sections take over. */
  class?: string;
}
const { title, subhead, subheadParen, href = "#", label, image, video, imageAlt = "", class: className = "" } = Astro.props;
const ariaId = `snap-${title.toLowerCase().replace(/[^a-z0-9]+/g, "-")}-h1`;
// Video takes precedence over image when both are provided.
const hasMedia = !!(video || image);
---
<section
  class:list={["snap-section", "snap-stub", hasMedia && "snap-stub--photo", className]}
  aria-labelledby={ariaId}
  aria-label={label}
>
  {video ? (
    <video
      class="stub-bg-video"
      data-section-video
      preload="none"
      muted
      loop
      playsinline
      data-poster={`/snap/${video}-poster.webp`}
      aria-label={imageAlt}
    >
      <source media="(max-width: 480px)" data-src={`/snap/${video}-mobile-av1-540.mp4`}  type="video/mp4; codecs=av01.0.05M.08" />
      <source media="(max-width: 480px)" data-src={`/snap/${video}-mobile-h264-540.mp4`} type="video/mp4" />
      <source data-src={`/snap/${video}-mobile-av1-1080.mp4`}  type="video/mp4; codecs=av01.0.05M.08" />
      <source data-src={`/snap/${video}-mobile-h264-1080.mp4`} type="video/mp4" />
    </video>
  ) : image && (
    <picture class="stub-bg">
      <source type="image/avif" srcset={`/snap/${image}-540.avif 540w, /snap/${image}-900.avif 900w`} sizes="100vw" />
      <source type="image/webp" srcset={`/snap/${image}-540.webp 540w, /snap/${image}-900.webp 900w`} sizes="100vw" />
      <img
        class="stub-bg-img"
        src={`/snap/${image}-900.jpg`}
        srcset={`/snap/${image}-540.jpg 540w, /snap/${image}-900.jpg 900w`}
        sizes="100vw"
        alt={imageAlt}
        width="900"
        height="1600"
        loading="lazy"
        decoding="async"
      />
    </picture>
  )}
  {hasMedia && <div class="stub-scrim" aria-hidden="true"></div>}
  <div class="stub-inner">
    <h2 class="stub-title" id={ariaId}>{title}</h2>
    <p class="stub-sub">
      <span class="stub-sub-main">{subhead}</span>
      {subheadParen && (
        <span class="stub-sub-paren">({subheadParen})</span>
      )}
    </p>
    <a class="stub-learn" href={href}>
      Learn more <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

<style>
  /* Inherit .snap-section sizing/snap behavior from the parent page.
     This component only owns the inner block + visual treatment. */

  .snap-stub {
    position: relative; /* anchor for the optional photo bg + scrim layers */
    background: var(--indigo);
    /* Subtle vertical gradient gives the solid background a touch of
       atmosphere without competing with future real visuals. */
    background-image: linear-gradient(180deg,
      rgba(255, 255, 255, 0.025) 0%,
      transparent 28%,
      transparent 72%,
      rgba(0, 0, 0, 0.25) 100%);
  }

  /* Photo-backed mode: real visuals landed. Drop the solid background +
     gradient (the photo replaces them) and let the picture/scrim layers
     handle composition. */
  .snap-stub--photo {
    background: none;
    background-image: none;
    overflow: hidden;
  }
  .stub-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
  }
  .stub-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .stub-bg-video {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  /* Bottom scrim — fades photo into Indigo Deep at the lower third so
     the title + subhead + Learn more sit on a high-contrast surface
     without losing the photo entirely. Mirrors the mobile snap-tapwall
     treatment. */
  .stub-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg,
      rgba(14, 10, 31, 0.18) 0%,
      rgba(14, 10, 31, 0.32) 35%,
      rgba(14, 10, 31, 0.78) 78%,
      rgba(14, 10, 31, 0.94) 100%);
    pointer-events: none;
  }

  .stub-inner {
    /* Bottom-anchored, horizontally centered, text-centered. */
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 640px;
    margin: 0 auto;
    margin-top: auto; /* push down inside the flex parent */
    padding: 0 22px;
    text-align: center;
    color: var(--warm-white);
  }
  @media (min-width: 1025px) {
    .stub-inner { max-width: 880px; padding: 0 64px; }
  }

  /* Snap title — UI font (Proxima Nova Bold substitute = Montserrat 700).
     Deliberately distinct from the hero's display-font headline so the
     section labels read as section labels, not competing headlines. */
  .stub-title {
    font-family: var(--font-ui);
    font-weight: 700;
    text-transform: uppercase;
    color: var(--warm-white);
    font-size: clamp(34px, 9vw, 60px);
    letter-spacing: 0.02em;
    line-height: 1.0;
    margin-bottom: 14px;
  }
  @media (min-width: 1025px) {
    .stub-title { font-size: clamp(48px, 5.5vw, 72px); }
  }

  .stub-sub {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 16px;
    line-height: 1.45;
    color: #ece6d6;
    max-width: 32em;
    margin: 0 auto 22px;
  }
  /* Two-line pattern: main statement + parenthetical aside on its own line.
     Both spans become block so the line break is structural, not whitespace. */
  .stub-sub-main,
  .stub-sub-paren { display: block; }
  .stub-sub-paren {
    color: var(--warm-dim);
    margin-top: 4px;
    font-size: 0.9em;
  }
  @media (min-width: 1025px) {
    .stub-sub { font-size: 19px; line-height: 1.5; margin-bottom: 28px; }
    .stub-sub-paren { margin-top: 6px; }
  }

  .stub-learn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--glow);
    padding: 10px 0;
    border-bottom: 1px solid rgba(78, 236, 196, 0.4);
    transition: color 150ms ease-out, border-color 150ms ease-out, transform 150ms ease-out;
  }
  .stub-learn:hover {
    color: var(--warm-white);
    border-bottom-color: var(--warm-white);
    transform: translateX(2px);
  }
</style>
