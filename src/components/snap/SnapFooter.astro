---
/**
 * SnapFooter — snap 8 of /snap-test/.
 *
 * Layout (mobile, top → bottom):
 *   - "FIND US" snap title (left)             — back-to-top button (top-right corner)
 *   - Hours strip
 *   - Address (UI font, modest size)
 *   - Get Directions + Call buttons
 *   - (gap)
 *   - Logo
 *   - Utility links
 *   - Social icons
 *   - Copyright (very bottom)
 *
 * No "Visit" eyebrow — replaced with a proper snap title that matches the
 * rhythm of snaps 2–7. Address dropped from display font (was huge) to UI
 * font for contact-card legibility. Back-to-top moved to top-right corner.
 *
 * Sticky CTA bar is hidden when this snap is in view (handled by the
 * page-level scroll watcher).
 *
 * Hours strip pulls live data from Google Business Profile via
 * src/lib/google-hours.ts (currentOpeningHours field — overlays holiday
 * + special-day edits). Daily 4am cron rebuild keeps it fresh. Falls
 * back to static src/data/hours.ts when env vars aren't configured.
 */
import { getLiveHours, getLiveReviews } from "../../lib/google-hours";
import { MAPS_VENUE_URL, GOOGLE_RATING, GOOGLE_REVIEW_COUNT } from "../../lib/schema";
import {
  todayKey,
  previousDay,
  staticWindow,
  nowMinutesCentral,
} from "../../data/hours";
import type { DayWindow, DayKey } from "../../data/hours";

// Build-time fetch — null when GOOGLE_MAPS_API_KEY / GOOGLE_PLACE_ID
// env vars aren't set, or on API failure. Hours + reviews share a single
// Places API call internally; this is two function calls but one fetch.
const liveHours = await getLiveHours();
const liveReviews = await getLiveReviews();

// Display values for the proof-card. Live values when present; fall back
// to constants (captured 2026-05-07, refreshed annually as a floor) so
// the card always renders honest data even if env vars / cron / GitHub
// commit have all failed.
const googleRating = liveReviews?.rating ?? GOOGLE_RATING;
const googleReviewCount = liveReviews?.reviewCount ?? GOOGLE_REVIEW_COUNT;
// One-decimal rating ("4.5") + thousands-separated count ("1,141").
const googleRatingLabel = googleRating.toFixed(1);
const googleReviewCountLabel = googleReviewCount.toLocaleString("en-US");
const today = todayKey();
const yesterday = previousDay(today);
const nowMin = nowMinutesCentral();

/** Build a DayWindow from live data (preferred) or static (fallback). null = closed all day. */
function windowFor(day: DayKey): DayWindow | null {
  if (liveHours) {
    const lh = liveHours[day];
    if (lh.closed) return null;
    return {
      openMinutes: lh.openMinutes,
      closeMinutes: lh.closeMinutes,
      openLabel: lh.openLabel,
      closeLabel: lh.closeLabel,
    };
  }
  return staticWindow(day);
}

type FooterHoursStatus =
  | { state: "closed-today" }
  | { state: "open"; closeLabel: string }
  | { state: "before-open"; openLabel: string }
  | { state: "after-close" };

function getStatus(): FooterHoursStatus {
  const todayWin = windowFor(today);
  const yWin = windowFor(yesterday);

  // Yesterday's late-night carry-over still active? (e.g. Sat 12:30am inside Fri 2pm–1am)
  if (yWin && yWin.closeMinutes >= 24 * 60) {
    const carryClose = yWin.closeMinutes - 24 * 60;
    if (nowMin < carryClose) {
      return { state: "open", closeLabel: yWin.closeLabel };
    }
  }

  if (!todayWin) return { state: "closed-today" };

  if (nowMin >= todayWin.openMinutes && nowMin < todayWin.closeMinutes) {
    return { state: "open", closeLabel: todayWin.closeLabel };
  }
  if (nowMin < todayWin.openMinutes) {
    return { state: "before-open", openLabel: todayWin.openLabel };
  }
  return { state: "after-close" };
}

const status = getStatus();

const ADDRESS_STREET = "15610 Joliet Rd";
const ADDRESS_CITY   = "Plainfield, IL";
// Google Place ID drives the Get Directions URL — the place_id query
// param ensures Maps lands on the right venue regardless of how the
// address string is parsed. The Google reviews card uses MAPS_VENUE_URL
// (the documented `search/?api=1` deep-link with `query_place_id` —
// see src/lib/schema.ts) which replaced the prior maps.app.goo.gl
// short URL in the 2026-05-10 Firebase Dynamic Links retirement.
const PLACE_ID = "ChIJURI15Tr1DogRLKYdPWWuY-M";
const MAPS_HREF = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(`${ADDRESS_STREET}, ${ADDRESS_CITY}`)}&destination_place_id=${PLACE_ID}`;
const PHONE_DISPLAY = "(815) 782-7790";
const PHONE_TEL     = "+18157827790";
const EMAIL_ADDRESS = "contactus@twistedpin.com";
// Pre-populated mailto: subject + body so the user's mail client opens
// with a sensible subject line (tags the lead source for triage in
// Freshdesk) + cursor in body ready to type. Friction-reducing polish:
// the user's open-message app already has the email started for them.
const EMAIL_HREF =
  `mailto:${EMAIL_ADDRESS}` +
  `?subject=${encodeURIComponent("Question from twistedpin.com")}` +
  `&body=${encodeURIComponent("Hi,\n\n")}`;

// Real social URLs (verified 2026-05-05 from twistedpin.com JSON-LD
// schema's `sameAs` array). YouTube confirmed 2026-05-08. TikTok was a
// placeholder; user confirmed 2026-05-05 the business has no TikTok
// presence currently — icon removed below. Re-add the SVG + URL
// constant when/if a TikTok account launches. LinkedIn + X also absent.
const IG_URL  = "https://www.instagram.com/twistedpinplainfield/";
const FB_URL  = "https://www.facebook.com/twistedpin";
const YT_URL  = "https://www.youtube.com/@TwistedPin";

const UTILITY_LINKS = [
  { label: "FAQ",           href: "/faq/" },
  { label: "Careers",       href: "/careers/" },
  { label: "Gift Cards",    href: "/gift-cards/" },
  { label: "Privacy",       href: "/privacy/" },
  { label: "Terms",         href: "/terms/" },
  // SMS service info — paired with Privacy + Terms since carrier
  // reviewers crawl the footer expecting all three compliance pages
  // to be discoverable from any page on the site.
  { label: "SMS",           href: "/sms/" },
  { label: "Accessibility", href: "/accessibility/" },
];
---
<section id="find-us" class="snap-section snap-footer" aria-labelledby="footer-h2">
  {/* Back-to-top — anchored to the snap's top-right corner so it reads as
      a corner utility, not part of the copyright row. */}
  <button type="button" class="back-to-top" data-back-to-top aria-label="Back to top">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="12" y1="19" x2="12" y2="5"/>
      <polyline points="5 12 12 5 19 12"/>
    </svg>
  </button>

  <div class="footer-inner">
    {/* ---------- TOP BLOCK ----------
         Mobile: single column, vertical stack (Find Us → reviews → bottom).
         Desktop: 2-column grid (Find Us on left, reviews on right). */}
    <div class="footer-top">
      <div class="footer-find">
        <h2 class="footer-title" id="footer-h2">Find&nbsp;us</h2>

        {/* Hours strip — driven by getStatus() in the frontmatter. Live
            data when configured, static fallback otherwise. Daily cron
            keeps the build fresh enough that holiday closures land
            within ~24h of the Business Profile edit. */}
        <p class="hours-strip">
          {status.state === "closed-today" && (
            <span class="hours-status hours-status-closed">Closed today</span>
          )}
          {status.state === "open" && (
            <>
              <span class="hours-status">Open</span>
              <span class="hours-dot" aria-hidden="true">·</span>
              <span class="hours-times">until {status.closeLabel}</span>
            </>
          )}
          {status.state === "before-open" && (
            <>
              <span class="hours-status hours-status-closed">Closed</span>
              <span class="hours-dot" aria-hidden="true">·</span>
              <span class="hours-times">opens {status.openLabel}</span>
            </>
          )}
          {status.state === "after-close" && (
            <span class="hours-status hours-status-closed">Closed for tonight</span>
          )}
        </p>

        <address class="footer-address">
          <span class="address-line">{ADDRESS_STREET}</span>
          <span class="address-line">{ADDRESS_CITY}</span>
        </address>

        <div class="footer-actions">
          <a class="footer-action" href={MAPS_HREF} target="_blank" rel="noopener">
            <svg class="action-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            Get directions
          </a>
          <a class="footer-action" href={`tel:${PHONE_TEL}`}>
            <svg class="action-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.37 1.9.72 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0122 16.92z"/>
            </svg>
            {PHONE_DISPLAY}
          </a>
          <a class="footer-action" href={EMAIL_HREF}>
            <svg class="action-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <polyline points="22 6 12 13 2 6"/>
            </svg>
            Email us
          </a>
        </div>
      </div>

      {/* Social proof — moved INTO the footer (was a separate pre-footer
          snap during the prior round) so the footer's vacant real estate
          carries actual content. IG grid intentionally dropped per user
          decision; Instagram icon stays in the social-icons row below. */}
      <div class="footer-proof">
        <p class="proof-eyebrow">Don't take our word for it.</p>
        <p class="proof-sub">Everyone's been talking.</p>
        <div class="proof-cards">
          <a class="proof-card" href={MAPS_VENUE_URL} target="_blank" rel="noopener">
            <p class="proof-source">Google</p>
            <p class="proof-rating">
              <span class="proof-stars" aria-hidden="true">★★★★★</span>
              <span class="proof-num">{googleRatingLabel}</span>
            </p>
            <p class="proof-meta">{googleReviewCountLabel} reviews</p>
          </a>
          <a class="proof-card" href="https://www.yelp.com/biz/twisted-pin-plainfield" target="_blank" rel="noopener">
            <p class="proof-source">Yelp</p>
            <p class="proof-rating">
              <span class="proof-stars" aria-hidden="true">★★★★★</span>
              <span class="proof-num">4.1</span>
            </p>
            <p class="proof-meta">99 reviews</p>
          </a>
        </div>
      </div>
    </div>

    {/* ---------- INSTAGRAM GRID (desktop only) ----------
         Sits in the gap between the top block (Find Us / reviews) and the
         bottom block (utility + social). Mobile: hidden — would push the
         footer past 100dvh and bury the bottom block below the fold. The
         IG thumbs are placeholders re-using the brand-safe stills already
         encoded in scripts/build-snap-images.mjs (1:1 320/540 widths).
         Real IG handle / Basic Display API embed is queued for the API
         batch round; per-thumb hrefs use `#` until then. */}
    <div class="footer-ig">
      <a class="ig-handle" href={IG_URL} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
        @twistedpin
      </a>
      <ul class="ig-grid" role="list">
        {[1, 2, 3, 4, 5, 6].map((n) => (
          <li>
            <a href={IG_URL} target="_blank" rel="noopener" aria-label={`Twisted Pin on Instagram — post ${n}`}>
              <picture>
                <source
                  type="image/webp"
                  srcset={`/snap/ig-${n}-320.webp 320w, /snap/ig-${n}-540.webp 540w`}
                  sizes="(min-width: 1025px) 160px, 100vw"
                />
                <img
                  src={`/snap/ig-${n}-540.jpg`}
                  alt={`Recent scene from Twisted Pin in Plainfield, IL — ${n}`}
                  width="540"
                  height="540"
                  loading="lazy"
                  decoding="async"
                />
              </picture>
            </a>
          </li>
        ))}
      </ul>
    </div>

    {/* ---------- BOTTOM BLOCK ----------
         Logo intentionally omitted — the persistent SiteHeader's logo
         (visible at the top of every snap) is sufficient brand recall.
         A second logo here was visual redundancy in a footer that already
         needs to make every line earn its space. */}
    <div class="footer-bottom">
      <ul class="utility-links" aria-label="Utility navigation">
        {UTILITY_LINKS.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>

      <ul class="social-icons" aria-label="Social media">
        <li>
          <a href={IG_URL} target="_blank" rel="noopener" aria-label="Twisted Pin on Instagram">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
        </li>
        <li>
          <a href={FB_URL} target="_blank" rel="noopener" aria-label="Twisted Pin on Facebook">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
        </li>
        <li>
          <a href={YT_URL} target="_blank" rel="noopener" aria-label="Twisted Pin on YouTube">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33z"/>
              <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="currentColor"/>
            </svg>
          </a>
        </li>
      </ul>

      <p class="copyright">© {new Date().getFullYear()} Twisted Pin · Plainfield, IL</p>
    </div>
  </div>
</section>

<script>
  /* Back-to-top scrolls the .snap container (the actual scrollport on
     mobile). Falls back to window scroll on desktop. */
  document.querySelector("[data-back-to-top]")?.addEventListener("click", () => {
    const snap = document.querySelector<HTMLElement>(".snap");
    if (snap && snap.scrollHeight > snap.clientHeight) {
      snap.scrollTo({ top: 0, behavior: "smooth" });
    } else {
      window.scrollTo({ top: 0, behavior: "smooth" });
    }
  });
</script>

<style>
  .snap-footer {
    background: var(--indigo-deep);
    color: var(--warm-white);
    /* The page reserves padding-bottom for the sticky CTA bar; the bar is
       hidden on this snap, so reclaim that space. */
    padding-bottom: 0;
    /* Top-align content in this snap (override the page's centered
       align-items:center) so the layout reads top-down and never floats
       in a void in the middle. */
    align-items: stretch;
  }

  /* Desktop: transparent background so the page-level Pin Tilt watermark
     (`.snap::before`) shows through to the footer. Mobile keeps the
     solid Indigo Deep — the locked mobile track doesn't carry the
     pattern (no .snap::before visible behind mobile sections, which
     all have their own opaque backgrounds). */
  @media (min-width: 1025px) {
    .snap-footer {
      background: transparent;
    }
  }

  /* ---------- back-to-top, bottom-right corner ----------
     Bottom-right is the standard spot for back-to-top buttons. On snap 8
     the sticky CTA bar is hidden, so the corner is free. Lifted slightly
     above the safe-area inset so it doesn't sit flush with the iOS home
     indicator. */
  .back-to-top {
    position: absolute;
    bottom: calc(20px + var(--safe-bottom));
    right: 22px;
    z-index: 3;
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid rgba(244, 239, 227, 0.22);
    color: var(--warm-white);
    background: rgba(14, 10, 31, 0.6);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    cursor: pointer;
    transition: border-color 150ms ease-out, color 150ms ease-out, background-color 150ms ease-out, transform 150ms ease-out;
  }
  .back-to-top:hover {
    color: var(--glow);
    border-color: rgba(78, 236, 196, 0.5);
    background: rgba(14, 10, 31, 0.8);
    transform: translateY(-1px);
  }
  @media (min-width: 1025px) {
    .back-to-top { bottom: calc(28px + var(--safe-bottom)); right: 40px; }
  }

  /* ---------- inner layout ---------- */
  .footer-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    /* No explicit height — the parent .snap-section is a flex ROW
       (display: flex, default direction) with `min-height: 100dvh`
       and `align-items: stretch` (overridden on .snap-footer). The
       prior `height: 100%` did NOT resolve against the parent's
       min-height, so this block was collapsing to its content height
       (~615px) inside a 1080px viewport, leaving the dead space at
       the bottom of the snap. Removing the explicit height lets
       `align-items: stretch` do its job — child fills the parent's
       full height — and justify-content: space-between then anchors
       the bottom block to the actual bottom of the snap. */
    align-self: stretch;
    display: flex;
    flex-direction: column;
    /* Two blocks: TOP near the top of the snap, BOTTOM near the bottom.
       Use `space-between` deliberately so the snap title anchors top and
       copyright anchors bottom; both blocks are dense internally. */
    justify-content: space-between;
    gap: 24px;
    /* Padding-top clears the persistent SiteHeader on both viewports.
       Mobile header ~62px, desktop header ~77px — bumping mobile from
       36px to 96px (clears ~62px header + breathing) and keeping desktop
       at 128px. Was clipping the FIND US title behind the header before. */
    padding: calc(96px + var(--safe-top)) 22px calc(28px + var(--safe-bottom));
    max-width: 880px;
    margin: 0 auto;
  }
  @media (min-width: 1025px) {
    .footer-inner {
      padding: 128px 64px 36px;
      max-width: 1280px;
    }
  }

  /* ---------- TOP BLOCK ----------
     Mobile: vertical stack (Find Us → reviews) at full width.
     Desktop: 2-column grid (Find Us left, reviews right) using the
     vacant horizontal real estate. */
  .footer-top {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  @media (min-width: 1025px) {
    .footer-top {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: start;
    }
  }

  .footer-find {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  /* Snap title — matches the SnapStub treatment so the rhythm carries
     through to the footer. Left-aligned (not centered like stubs) because
     the contact info below reads better left-aligned. */
  .footer-title {
    font-family: var(--font-ui);
    font-weight: 700;
    text-transform: uppercase;
    color: var(--warm-white);
    font-size: clamp(34px, 9vw, 60px);
    letter-spacing: 0.02em;
    line-height: 1.0;
    margin-bottom: 6px;
  }
  @media (min-width: 1025px) {
    .footer-title { font-size: clamp(48px, 5.5vw, 72px); }
  }

  .hours-strip {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.02em;
    color: var(--warm-white);
  }
  .hours-strip .hours-status { color: var(--glow); }
  .hours-strip .hours-status-closed { color: var(--warm-dim); }
  .hours-strip .hours-dot { color: var(--warm-dim); margin: 0 0.5em; }

  .footer-address {
    font-style: normal;
    font-family: var(--font-ui);
    font-weight: 600;
    color: var(--warm-mid);
    font-size: 16px;
    line-height: 1.4;
    letter-spacing: 0.01em;
  }
  .footer-address .address-line { display: block; }

  .footer-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 6px;
  }
  .footer-action {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 16px;
    border: 1px solid rgba(244, 239, 227, 0.22);
    border-radius: var(--radius-button);
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 12.5px;
    letter-spacing: 0.06em;
    color: var(--warm-white);
    background: rgba(244, 239, 227, 0.04);
    transition: background-color 150ms ease-out, border-color 150ms ease-out, transform 150ms ease-out;
  }
  .footer-action:hover {
    background: rgba(244, 239, 227, 0.10);
    border-color: rgba(244, 239, 227, 0.40);
    transform: translateY(-1px);
  }
  .footer-action .action-icon { color: var(--glow); flex: 0 0 auto; }

  /* ---------- SOCIAL PROOF (in-footer) ----------
     Tagline + 2 review cards. Mobile: cards stacked vertically.
     Desktop: cards side-by-side in a row. Brand-toned (NOT Yelp red /
     Google blue) — Indigo Lift surface, Glow stars, warm-white rating
     number anchors social-proof to brand instead of platform colors. */
  .footer-proof {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .proof-eyebrow {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    color: var(--warm-white);
    font-size: clamp(22px, 6vw, 32px);
    letter-spacing: -0.005em;
    line-height: 0.95;
    margin: 0;
  }
  @media (min-width: 1025px) {
    .proof-eyebrow { font-size: clamp(32px, 3vw, 44px); }
  }

  .proof-sub {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 14px;
    line-height: 1.4;
    color: var(--warm-mid);
    margin: 0 0 4px;
  }
  @media (min-width: 1025px) {
    .proof-sub { font-size: 16px; }
  }

  /* Cards as a 2-column grid on BOTH mobile and desktop. Stacked-cards
     was the first cut for mobile but pushed footer content past 100dvh;
     2-col fits cleanly in mobile width (~173px per card at 390 viewport
     with 22px page padding) and matches desktop's side-by-side rhythm. */
  .proof-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  @media (min-width: 1025px) {
    .proof-cards { gap: 14px; }
