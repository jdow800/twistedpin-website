---
/**
 * PromoBar — site-wide "attention" overlay for time-bounded campaigns.
 *
 * Server-side selection from src/config/promos.ts. Renders the first active
 * promo or nothing. Auto-hides on the promo's own landing page so we don't
 * tell a /free-kids-bowling visitor about /free-kids-bowling.
 *
 * Layout strategy:
 *   - Mobile: thin bar pinned BELOW the persistent SiteHeader (~72px from
 *     the top, accounting for header height + safe-area inset). Full-width
 *     minus 12px side margins. Slides down from behind the header.
 *     Earlier iteration sat above the sticky CTAs but overlapped hero
 *     headline copy at the bottom of the viewport — moved to the top
 *     band where it only covers hero video, never text. (2026-05-10)
 *   - Desktop: floating bottom-right toast (440px wide) 24px from corners.
 *     The mobile "below the header" layout doesn't translate — desktop
 *     has more horizontal real estate and the bottom-right is the
 *     standard toast zone for non-blocking notifications. Slides up
 *     from below the viewport.
 *
 * Visual recipe:
 *   - Indigo Deep blurred background (same as sticky pill — cohesive)
 *   - 1px Glow top border for attention contrast
 *   - Glow dot + arrow accent; warm-white message text
 *   - 2-line wrap (via -webkit-line-clamp) — no mid-word truncation
 *   - Whole link region clickable; dismiss X is a separate flex sibling
 *
 * Entry timing:
 *   - Slides in ~1200ms after page load — AFTER the sticky-CTA Motion One
 *     entry completes (~870ms). Gives the CTAs their landing moment first,
 *     then the promo arrives as a deliberate second beat for attention.
 *
 * Dismissal:
 *   - No persistence. Click X slides the bar back out and hides it for
 *     the current page view only. Reload or navigation brings it back.
 *     The promo is a recurring nudge for the showFrom→showUntil window —
 *     a permanent silence isn't what the user wanted (2026-05-10 call).
 *
 * A11y:
 *   - role="region" + aria-label so it's announced as a landmark
 *   - Dismiss is a real <button> with aria-label
 *   - prefers-reduced-motion: skip the entry slide
 */
import { getActivePromo } from "../config/promos";

const promo = getActivePromo();

// Auto-hide on the promo's own landing page. Trailing-slash normalize so
// "/free-kids-bowling" and "/free-kids-bowling/" both match.
const currentPath = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const targetPath = promo?.hideOnPath ?? promo?.href;
const targetPathNormalized = targetPath?.endsWith("/")
  ? targetPath
  : targetPath
    ? `${targetPath}/`
    : undefined;
const onLandingPage = targetPathNormalized && currentPath === targetPathNormalized;

const shouldRender = promo && !onLandingPage;
---
{shouldRender && (
  <aside
    class="promo-bar"
    data-promo-bar
    data-promo-id={promo.id}
    role="region"
    aria-label="Promotion"
  >
    <a class="promo-link" href={promo.href}>
      <span class="promo-dot" aria-hidden="true"></span>
      <span class="promo-text">{promo.message}</span>
      <span class="promo-arrow" aria-hidden="true">&rarr;</span>
    </a>
    <button
      type="button"
      class="promo-dismiss"
      data-promo-dismiss
      aria-label="Dismiss promotion"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
  </aside>
)}

<style>
  /* ---------- Mobile (default) ---------- */

  .promo-bar {
    position: fixed;
    z-index: 19; /* below .site-chrome (20) so the header always wins
                    visually; the bar slides in *under* the header band. */

    /* Sit just below the persistent SiteHeader. Mobile header:
       padding 10px + logo 41px + padding 10px = ~61px.
       Plus 8px gap below it and slack for the header's bottom border.
       72px is the working number; safe-top added for notched devices. */
    left: 12px;
    right: 12px;
    top: calc(72px + var(--safe-top, 0px));

    display: flex;
    align-items: stretch;

    background: rgba(14, 10, 31, 0.92);
    -webkit-backdrop-filter: blur(18px) saturate(140%);
    backdrop-filter: blur(18px) saturate(140%);
    border-radius: calc(var(--radius-button) + 4px);
    border: 1px solid rgba(244, 239, 227, 0.10);
    border-top: 1px solid var(--glow);
    box-shadow: 0 18px 36px rgba(0, 0, 0, 0.4);

    /* Entry animation — slides DOWN from behind the header. Initial state
       offset upward; .promo-ready class on body triggers transition.
       Timing tuned so the bar arrives AFTER the sticky-CTA entry (Motion
       One: delay 550ms + duration 320ms = ~870ms) — gives the CTAs their
       moment first, then the promo slides in as a second beat. */
    transform: translateY(-140%);
    opacity: 0;
    transition:
      transform 380ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 260ms ease-out;
  }

  :global(body.promo-ready) .promo-bar {
    transform: translateY(0);
    opacity: 1;
  }

  /* Dismissed state — slide back up and fade out, then hide entirely. */
  .promo-bar[data-dismissed] {
    transform: translateY(-140%);
    opacity: 0;
    pointer-events: none;
  }

  /* ---------- The message link (full-bleed clickable area) ---------- */

  .promo-link {
    flex: 1 1 auto;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 14px;
    color: var(--warm-white);
    text-decoration: none;
    font-family: var(--font-ui);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.01em;
    line-height: 1.25;
    min-width: 0; /* allow text truncation if needed */
  }

  .promo-dot {
    flex: 0 0 8px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--glow);
    box-shadow: 0 0 8px rgba(178, 255, 89, 0.6); /* soft Glow halo */
  }

  .promo-text {
    flex: 1 1 auto;
    /* Allow up to 2 lines, then clamp. Removes the prior single-line
       ellipsis (which cut "Free Bowling For Kids — throu…" on desktop). */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .promo-arrow {
    flex: 0 0 auto;
    color: var(--glow);
    font-size: 16px;
    line-height: 1;
    transition: transform 200ms ease;
  }

  .promo-link:hover .promo-arrow,
  .promo-link:focus-visible .promo-arrow {
    transform: translateX(2px);
  }

  /* ---------- Dismiss button ---------- */

  .promo-dismiss {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    padding: 0;
    background: transparent;
    border: 0;
    border-left: 1px solid rgba(244, 239, 227, 0.10);
    color: var(--warm-mid);
    cursor: pointer;
    transition: color 150ms ease;
  }

  .promo-dismiss:hover,
  .promo-dismiss:focus-visible {
    color: var(--warm-white);
  }

  /* ---------- Desktop (≥1025): bottom-right toast ---------- */

  @media (min-width: 1025px) {
    .promo-bar {
      /* Desktop layout is different: bottom-right toast, not top bar.
         Override mobile top: with bottom: and adjust left/right. The slide
         direction also flips — initial state translates DOWN below the
         viewport, slides UP into view. */
      left: auto;
      top: auto;
      right: 24px;
      bottom: 24px;
      width: 440px; /* wider so message gets 2 generous lines, not 1 truncated */
      max-width: calc(100vw - 48px);

      transform: translateY(140%);
    }

    :global(body.promo-ready) .promo-bar {
      transform: translateY(0);
    }

    .promo-bar[data-dismissed] {
      transform: translateY(140%);
    }

    .promo-link {
      padding: 13px 18px;
      font-size: 14px;
      line-height: 1.3;
    }

    .promo-dismiss {
      width: 44px;
    }
  }

  /* ---------- Reduced motion ---------- */

  @media (prefers-reduced-motion: reduce) {
    .promo-bar {
      transform: none;
      opacity: 1;
      transition: none;
    }
  }
</style>

<script is:inline>
  // Client-side: trigger the entry animation AFTER the sticky CTA bar
  // lands. Motion One animates the CTA bar with delay 550ms + duration
  // 320ms = ~870ms. We wait ~1200ms so the promo arrives as a deliberate
  // second beat rather than competing with the CTA entry.
  //
  // No persistence: user dismissal hides the bar for the current page
  // view only. Reloading or navigating brings it back. This is intentional
  // per the 2026-05-10 product call — the promo is a recurring nudge for
  // the showFrom→showUntil window, not a permanent overlay the user
  // wants to silence forever. Showing it again on the next page load
  // costs the user one click; never showing it again costs us the
  // conversion.
  (function () {
    var bar = document.querySelector("[data-promo-bar]");
    if (!bar) return;

    // Trigger entry slide-in after the CTA bar has finished its own.
    window.setTimeout(function () {
      document.body.classList.add("promo-ready");
    }, 1200);

    // Dismiss handler — slide back to initial state then hide entirely
    // once the transition completes so it can't trap pointer events.
    var dismissBtn = bar.querySelector("[data-promo-dismiss]");
    if (dismissBtn) {
      dismissBtn.addEventListener("click", function () {
        bar.setAttribute("data-dismissed", "");
        window.setTimeout(function () {
          bar.style.display = "none";
        }, 420); // matches transition duration + small slack
      });
    }
  })();
</script>
