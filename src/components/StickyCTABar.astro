---
/**
 * Global sticky CTA bar — appears on every page (unless layout passes hideStickyCTA).
 *
 * Mobile (≤1024): bottom bar, two equal-weight buttons.
 * Desktop (≥1025): top-right of a sticky header, same two buttons.
 *
 * Always visible (per locked decision — see CLAUDE.md decisions log 2026-04-30).
 */
---
<aside class="cta-bar" data-cta-bar aria-label="Site actions">
  <a href="/reserve" class="btn btn-solid">Reserve a lane</a>
  <a href="/events" class="btn btn-outline">Plan an event</a>
</aside>

<style>
  .cta-bar {
    position: fixed;
    z-index: 30;
    display: flex;
    gap: 10px;

    /* mobile: bottom bar, full-width buttons */
    left: 12px;
    right: 12px;
    bottom: calc(12px + var(--safe-bottom));

    background: rgba(14, 10, 31, 0.88);
    backdrop-filter: blur(18px) saturate(140%);
    -webkit-backdrop-filter: blur(18px) saturate(140%);
    padding: 10px;
    border-radius: calc(var(--radius-button) + 4px);
    border: 1px solid rgba(244, 239, 227, 0.10);
    box-shadow: 0 18px 36px rgba(0, 0, 0, 0.4);

    /* entry state — Motion One slides this up on first paint */
    transform: translateY(120%);
    opacity: 0;
  }
  .cta-bar .btn { flex: 1; padding: 14px 16px; font-size: 11.5px; }

  @media (min-width: 1025px) {
    /* Desktop: become a top-right sticky header. */
    .cta-bar {
      top: calc(16px + var(--safe-top));
      right: 24px;
      left: auto;
      bottom: auto;
      padding: 8px;
      gap: 8px;
      border-radius: var(--radius-button);
    }
    .cta-bar .btn { flex: 0 0 auto; padding: 12px 20px; font-size: 12px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-bar { transform: none; opacity: 1; }
  }
</style>
