---
/**
 * Mobile sticky CTA bar — bottom-bar variant only.
 *
 * Desktop CTAs moved into the persistent SiteHeader (Phase 1 build). This
 * component is mobile-only — display: none on ≥1025.
 *
 * CTA hierarchy mirrors the desktop header: Reserve a Lane is primary
 * (Glow solid), Plan an Event is the deliberate alternate (Indigo Deep
 * solid + warm-white outlined). Restraint-as-confidence pattern.
 * See CLAUDE.md decisions log 2026-05-01 for the reversal of the earlier
 * "two co-equal primaries / Glow + Copper" treatment.
 */
import { PLAN_EVENT_URL } from "../lib/links";
---
<div class="cta-bar-base" aria-hidden="true"></div>
<aside class="cta-bar" data-cta-bar aria-label="Site actions">
  <a href="https://ecom.roller.app/twistedpin/openbowl/en-us/home" target="_blank" rel="noopener" class="btn btn-solid">Reserve a lane</a>
  <a href={PLAN_EVENT_URL} target="_blank" rel="noopener" class="btn btn-outline">Plan an event</a>
</aside>

<style>
  /* Solid blur strip from viewport bottom up to where the pill starts.
     Same backdrop-filter + Indigo Deep wash as the pill, so the pill
     reads as seated on a continuous base rather than floating with a
     visible gap below it. No fade above (that was the earlier mistake). */
  .cta-bar-base {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    height: calc(6px + var(--safe-bottom));
    z-index: 29;
    pointer-events: none;
    background: rgba(14, 10, 31, 0.88);
    -webkit-backdrop-filter: blur(18px) saturate(140%);
    backdrop-filter: blur(18px) saturate(140%);
  }
  @media (min-width: 1025px) {
    .cta-bar-base { display: none; }
  }

  .cta-bar {
    position: fixed;
    z-index: 30;
    display: flex;
    gap: 10px;

    /* Mobile bottom bar, full-width buttons. Tight 6px gap to the viewport
       bottom (was 12px) — small enough that no meaningful page content
       shows in the gap. Pill's own backdrop-blur handles content scrolling
       behind it. */
    left: 12px;
    right: 12px;
    bottom: calc(6px + var(--safe-bottom));

    background: rgba(14, 10, 31, 0.88);
    backdrop-filter: blur(18px) saturate(140%);
    -webkit-backdrop-filter: blur(18px) saturate(140%);
    padding: 10px;
    border-radius: calc(var(--radius-button) + 4px);
    border: 1px solid rgba(244, 239, 227, 0.10);
    box-shadow: 0 18px 36px rgba(0, 0, 0, 0.4);

    /* Entry state — Motion One slides this up on first paint. */
    transform: translateY(120%);
    opacity: 0;
  }
  .cta-bar .btn { flex: 1; padding: 14px 16px; font-size: 11.5px; }

  /* Desktop: bar is hidden — CTAs live in the persistent SiteHeader. */
  @media (min-width: 1025px) {
    .cta-bar { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-bar { transform: none; opacity: 1; }
  }
</style>
