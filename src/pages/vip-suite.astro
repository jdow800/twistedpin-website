---
/**
 * /vip-suite/ — VIP Suite pillar page.
 *
 * Third inner-page mock. Highest-LTV page on the site — the suite is the
 * actual revenue engine, doing both bowling AND events differentiation
 * work. Per voice.md: VIP suite is where bowling and events converge,
 * mention the cocktail credential here in service of "the bar program
 * in the VIP suite is the same one curated by..."
 *
 * Same skeleton as /bar and /eat:
 *   - Hero: typography-led title section (no image)
 *   - Two long-scroll editorial sections (image one side, copy the other,
 *     alternating)
 *   - SnapFooter
 *
 * Two thematic sections:
 *   1. The Room — physical specs (lanes, capacity, AV, seating, bar/kitchen access)
 *   2. What You Can Do — use cases (birthdays, corporate, holiday parties)
 *
 * **Fundraisers do NOT happen in the VIP suite** — they run on the main
 * floor, Thursdays 5–9pm only. Dedicated /fundraisers page covers that
 * program. Keep this page clear of fundraiser language to avoid creating
 * an inaccurate public claim.
 *
 * Rule-of-three triggered: .bar-* / .eat-* / .vip-* CSS is now triplicated.
 * Next refactor pass should hoist shared rules to .pillar-* utilities in
 * global.css. Flagged in Context/media-needs.md.
 *
 * TODOs (non-blocking):
 *   - Section photos are stubs (events-bg-600 / events-bg-540, same shot
 *     as the homepage Events snap). Need distinct VIP-suite imagery —
 *     room shot + event-energy shot. See Context/media-needs.md.
 */
import Base from "../layouts/Base.astro";
import SnapFooter from "../components/snap/SnapFooter.astro";
import BreadcrumbSchema from "../components/BreadcrumbSchema.astro";
import {
  BUSINESS_URL,
  BUSINESS_ENTITY_ID,
  addressNAP,
  videoObjectSchema,
} from "../lib/schema";
import { PLAN_EVENT_URL } from "../lib/links";
import { VIP_LANES_VIDEO } from "../data/videos";

const vipLanesVideoSchema = videoObjectSchema(VIP_LANES_VIDEO);

// JSON-LD: EventVenue with its own @id (#vip-suite) — the suite is a
// distinct sub-location with its own capacity claim. containedInPlace
// links it back to the venue via @id. Capacity mirrors the page copy
// ("Up to 80"); when ops corrects the displayed number, schema updates
// in the same diff.
const PAGE_URL = `${BUSINESS_URL}/vip-suite/`;
const vipSuiteSchema = {
  "@context": "https://schema.org",
  "@type": "EventVenue",
  "@id": `${BUSINESS_URL}/#vip-suite`,
  name: "The VIP Suite at Twisted Pin",
  url: PAGE_URL,
  description:
    "Six bowling lanes set apart from the traditional lanes, in-house catering, the same craft cocktail program as the main bar. Up to 80 guests. Plainfield, IL.",
  image: `${BUSINESS_URL}/snap/vip-energy-900.webp`,
  maximumAttendeeCapacity: 80,
  address: addressNAP(),
  containedInPlace: { "@id": BUSINESS_ENTITY_ID },
};
---
<Base
  title="VIP Suite — Bowling for Groups Up to 80 | Twisted Pin"
  description="Six lanes for your group, in-house catering, craft cocktails. Birthdays, offsites, holiday parties — the VIP suite at Twisted Pin, Plainfield, IL."
  ogImage="/og/og-vip-suite.jpg"
  ogImageAlt="The VIP suite at Twisted Pin — six lanes set apart for groups"
  lcpPreloadHref="/snap/vip-lanes-poster.avif"
  lcpPreloadMedia="(max-width: 1024px)"
>

  {/* ============================================================
      HERO — typography-led title section (no image)
      ============================================================ */}
  <section class="vip-hero" data-hero aria-labelledby="vip-hero-h1">
    <div class="vip-hero-copy">
      <p class="t-eyebrow hero-fade" data-delay-ms="0">Group Events</p>
      <h1 class="t-display vip-hero-headline hero-fade" id="vip-hero-h1" data-delay-ms="120">
        The&nbsp;6-lane VIP&nbsp;suite.
      </h1>
      <p class="vip-hero-sub hero-fade" data-delay-ms="320">
        Up to 80 people. Reserve two lanes, four, or all six. The same
        bar program as the rest of the venue. Built for the night you
        want to throw.
      </p>
    </div>
  </section>

  {/* ============================================================
      THE ROOM — image left, copy right (desktop)
      ============================================================ */}
  <section class="vip-section" aria-labelledby="vip-room-h2">
    <div class="vip-section-grid">
      <div class="vip-section-frame">
        {/* "VIP Lanes" video — source is landscape 4K (3840×2160);
            center-cropped to portrait in the encode pipeline (full
            source height, center horizontal slice) so the lanes + LED
            screens read as the focal subject.
            LCP optimization (2026-05-17): direct poster= + preload via
            Base.astro lcpPreloadHref; bounded media queries on sources.
            Same recipe as /events first section. */}
        <video
          class="vip-section-video"
          data-section-video
          preload="none"
          muted
          loop
          playsinline
          poster="/snap/vip-lanes-poster.avif"
          aria-label="The 6-lane VIP suite at Twisted Pin — neon-lit lanes with LED video walls overhead"
        >
          <source media="(max-width: 480px)" data-src="/snap/vip-lanes-mobile-av1-540.mp4"  type="video/mp4; codecs=av01.0.05M.08" />
          <source media="(max-width: 480px)" data-src="/snap/vip-lanes-mobile-h264-540.mp4" type="video/mp4" />
          <source media="(min-width: 481px)" data-src="/snap/vip-lanes-mobile-av1-1080.mp4"  type="video/mp4; codecs=av01.0.05M.08" />
          <source media="(min-width: 481px)" data-src="/snap/vip-lanes-mobile-h264-1080.mp4" type="video/mp4" />
        </video>
      </div>
      <div class="vip-section-copy">
        <p class="t-eyebrow">The Room</p>
        <h2 class="t-display vip-section-title" id="vip-room-h2">
          Six lanes. Yours.
        </h2>
        <p class="vip-section-aside">(when you take the whole suite)</p>

        <p class="vip-section-body">
          Six bowling lanes set apart from the traditional lanes —
          divided by a wall, semi-private. Reserve two lanes, four, or
          all six; the whole suite is yours when you take it over.
          Semi-private couch seating wraps the lanes for whoever'd rather
          watch than throw. LED video wall for slideshows, sports,
          presentations, or whatever you want playing. AV solutions
          available.
        </p>

        <p class="vip-section-body">
          The 28-tap self-serve wall sits right next to it. The cocktail
          bar runs the program curated by Brian Van Flandern,
          <em>America's Top Mixologist</em> — same drinks, same
          execution as the rest of the venue. The kitchen runs through,
          too.
        </p>

        <ul class="vip-section-list">
          <li>Reserve 2, 4, or 6 lanes</li>
          <li>Up to 80 people</li>
          <li>LED video wall</li>
          <li>AV solutions available</li>
          <li>Semi-private couch seating</li>
          <li>Tap wall + cocktail bar + kitchen access</li>
        </ul>
      </div>
    </div>
  </section>

  {/* ============================================================
      WHAT YOU CAN DO — image RIGHT, copy LEFT (desktop alternation)
      ============================================================ */}
  <section class="vip-section vip-section--reverse" aria-labelledby="vip-uses-h2">
    <div class="vip-section-grid">
      <div class="vip-section-frame">
        {/* "Buffet Before & After" video (2026-05-12) — replaces the
            vip-energy still. Reuses /snap/buffet-mobile-* assets
            (same source video the homepage Events snap uses; DRY).
            Lazy-loaded via data-section-video — poster shows until
            section enters viewport, then sources promote. */}
        <video
          class="vip-section-video"
          data-section-video
          preload="none"
          muted
          loop
          playsinline
          data-poster="/snap/buffet-poster.avif"
          aria-label="A buffet of catering food set up for a group event at Twisted Pin"
        >
          <source media="(max-width: 480px)" data-src="/snap/buffet-mobile-av1-540.mp4"  type="video/mp4; codecs=av01.0.05M.08" />
          <source media="(max-width: 480px)" data-src="/snap/buffet-mobile-h264-540.mp4" type="video/mp4" />
          <source media="(min-width: 481px)" data-src="/snap/buffet-mobile-av1-1080.mp4"  type="video/mp4; codecs=av01.0.05M.08" />
          <source media="(min-width: 481px)" data-src="/snap/buffet-mobile-h264-1080.mp4" type="video/mp4" />
        </video>
      </div>
      <div class="vip-section-copy">
        <p class="t-eyebrow">What You Can Do Here</p>
        <h2 class="t-display vip-section-title" id="vip-uses-h2">
          Birthdays. Corporate. Holiday parties.
        </h2>
        <p class="vip-section-aside">(or whatever you can talk us into)</p>

        <p class="vip-section-body">
          Most groups book the suite for adult birthday parties, <a href="/corporate-events/">corporate
          offsites</a>, holiday parties, and staff appreciation nights.
          Bridal showers, gender reveals, graduation parties, reception
          dinners — those work too. Tell us what you want; we set it up.
        </p>

        <p class="vip-section-body">
          In-house catering through the kitchen. Run a tab or hand out
          drink tickets — pick whatever billing model fits your group.
          The suite is yours from setup to last call.
        </p>

        <p class="vip-section-body">
          Hosting a <a href="/birthday-parties-booking/">kids' birthday
          party</a>? That runs on a separate package — book online for
          the kids' party flow.
        </p>

        <ul class="vip-section-list">
          <li>Adult birthday parties</li>
          <li><a href="/corporate-events/">Corporate offsites</a></li>
          <li><a href="/corporate-events/">Holiday parties</a></li>
          <li>Staff appreciation events</li>
          <li>Graduation parties</li>
          <li>Gender reveals</li>
          <li>Bridal showers</li>
          <li>Reception dinners</li>
        </ul>

        <a class="btn btn-outline" href={PLAN_EVENT_URL} target="_blank" rel="noopener">Plan an event</a>
      </div>
    </div>
  </section>

  <SnapFooter />

  <script type="application/ld+json" set:html={JSON.stringify(vipSuiteSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(vipLanesVideoSchema)} />
  <BreadcrumbSchema crumbs={[
    { name: "Home", path: "/" },
    { name: "VIP Suite", path: "/vip-suite/" },
  ]} />
</Base>

<style>
  /* ============================================================
     /vip-suite — same pattern as /bar, /eat. Class names .vip-*
     mirror .bar-* / .eat-*; rule-of-three has triggered, so the
     next refactor pass should hoist shared rules to .pillar-*
     utilities in global.css (see Context/media-needs.md tech debt).
     ============================================================ */

  /* ---------- hero (typography-led, no image) ---------- */
  .vip-hero {
    position: relative;
    display: flex;
    align-items: center;
    /* Match t2-hero — see /bar.astro for rationale. */
    min-height: clamp(320px, 42vh, 420px);
    padding: calc(var(--header-height) + 28px) 22px 24px;
  }
  @media (min-width: 1025px) {
    .vip-hero {
      min-height: clamp(440px, 55vh, 640px);
      padding: calc(var(--header-height) + 64px) 64px 64px;
      /* Desktop: center the title moment horizontally — same pattern
         as /bar and /eat. */
      justify-content: center;
    }
  }

  .vip-hero-copy {
    max-width: 720px;
    color: var(--warm-white);
  }
  @media (min-width: 1025px) {
    .vip-hero-copy {
      text-align: center;
    }
    .vip-hero-sub {
      margin-left: auto;
      margin-right: auto;
    }
  }

  .vip-hero-headline {
    color: var(--warm-white);
    font-size: clamp(28px, 8vw, 56px);
    letter-spacing: -0.005em;
    line-height: 0.95;
    margin-top: 12px;
  }
  @media (min-width: 1025px) {
    .vip-hero-headline { font-size: clamp(48px, 5.2vw, 72px); }
  }

  .vip-hero-sub {
    margin-top: 18px;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.5;
    color: #ece6d6;
    max-width: 32em;
  }
  @media (min-width: 1025px) {
    .vip-hero-sub { margin-top: 22px; font-size: 19px; max-width: 36em; }
  }

  /* .hero-fade hoisted to global.css (2026-05-08 LCP fix). */

  /* ============================================================
     section pattern (same shape as .bar-section / .eat-section)
     ============================================================ */
  .vip-section {
    /* Transparent so the global body::before Pin Tilt watermark shows
       through. */
    background: transparent;
    /* Tightened — see /bar.astro for rationale. */
    padding: 5px 22px;
  }
  @media (min-width: 1025px) {
    .vip-section { padding: 24px 64px; }
  }

  .vip-section-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    max-width: 1280px;
    margin: 0 auto;
    align-items: start;
  }
  @media (min-width: 1025px) {
    .vip-section-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
      gap: 64px;
    }
    .vip-section--reverse .vip-section-grid > .vip-section-frame {
      order: 2;
    }
  }

  .vip-section-frame {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-surface);
    aspect-ratio: 4 / 5;
  }
  @media (min-width: 1025px) {
    .vip-section-frame { aspect-ratio: 3 / 4; max-height: 640px; }
  }

  .vip-section-img,
  .vip-section-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .vip-section-copy {
    color: var(--warm-white);
    max-width: 36em;
  }

  .vip-section-title {
    color: var(--warm-white);
    font-size: clamp(28px, 7.5vw, 42px);
    line-height: 0.98;
    letter-spacing: -0.005em;
    margin-top: 10px;
  }
  @media (min-width: 1025px) {
    .vip-section-title { font-size: clamp(40px, 4.2vw, 56px); }
  }

  .vip-section-aside {
    margin-top: 6px;
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--warm-dim);
  }
  @media (min-width: 1025px) {
    .vip-section-aside { font-size: 17px; }
  }

  .vip-section-body {
    margin-top: 18px;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    color: var(--warm-mid);
  }
  @media (min-width: 1025px) {
    .vip-section-body { font-size: 17.5px; line-height: 1.65; }
  }

  .vip-section-list {
    margin-top: 22px;
    padding-left: 0;
    list-style: none;
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--warm-white);
  }
  .vip-section-list li {
    padding: 8px 0 8px 22px;
    border-bottom: 1px solid rgba(244, 239, 227, 0.08);
    position: relative;
  }
  .vip-section-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--glow);
    opacity: 0.85;
  }

  .vip-section-copy .btn {
    margin-top: 28px;
  }
</style>
