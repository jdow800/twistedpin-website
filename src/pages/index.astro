---
/**
 * Homepage. Promoted from /snap-test/ on 2026-05-03 (was staging since
 * Phase 2A). Promotion preserves rendered output exactly; only the route
 * (snap-test → index) and the page metadata changed.
 *
 * Parallel mobile / desktop tracks share Hero (snap 1) and Footer (snap 8);
 * the middle six snaps swap via `mobile-only` / `desktop-only` classes
 * gated by `@media (min-width: 1025px)`.
 *
 * Mobile track (≤1024px):
 *   1. Hero                          (shared)
 *   2. Events That Don't Suck        (stub)
 *   3. Tap Wall                      (real beer-wall video)
 *   4. Craft Cocktails               (stub)
 *   5. Eat                           (stub)
 *   6. Bowl                          (stub)
 *   7. Game                          (stub)
 *   8. Footer                        (shared)
 *
 * Desktop track (≥1025px):
 *   1. Hero                          (shared)
 *   2. Events                        (cluster grid)
 *   3. Tap Wall                      (cluster grid, video)
 *   4. Craft Cocktails               (cluster grid)
 *   5. Eat                           (cluster grid)
 *   6. Bowl                          (cluster grid)
 *   7. Game                          (cluster grid)
 *   8. Footer                        (shared)
 *
 * Snap mechanic: container-driven scroll-snap on mobile (≤1024), normal
 *   long-scroll on desktop. See the .snap CSS block for specifics.
 *
 * Hero is INLINED in this file (snap 1) rather than a shared component —
 *   the inlined version is the canonical implementation. (The older
 *   src/components/Hero.astro was deleted 2026-05-05.)
 *
 * Sticky CTA bar (rendered by Base) stays visible on snaps 1–7; the
 *   page-level scroll watcher toggles `body.snap-cta-hidden` when the
 *   footer is in view, fading the bar out.
 */
import Base from "../layouts/Base.astro";
import SnapStub from "../components/snap/SnapStub.astro";
import SnapFooter from "../components/snap/SnapFooter.astro";
import {
  localBusinessBase,
  BUSINESS_NAME,
  BUSINESS_URL,
  BUSINESS_ENTITY_ID,
} from "../lib/schema";

// JSON-LD: BarOrPub primary entity + bare WebSite. Single @type per page
// (bar-led thesis; bowling lives on /bowl). hasMap, hours, NAP, sameAs
// all come from localBusinessBase().
const PAGE_URL = `${BUSINESS_URL}/`;

const barOrPubSchema = {
  ...(await localBusinessBase({
    url: PAGE_URL,
    image: `${BUSINESS_URL}/hero/hero-desktop-poster.webp`,
    description:
      "A craft cocktail program curated by Brian Van Flandern (America's Top Mixologist), a 28-tap self-serve beer and wine wall, and 17 traditional bowling lanes plus a 6-lane VIP suite. Bar-led, group-friendly, in Plainfield, IL.",
  })),
  "@type": "BarOrPub",
};

// WebSite — entity declaration only. No SearchAction (no site-search route).
// publisher references the LocalBusiness via @id so the entity graph
// unifies across pages.
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${BUSINESS_URL}/#website`,
  url: BUSINESS_URL,
  name: BUSINESS_NAME,
  publisher: { "@id": BUSINESS_ENTITY_ID },
};
---
<Base
  title="Twisted Pin — Cocktails, Taps & VIP Suite. Plainfield, IL."
  description="A craft cocktail program curated by Brian Van Flandern (America's Top Mixologist). 28 self-serve taps. 17 lanes + 6-lane VIP suite. Plainfield, IL."
>
  {/* <div class="snap"> rather than <main class="snap">. Base.astro
      now wraps every page's slot in a <main> landmark; keeping a
      <main> here too would double-nest. The .snap class carries the
      snap-scroll behavior + Pin Tilt watermark — only div→main was
      semantic, so the swap is purely structural. */}
  <div class="snap">
    {/* ================================================
        SNAP 1 — HERO (revised per brief)
        Inlined: shared <Hero /> stays untouched until staging review.
        ================================================ */}
    <section class="snap-section snap-hero" data-hero aria-labelledby="hero-h1">
      {/* Logo lives in the persistent SiteHeader — not duplicated here.
          The header sits over the hero with a translucent dark scrim. */}

      {/* Mobile vertical 9:16 video — same source as the live hero.
          Source order: AV1 (best compression) first, H.264 (universal) fallback.

          Media queries on <source> mirror the CSS display rules so each
          viewport only fetches ONE hero video. Without the upper bound
          on the 1080w sources, desktop visits would fetch the mobile-1080
          AND desktop variants (CSS display:none doesn't stop a <source>
          fetch — the browser resolves the first matching source per
          element). Lighthouse on 2026-05-08 caught ~3.7 MB of doubled
          fetches on every mobile visit. 2026-05-08 perf pass.

          Within mobile, 540w wins for phones ≤480px CSS width (749 KB
          H.264 / 1.2 MB AV1); 1080w covers tablets up to 1024px CSS
          width (1.8 MB H.264 / 2.0 MB AV1). Desktop kicks in at 1025px+
          via the desktop video below. */}
      <video
        class="hero-video hero-video-mobile"
        preload="none"
        muted
        autoplay
        loop
        playsinline
        poster="/hero/hero-poster.webp"
        aria-hidden="true"
      >
        <source media="(max-width: 480px)" src="/hero/hero-mobile-av1-540.mp4"  type="video/mp4; codecs=av01.0.05M.08" />
        <source media="(max-width: 480px)" src="/hero/hero-mobile-h264-540.mp4" type="video/mp4" />
        <source media="(max-width: 1024px)" src="/hero/hero-mobile-av1-1080.mp4"  type="video/mp4; codecs=av01.0.05M.08" />
        <source media="(max-width: 1024px)" src="/hero/hero-mobile-h264-1080.mp4" type="video/mp4" />
      </video>

      {/* Desktop 16:9 video.
          data-section-video: pauses when scroll-past drops the ratio below 0.5,
          freeing main-thread decode for the Tap Wall video next in line.
          Mobile hero video is intentionally NOT marked — locked mobile track.

          `media="(min-width: 1025px)"` on every source ensures viewports
          below the desktop breakpoint never fetch the desktop variant.
          On mobile/tablet the browser finds no matching source and just
          falls back to the data-poster (when promoted) — but since
          .hero-video-desktop is display:none below 1025px, the poster
          isn't visible there anyway. Net: one video file fetched per
          viewport tier. */}
      <video
        class="hero-video hero-video-desktop"
        data-section-video
        preload="none"
        muted
        autoplay
        loop
        playsinline
        data-poster="/hero/hero-desktop-poster.webp"
        aria-hidden="true"
      >
        <source media="(min-width: 1025px)" src="/hero/hero-desktop-av1.mp4" type="video/mp4; codecs=av01.0.05M.08" />
        <source media="(min-width: 1025px)" src="/hero/hero-desktop-h264.mp4" type="video/mp4" />
      </video>

      {/* Bottom-only scrim — dark fade up from the bottom. */}
      <div class="hero-scrim" aria-hidden="true"></div>

      <div class="hero-copy">
        <h1 class="t-display hero-headline" id="hero-h1">
          <span class="hero-headline-line hero-fade" data-delay-ms="0">Built&nbsp;for&nbsp;adults.</span>
          <span class="hero-headline-line hero-fade" data-delay-ms="300">Fine,&nbsp;bring&nbsp;the&nbsp;kids.</span>
        </h1>
        <p class="hero-sub hero-fade" data-delay-ms="380">
          Plainfield's premier night out. Bowling optional.
        </p>
      </div>
    </section>

    {/* ================================================
        SNAP 2 — EVENTS THAT DON'T SUCK  (mobile-only stub)
        ================================================ */}
    <SnapStub
      title="Events That Don't Suck"
      subhead="Take over the suite. Run the night your way."
      href="/events/"
      video="buffet"
      imageAlt="A buffet of catering food set up for a group event at Twisted Pin"
      class="mobile-only"
    />

    {/* ================================================
        SNAP 3 — THE TAP WALL  (mobile-only, real beer-wall video)
        ================================================ */}
    <section class="snap-section snap-tapwall mobile-only" data-tapwall-section aria-labelledby="tapwall-h1">
      {/* Lazy: <video preload="none">; sources held in data-src until the
          page-level lazy-loader promotes them on near-viewport entry. */}
      <video
        class="tapwall-video"
        data-tapwall-video
        preload="none"
        muted
        loop
        playsinline
        data-poster="/snap/beerwall-poster.webp"
        aria-hidden="true"
      >
        {/* Narrow-viewport variants (≤480px CSS width) come first — first-match-wins
            means phones fetch the 540w files instead of the 1080w. Saves ~50%
            bandwidth on this lazy-loaded section. Encoded by build-snap-video.sh. */}
        <source media="(max-width: 480px)" data-src="/snap/beerwall-mobile-av1-540.mp4"  type="video/mp4; codecs=av01.0.05M.08" />
        <source media="(max-width: 480px)" data-src="/snap/beerwall-mobile-h264-540.mp4" type="video/mp4" />
        <source data-src="/snap/beerwall-mobile-av1-1080.mp4"  type="video/mp4; codecs=av01.0.05M.08" />
        <source data-src="/snap/beerwall-mobile-h264-1080.mp4" type="video/mp4" />
      </video>
      <div class="tapwall-scrim" aria-hidden="true"></div>

      <div class="tapwall-inner">
        <h2 class="tapwall-title" id="tapwall-h1">The tap wall</h2>
        <p class="tapwall-sub">
          <span class="tapwall-sub-main">28 self-serve taps</span>
          <span class="tapwall-sub-paren">(only wall in the area)</span>
        </p>
        <a class="stub-learn" href="/bar/">Learn more <span aria-hidden="true">→</span></a>
      </div>
    </section>

    {/* ================================================
        SNAP 4 — CRAFT COCKTAILS  (mobile-only stub; terse credential)
        Desktop track promotes this to a 50/50 split with the long-form
        reserved copy ("Cocktails this serious aren't supposed to live at
        bowling alleys.") — see the desktop-cocktails section below.
        ================================================ */}
    <SnapStub
      title="Craft Cocktails"
      subhead="Curated by Brian Van Flandern."
      subheadParen="America's Top Mixologist"
      href="/bar/"
      video="cocktails-hero"
      imageAlt="Cocktail being built behind the bar at Twisted Pin"
      class="mobile-only"
    />

    {/* ================================================
        SNAP 5 — EAT  (mobile-only; food-focused copy, no bar reference)
        ================================================ */}
    <SnapStub
      title="Eat"
      subhead="Chef-inspired menu."
      subheadParen="built to share"
      href="/eat/"
      image="eat-kitchen"
      imageAlt="Chafers of chips, salsa, guacamole, and wings on a buffet at Twisted Pin"
      class="mobile-only"
    />

    {/* ================================================
        SNAP 6 — BOWL  (mobile-only; VIP-leading + take-it-over aside)
        Desktop EBG card uses the tighter no-aside variant — see voice.md
        Locked Lines (two Bowl variants).
        ================================================ */}
    <SnapStub
      title="Bowl"
      subhead="17 traditional lanes plus a 6-lane VIP suite."
      subheadParen="yes, you can take it over"
      href="/bowl/"
      image="vip-energy"
      imageAlt="The VIP suite at Twisted Pin set up for a custom celebration with named signage and balloons"
      class="mobile-only"
    />

    {/* ================================================
        SNAP 7 — GAME  (mobile-only; statement / aside)
        ================================================ */}
    <SnapStub
      title="Game"
      subhead="Skee-ball, redemption, jackpot."
      subheadParen="don't pretend you don't want the giant bear"
      href="/game/"
      video="arcade"
      imageAlt="Arcade games at Twisted Pin"
      class="mobile-only"
    />

    {/* ================================================
        DESKTOP TRACK — six cluster sections, each one full viewport
        height with vertical scroll-snap. Mobile snap-track is locked
        and untouched; this is the desktop-only sibling track that
        mirrors mobile's 6-section structure (Hero + 6 + Footer = 8
        snaps top-to-bottom on both devices).

        Pattern: every section uses the same composition — frame on
        the LEFT, copy on the RIGHT, no alternation. Sameness IS the
        design (per the Spotify-featured-albums register). Snap-scroll
        gives each section full viewport presence, so the dead-air
        problem from earlier phases (when sections shared a long-scroll
        with content centered in a 100vh box) doesn't apply here —
        the cluster fills the section.

        Body copy on Events / Tap Wall / Cocktails is locked from
        prior phases. Body copy on Eat / Bowl / Game is FIRST DRAFT
        — voice-checked but expects user iteration.

        Class strategy: shared `.cluster-*` classes (single rule per
        property) since six sections use the identical pattern. Per-
        section classes (`.desktop-events` etc.) are kept on the
        section element only, for any section-specific overrides if
        ever needed.
        ================================================ */}

    {/* DESKTOP — Events */}
    <section class="snap-section desktop-only desktop-events" aria-labelledby="desktop-events-h2">
      <div class="cluster-grid">
        <div class="cluster-frame">
          {/* Buffet "after" video — last 7s of Buffet Before & After.mov,
              the full-spread payoff. Same single-active-video rule via
              sectionVideo() in motion.client.ts; data-src lazy-promotion. */}
          <video class="cluster-video" data-section-video preload="none" muted loop playsinline data-poster="/snap/buffet-poster.webp" aria-label="A buffet of catering food set up for a group event at Twisted Pin">
            <source data-src="/snap/buffet-mobile-av1-1080.mp4" type="video/mp4; codecs=av01.0.05M.08" />
            <source data-src="/snap/buffet-mobile-h264-1080.mp4" type="video/mp4" />
          </video>
        </div>
        <div class="cluster-copy">
          <p class="section-eyebrow" data-reveal>VIP Suite</p>
          <h2 class="cluster-title" id="desktop-events-h2" data-reveal>Events that don't suck</h2>
          <p class="cluster-body" data-reveal>Take over the 6-lane VIP suite. Custom catering. Birthdays, corporate things, the after-party of an after-party. Tell us what you want, we set it up.</p>
          <a class="stub-learn" href="/events" data-reveal>Learn more <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>

    {/* DESKTOP — Tap Wall (video, lazy-loaded + plays when in-viewport) */}
    <section class="snap-section desktop-only desktop-tapwall" aria-labelledby="desktop-tapwall-h2">
      <div class="cluster-grid">
        <div class="cluster-frame">
          <video class="cluster-video" data-section-video preload="none" muted loop playsinline data-poster="/snap/beerwall-poster.webp" aria-hidden="true">
            <source data-src="/snap/beerwall-mobile-av1-1080.mp4" type="video/mp4; codecs=av01.0.05M.08" />
            <source data-src="/snap/beerwall-mobile-h264-1080.mp4" type="video/mp4" />
          </video>
        </div>
        <div class="cluster-copy">
          <p class="section-eyebrow" data-reveal>The Bar</p>
          <h2 class="cluster-title" id="desktop-tapwall-h2" data-reveal>The tap wall</h2>
          <p class="cluster-body" data-reveal>28 self-serve taps. The only self-serve wall in the area. Pour your own beer, wine, or rotating cocktail. Tap a card, find your style, settle up when you're done.</p>
          <a class="stub-learn" href="/bar" data-reveal>Learn more <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>

    {/* DESKTOP — Cocktails (long-form credential, two-line split body) */}
    <section class="snap-section desktop-only desktop-cocktails" aria-labelledby="desktop-cocktails-h2">
      <div class="cluster-grid">
        <div class="cluster-frame">
          {/* Cocktails Hero video — bartender building a cocktail, autoplay-
              muted-loop. Same single-active-video rule as Tap Wall via
              sectionVideo() in motion.client.ts; data-src lazy-promotion. */}
          <video class="cluster-video" data-section-video preload="none" muted loop playsinline data-poster="/snap/cocktails-hero-poster.webp" aria-label="A cocktail being built behind the bar at Twisted Pin">
            <source data-src="/snap/cocktails-hero-mobile-av1-1080.mp4" type="video/mp4; codecs=av01.0.05M.08" />
            <source data-src="/snap/cocktails-hero-mobile-h264-1080.mp4" type="video/mp4" />
          </video>
        </div>
        <div class="cluster-copy">
          <p class="section-eyebrow" data-reveal>The Bar</p>
          <h2 class="cluster-title" id="desktop-cocktails-h2" data-reveal>Craft cocktails</h2>
          <p class="cluster-body cluster-body-split">
            <span data-reveal>Cocktails this serious aren't supposed to live at bowling alleys.</span>
            <span data-reveal>Curated by Brian Van Flandern, America's Top Mixologist.</span>
          </p>
          <a class="stub-learn" href="/bar" data-reveal>Learn more <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>

    {/* DESKTOP — Eat (DRAFT body copy) */}
    <section class="snap-section desktop-only desktop-eat" aria-labelledby="desktop-eat-h2">
      <div class="cluster-grid">
        <div class="cluster-frame">
          <picture>
            <source type="image/webp" srcset="/snap/stage-eat-540.webp 540w, /snap/stage-eat-600.webp 600w" sizes="(min-width: 1280px) 405px, 32vw" />
            <img class="cluster-img" src="/snap/stage-eat-600.jpg" srcset="/snap/stage-eat-540.jpg 540w, /snap/stage-eat-600.jpg 600w" sizes="(min-width: 1280px) 405px, 32vw" alt="A spread of food at Twisted Pin" width="600" height="1067" loading="lazy" decoding="async" />
          </picture>
        </div>
        <div class="cluster-copy">
          <p class="section-eyebrow" data-reveal>Kitchen</p>
          <h2 class="cluster-title" id="desktop-eat-h2" data-reveal>Eat</h2>
          <p class="cluster-body" data-reveal>Chef-inspired menu, built to share. Wings, flatbreads, cheese curds — things that travel from kitchen to lane without losing the plot. Custom catering when you take it over.</p>
          <a class="stub-learn" href="/eat" data-reveal>Learn more <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>

    {/* DESKTOP — Bowl (DRAFT body copy) */}
    <section class="snap-section desktop-only desktop-bowl" aria-labelledby="desktop-bowl-h2">
      <div class="cluster-grid">
        <div class="cluster-frame">
          <picture>
            <source type="image/webp" srcset="/snap/stage-bowl-540.webp 540w, /snap/stage-bowl-600.webp 600w" sizes="(min-width: 1280px) 405px, 32vw" />
            <img class="cluster-img" src="/snap/stage-bowl-600.jpg" srcset="/snap/stage-bowl-540.jpg 540w, /snap/stage-bowl-600.jpg 600w" sizes="(min-width: 1280px) 405px, 32vw" alt="Bowling lanes at Twisted Pin" width="600" height="1067" loading="lazy" decoding="async" />
          </picture>
        </div>
        <div class="cluster-copy">
          <p class="section-eyebrow" data-reveal>Lanes</p>
          <h2 class="cluster-title" id="desktop-bowl-h2" data-reveal>Bowl</h2>
          <p class="cluster-body" data-reveal>17 lanes plus a 6-lane VIP suite. Traditional lanes are open to anyone; the suite is takeable when you book it. Leagues, birthdays, the after-party — pick your size.</p>
          <a class="stub-learn" href="/bowl" data-reveal>Learn more <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>

    {/* DESKTOP — Game (DRAFT body copy) */}
    <section class="snap-section desktop-only desktop-game" aria-labelledby="desktop-game-h2">
      <div class="cluster-grid">
        <div class="cluster-frame">
          {/* Arcade video — autoplay-muted-loop, 6s window. Same lazy-
              loaded pattern as Cocktails / Tap Wall / Buffet. */}
          <video class="cluster-video" data-section-video preload="none" muted loop playsinline data-poster="/snap/arcade-poster.webp" aria-label="Arcade games at Twisted Pin">
            <source data-src="/snap/arcade-mobile-av1-1080.mp4" type="video/mp4; codecs=av01.0.05M.08" />
            <source data-src="/snap/arcade-mobile-h264-1080.mp4" type="video/mp4" />
          </video>
        </div>
        <div class="cluster-copy">
          <p class="section-eyebrow" data-reveal>Arcade</p>
          <h2 class="cluster-title" id="desktop-game-h2" data-reveal>Game</h2>
          <p class="cluster-body" data-reveal>Skee-ball, redemption, jackpot. Win tickets, walk out with the giant bear, drag your group through the prize wall. Open as late as we are.</p>
          <a class="stub-learn" href="/game" data-reveal>Learn more <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>

    {/* ================================================
        FOOTER — shared by both tracks.
        Sticky CTA bar fades out when this section is in view (mobile only;
        desktop CTAs live in the persistent SiteHeader).
        ================================================ */}
    <SnapFooter />
  </div>

  {/* JSON-LD: BarOrPub primary entity + bare WebSite. Same @id used
      across pages so crawlers unify the venue into one entity. */}
  <script type="application/ld+json" set:html={JSON.stringify(barOrPubSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
</Base>

<script>
  /* ============================================================
     Beer-wall video lazy-load (snap 3). Same pattern as before:
     <source data-src="…"> until IntersectionObserver promotes to src.
     Scroll-listener fallback covers environments where IO doesn't
     fire reliably for sub-scroller intersections.
     ============================================================ */
  const tapwallSection = document.querySelector<HTMLElement>("[data-tapwall-section]");
  const tapwallVideo = document.querySelector<HTMLVideoElement>("[data-tapwall-video]");
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (tapwallSection && tapwallVideo && !reducedMotion) {
    let promoted = false;
    const promoteSources = () => {
      if (promoted) return;
      promoted = true;
      tapwallVideo.querySelectorAll<HTMLSourceElement>("source[data-src]").forEach((s) => {
        const src = s.getAttribute("data-src");
        if (src) s.setAttribute("src", src);
      });
      // Lazy-poster promotion (matches motion.client.ts sectionVideo).
      const lazyPoster = tapwallVideo.getAttribute("data-poster");
      if (lazyPoster && !tapwallVideo.getAttribute("poster")) {
        tapwallVideo.setAttribute("poster", lazyPoster);
      }
      tapwallVideo.load();
    };
    const tryPlay = () => {
      promoteSources();
      tapwallVideo.play().catch(() => { /* autoplay blocked; poster stays */ });
    };

    if ("IntersectionObserver" in window) {
      const preloadObs = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              promoteSources();
              preloadObs.disconnect();
            }
          }
        },
        { rootMargin: "100% 0px 100% 0px", threshold: 0.01 },
      );
      preloadObs.observe(tapwallSection);

      const playObs = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) tryPlay();
            else tapwallVideo.pause();
          }
        },
        { threshold: 0.6 },
      );
      playObs.observe(tapwallSection);
    }

    const snapEl = document.querySelector<HTMLElement>(".snap");
    if (snapEl) {
      const onScroll = () => {
        const rect = tapwallSection.getBoundingClientRect();
        const vh = window.innerHeight;
        if (rect.top < vh * 2 && rect.bottom > -vh) promoteSources();
        if (rect.top < vh * 0.4 && rect.bottom > vh * 0.6) tryPlay();
      };
      snapEl.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    }
  }

  /* Sticky-CTA hide-on-SnapFooter mechanic moved to motion.client.ts
     (snapFooterCTAHide function) on 2026-05-04. Now applies to every
     page including SnapFooter — was /-only before. The global rule
     in global.css does the actual fade. */

  /* ============================================================
     Cluster section videos — same single-active-video rule as the
     existing sectionVideo() motion module (which already handles
     `[data-section-video]` elements via IntersectionObserver at
     threshold 0.5). The desktop Tap Wall video is marked
     data-section-video and inherits that behavior — plays only when
     its section is in the viewport, pauses on others. With desktop
     scroll-snap, only one section can be visible at a time, so the
     ratio>0.5 rule cleanly identifies the active section.
     ============================================================ */
</script>

<style>
  /* ============================================================
     Snap container. Vertical scroll-snap on BOTH mobile and desktop —
     each section is one full viewport, snaps into place when scrolled
     past its midpoint. Apple-product-page / CLUBHAUS register on
     desktop; same mechanic mobile already had. Mobile (≤1024) and
     desktop (≥1025) share the rule; the only desktop difference is
     overscroll-behavior (mobile gets a contained bounce, desktop
     defaults to native).
     ============================================================ */
  .snap {
    height: 100dvh;
    height: 100vh;
    height: 100dvh;
    overflow-y: scroll;
    overflow-x: hidden;
    scroll-snap-type: y mandatory;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior-y: contain;
  }
  /* Direct children become snap stops. `:global(.snap-section)` is needed
     because SnapStub and SnapFooter are child components — Astro scopes
