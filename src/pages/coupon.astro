---
/**
 * /coupon — $10 lane credit signup.
 *
 * 2026-05-07: reverted from native Astro form + Patch Retention API to
 * an embedded iframe wrapper. The Patch trigger pattern (DOI + coupon
 * SMS dispatch) was open pending Patch support response, and the user
 * wanted to abandon that integration for now and ship something that
 * matches the legacy live behavior. The iframe URL points at the same
 * hosted form behind the live twistedpin.com page, so the existing
 * SMS/email automation continues to work end-to-end without us
 * re-implementing it.
 *
 * Architecture: brand chrome + iframe. Same wrap pattern as /waitlist.
 *
 * Future revisit: when Patch support clarifies the API trigger pattern,
 * the native-form version (commit history, before this commit) can be
 * revived. For now, the iframe is the pragmatic ship.
 *
 * Voice rule: live page headline is "$10 OFF Open Bowling Certificate!"
 * which clashes with the hard ban on discount/off/deals language.
 * Reframed to "$10 lane credit" — same reframe pattern used on /rewards.
 */
import Base from "../layouts/Base.astro";
import SnapFooter from "../components/snap/SnapFooter.astro";

const COUPON_FORM_URL = "https://c-g.co/xORo1J";
---
<Base
  title="$10 Lane Credit — Twisted Pin Plainfield IL"
  description="Get a $10 lane credit toward open bowling at Twisted Pin in Plainfield, IL. Sign up, we'll text the code to your phone."
>

  <section class="t2-hero" data-hero aria-labelledby="coupon-h1">
    <div class="t2-hero-copy">
      <p class="t-eyebrow hero-fade" data-delay-ms="0">For Regulars (and the soon-to-be)</p>
      <h1 class="t-display t2-hero-headline hero-fade" id="coupon-h1" data-delay-ms="120">
        $10 toward your next&nbsp;lane.
      </h1>
      <p class="t2-hero-sub hero-fade" data-delay-ms="320">
        Drop your number below. We'll text you a $10 lane credit good
        on walk-in open bowling — or use it on a
        <a href="https://ecom.roller.app/twistedpin/openbowl/en-us/home" target="_blank" rel="noopener">lane reservation online</a>.
      </p>
    </div>
  </section>

  <section class="t2-section coupon-section" aria-labelledby="coupon-form-h2">
    <div class="t2-section-inner">
      <h2 class="t-eyebrow" id="coupon-form-h2" style="font-size:11px;">Sign Up</h2>

      <div class="coupon-frame">
        <iframe
          src={COUPON_FORM_URL}
          title="Sign up to receive your $10 lane credit"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="coupon-iframe"
        ></iframe>
      </div>

      <p class="coupon-fallback">
        Form not loading?
        <a href={COUPON_FORM_URL} target="_blank" rel="noopener noreferrer">
          Open it in a new tab &rarr;
        </a>
      </p>

      <p class="coupon-fineprint">
        Cannot be combined with other offers. Valid for open bowling
        only &mdash; not events, leagues, or the VIP suite. One redemption
        per customer.
      </p>
    </div>
  </section>

  <SnapFooter />
</Base>

<style>
  /* ============================================================
     /coupon iframe frame — same chrome register as /waitlist.
     Kept Indigo Deep backstop so any load-state gap reads dark,
     not blank white.
     ============================================================ */

  .coupon-section .t2-section-inner {
    max-width: 560px;
  }

  .coupon-frame {
    position: relative;
    margin-top: 16px;
    overflow: hidden;
    border-radius: var(--radius-surface);
    border: 1px solid rgba(244, 239, 227, 0.12);
    box-shadow:
      0 8px 16px rgba(0, 0, 0, 0.30),
      0 24px 48px rgba(0, 0, 0, 0.45);
    background: #0E0A1F;
  }

  .coupon-iframe {
    display: block;
    width: 100%;
    height: 1100px; /* matches the legacy live embed sizing */
    border: 0;
  }

  .coupon-fallback {
    margin-top: 14px;
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--warm-dim);
  }
  .coupon-fallback a {
    color: var(--glow);
    text-decoration: none;
    margin-left: 6px;
  }
  .coupon-fallback a:hover { text-decoration: underline; }

  .coupon-fineprint {
    margin-top: 32px;
    padding-top: 16px;
    border-top: 1px solid rgba(244, 239, 227, 0.08);
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.55;
    color: var(--warm-dim);
  }
</style>
