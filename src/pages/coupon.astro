---
/**
 * /coupon — $10 lane credit signup.
 *
 * 2026-05-07: reverted from native Astro form + Patch Retention API to
 * an embedded iframe wrapper. The Patch trigger pattern (DOI + coupon
 * SMS dispatch) was open pending Patch support response, and the user
 * wanted to abandon that integration for now and ship something that
 * matches the legacy live behavior. The iframe URL points at the same
 * hosted form behind the live twistedpin.com page, so the existing
 * SMS/email automation continues to work end-to-end without us
 * re-implementing it.
 *
 * Architecture: brand chrome + iframe. Same wrap pattern as /waitlist.
 *
 * Future revisit: when Patch support clarifies the API trigger pattern,
 * the native-form version (commit history, before this commit) can be
 * revived. For now, the iframe is the pragmatic ship.
 *
 * Voice rule: live page headline is "$10 OFF Open Bowling Certificate!"
 * which clashes with the hard ban on discount/off/deals language.
 * Reframed to "$10 lane credit" — same reframe pattern used on /rewards.
 */
import Base from "../layouts/Base.astro";
import SnapFooter from "../components/snap/SnapFooter.astro";
import BreadcrumbSchema from "../components/BreadcrumbSchema.astro";

const COUPON_FORM_URL = "https://c-g.co/xORo1J";
---
<Base
  title="Free $10 Lane Credit in Plainfield, IL | Twisted Pin"
  description="Get a free $10 lane credit toward open bowling at Twisted Pin in Plainfield, IL. Sign up — we'll text the credit to your phone in a few minutes."
>

  <section class="t2-hero" data-hero aria-labelledby="coupon-h1">
    <div class="t2-hero-copy">
      <p class="t-eyebrow hero-fade" data-delay-ms="0">For Regulars (and the soon-to-be)</p>
      <h1 class="t-display t2-hero-headline hero-fade" id="coupon-h1" data-delay-ms="120">
        $10 toward your next&nbsp;lane.
      </h1>
      <p class="t2-hero-sub hero-fade" data-delay-ms="320">
        Drop your number below. We'll text you a free $10 lane credit
        good on walk-in open bowling — or use it on a
        <a href="https://ecom.roller.app/twistedpin/openbowl/en-us/home" target="_blank" rel="noopener">lane reservation online</a>.
      </p>
    </div>
  </section>

  <section class="t2-section coupon-section" aria-labelledby="coupon-form-h2">
    <div class="t2-section-inner">
      <h2 class="t-eyebrow" id="coupon-form-h2" style="font-size:11px;">Sign Up</h2>

      <div class="coupon-frame">
        <iframe
          src={COUPON_FORM_URL}
          title="Sign up to receive your $10 lane credit"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="coupon-iframe"
        ></iframe>
      </div>

      <p class="coupon-fallback">
        Form not loading?
        <a href={COUPON_FORM_URL} target="_blank" rel="noopener noreferrer">
          Open it in a new tab &rarr;
        </a>
      </p>

      <p class="coupon-fineprint">
        Cannot be combined with other offers. Valid for open bowling
        only &mdash; not events, leagues, or the VIP suite. One redemption
        per customer.
      </p>
    </div>
  </section>

  {/* ============================================================
      SEO body block — explanatory copy beneath the iframe so the
      page has indexable content beyond the form chrome. Voice-aligned,
      no discount/off framing in the headline (the canonical reframe
      is "$10 lane credit"). Two redemption paths kept simple — the
      operational details (lookup mechanic, overage handling) live
      at the front desk, not in copy that could go stale.
      ============================================================ */}
  <section class="t2-section" aria-labelledby="coupon-info-h2">
    <div class="t2-section-inner">
      <p class="t-eyebrow">How it works</p>
      <h2 class="t-display coupon-info-title" id="coupon-info-h2">
        Two ways to use it.
      </h2>
      <p class="t2-section-body">
        Walk in and bring your phone to the front desk. We apply the
        $10 lane credit to your bowling tab. Or use it on a
        <a href="https://ecom.roller.app/twistedpin/openbowl/en-us/home" target="_blank" rel="noopener">lane reservation online</a>
        and the $10 comes off the booking total. Either way, it's for
        open bowling specifically &mdash; not group events, leagues, or
        the VIP suite.
      </p>
      <p class="t2-section-body">
        Plainfield's where we are; Will County's where most of our
        regulars come from. The credit's a low-friction way to test
        the place if you haven't been in. Date night, family night out,
        a Saturday with friends &mdash; the $10 applies to whatever the
        lane rate is when you arrive, and the rest of the night runs
        as a normal visit.
      </p>
      <p class="t2-section-body">
        One credit per customer. See <a href="/pricing/">walk-in pricing</a>
        for what $10 covers on a given day, or <a href="/bowl/">more on
        bowling here</a> before you book.
      </p>
    </div>
  </section>

  <SnapFooter />
  <BreadcrumbSchema crumbs={[
    { name: "Home", path: "/" },
    { name: "Coupon", path: "/coupon/" },
  ]} />
</Base>

<style>
  /* ============================================================
     /coupon iframe frame — same chrome register as /waitlist.
     Kept Indigo Deep backstop so any load-state gap reads dark,
     not blank white.
     ============================================================ */

  .coupon-section .t2-section-inner {
    max-width: 560px;
  }

  .coupon-frame {
    position: relative;
    margin-top: 16px;
    overflow: hidden;
    border-radius: var(--radius-surface);
    border: 1px solid rgba(244, 239, 227, 0.12);
    box-shadow:
      0 8px 16px rgba(0, 0, 0, 0.30),
      0 24px 48px rgba(0, 0, 0, 0.45);
    background: #0E0A1F;
  }

  .coupon-iframe {
    display: block;
    width: 100%;
    height: 1100px; /* matches the legacy live embed sizing */
    border: 0;
  }

  .coupon-fallback {
    margin-top: 14px;
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--warm-dim);
  }
  .coupon-fallback a {
    color: var(--glow);
    text-decoration: none;
    margin-left: 6px;
  }
  .coupon-fallback a:hover { text-decoration: underline; }

  .coupon-fineprint {
    margin-top: 32px;
    padding-top: 16px;
    border-top: 1px solid rgba(244, 239, 227, 0.08);
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.55;
    color: var(--warm-dim);
  }

  /* SEO body block heading — same recipe as .fkb-section-title.
     Will fold into the .pillar-* CSS hoist when that lands. */
  .coupon-info-title {
    color: var(--warm-white);
    font-size: clamp(28px, 7.5vw, 42px);
    line-height: 0.98;
    letter-spacing: -0.005em;
    margin: 10px 0 16px;
  }
  @media (min-width: 1025px) {
    .coupon-info-title { font-size: clamp(40px, 4.2vw, 56px); }
  }
</style>
