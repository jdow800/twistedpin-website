---
/**
 * /bar/ — Bar program pillar page.
 *
 * First inner-page mock. Establishes the inner-page rhythm:
 *   - Hero: typography-led title section (no image — page identity comes
 *     from the headline against the body bg + global Pin Tilt watermark).
 *     2026-05-04: switched from full-bleed cocktail-bg image to type-only.
 *     The image was redundant with the homepage's cocktails snap, and a
 *     typography hero gets to body content faster.
 *   - Long-scroll editorial sections (image one side, copy the other,
 *     alternating)
 *   - SnapFooter (reused from homepage)
 *
 * Closing CTA band ("Come see for yourself.") was retired 2026-05-04 —
 * the global sticky CTA bar at the bottom of the viewport already carries
 * Reserve / Plan, so a duplicate at the page bottom was visual debt without
 * conversion lift. SnapFooter handles the "find us" beat at the bottom.
 *
 * Two thematic sections because the bar IS two things:
 *   1. Tap Wall (28 self-serve taps)
 *   2. Craft Cocktails (Brian Van Flandern program)
 *
 * NOT snap-mechanic — inner pages are normal long-scroll. Snap is reserved
 * for / where the tasting-menu format earns it.
 *
 * TODOs (non-blocking):
 *   - "View what's on tap" CTA points at /menu/taps/ (Untappd integration shipped 2026-05-05).
 *   - "View the cocktail menu" CTA points at /menu/cocktails/ (GoTab integration shipped 2026-05-05).
 *   - 5 signature cocktail names + descriptions are placeholders.
 *   - Cocktail editorial photo: bar-cocktails-* (AIV01579 copper-shaker
 *     pour, encoded 2026-05-07). Distinct from homepage's AIV01592
 *     (cherry old fashioned).
 */
import Base from "../layouts/Base.astro";
import SnapFooter from "../components/snap/SnapFooter.astro";
import { getCocktails } from "../lib/gotab-cocktails";
import { localBusinessBase, BUSINESS_URL } from "../lib/schema";

// Editorial page only as of 2026-05-05 — full cocktail menu lives at
// /menu/cocktails, full tap list at /menu/taps. We still fetch cocktails
// here for the editorial teaser (5 staff favorites previewed in the
// craft cocktails section).
const cocktailMenu = await getCocktails();

// JSON-LD: BarOrPub for the bar program + Person for Brian Van Flandern.
// Same @id as homepage (BUSINESS_ENTITY_ID) — entity unification.
// Brian's @id is canonical so future pages can reference him by @id.
//
// IMPORTANT: Brian is a consulting partner, NOT staff. No worksFor,
// no employee link to BarOrPub. Co-occurrence on this page (he's named
// in the BarOrPub.description AND has his own Person entity) is enough
// for AI assistants to link the credential to the venue without making
// a structured employment claim.
const PAGE_URL = `${BUSINESS_URL}/bar/`;
const BRIAN_ID = `${BUSINESS_URL}/#brian-van-flandern`;

const barOrPubSchema = {
  ...(await localBusinessBase({
    url: PAGE_URL,
    image: `${BUSINESS_URL}/snap/bar-cocktails-900.webp`,
    description:
      "The bar at Twisted Pin — a craft cocktail program designed by Brian Van Flandern (America's Top Mixologist, Food Network) and a 28-tap self-serve beer and wine wall. Plainfield, IL.",
  })),
  "@type": "BarOrPub",
};

/**
 * sameAs — entity-graph identifiers for Brian. Verified URLs only,
 * picked for Knowledge Graph signal strength: Wikipedia (canonical
 * encyclopedia entity), IMDb (Food Network appearance credits — Bar
 * Rescue, Barefoot Contessa, A Nice Touch), mymixologist.com (his
 * canonical owned URL, listed as official site on Wikipedia), and
 * the Instagram handle that matches his domain.
 *
 * Intentionally omitted: X/Twitter and LinkedIn — both are
 * medium-confidence (handle pattern matches but content not directly
 * verified by this session's research). Bad sameAs URLs do
 * disproportionate damage in structured data; better to ship four
 * verified URLs than six probable ones.
 *
 * Note re. brand thesis: Wikipedia + mymixologist.com both prominently
 * mention Per Se / Thomas Keller / Michelin three-star. Per CLAUDE.md
 * 2026-05-03, that framing is fully retired in **on-site copy**.
 * sameAs URLs are entity identifiers, not copy — Wikipedia is the
 * single strongest signal we have for Knowledge Graph unification, and
 * the rule applies to what we say about Brian, not to which canonical
 * encyclopedia entry we point at.
 */
const brianSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": BRIAN_ID,
  name: "Brian Van Flandern",
  jobTitle: "Mixologist",
  award: "America's Top Mixologist (Food Network)",
  knowsAbout: [
    "mixology",
    "cocktail program design",
    "craft cocktails",
  ],
  sameAs: [
    "https://en.wikipedia.org/wiki/Brian_Van_Flandern",
    "https://mymixologist.com",
    "https://www.imdb.com/name/nm4724304/",
    "https://www.instagram.com/mymixologist/",
  ],
  description:
    "Mixologist whose cocktails are served in 40+ countries. Designed the cocktail program at Twisted Pin in Plainfield, IL as a consulting partner.",
};
---
<Base
  title="Craft Cocktails & 28-Tap Self-Serve Beer Wall | Twisted Pin"
  description="A craft cocktail program by America's Top Mixologist plus the area's only 28-tap self-serve beer & wine wall. Twisted Pin, Plainfield IL."
  ogImage="/og/og-bar.jpg"
  ogImageAlt="A craft cocktail mid-pour at the bar at Twisted Pin"
>

  {/* ============================================================
      HERO — typography-led title section (no image)
      ============================================================ */}
  <section class="bar-hero" data-hero aria-labelledby="bar-hero-h1">
    <div class="bar-hero-copy">
      <p class="t-eyebrow hero-fade" data-delay-ms="0">Bar Program</p>
      <h1 class="t-display bar-hero-headline hero-fade" id="bar-hero-h1" data-delay-ms="120">
        Cocktails&nbsp;this&nbsp;serious aren't&nbsp;supposed to&nbsp;live at&nbsp;bowling alleys.
      </h1>
      <p class="bar-hero-sub hero-fade" data-delay-ms="320">
        28 self-serve taps and a craft cocktail program curated by
        Brian Van Flandern — America's Top Mixologist. Yes, here. Right
        next to the lanes.
      </p>
    </div>
  </section>

  {/* ============================================================
      TAP WALL — image left, copy right (desktop)
      ============================================================ */}
  <section class="bar-section" aria-labelledby="bar-tapwall-h2">
    <div class="bar-section-grid">
      <div class="bar-section-frame">
        <picture>
          <source type="image/webp" srcset="/snap/beerwall-poster.webp" />
          <img
            class="bar-section-img"
            src="/snap/beerwall-poster.jpg"
            alt="The 28-tap self-serve beer & wine wall at Twisted Pin"
            width="900"
            height="1600"
            loading="lazy"
            decoding="async"
          />
        </picture>
      </div>
      <div class="bar-section-copy">
        <p class="t-eyebrow">The Tap Wall</p>
        <h2 class="t-display bar-section-title" id="bar-tapwall-h2">
          28 self-serve taps.
        </h2>
        <p class="bar-section-aside">(only wall in the immediate area)</p>

        <p class="bar-section-body">
          Twenty-eight taps. Beer, wine, and a few non-alcoholic options
          on rotation. Grab a card, pour your own, pay by the ounce.
          No flagging down a bartender for a refill. No committing to a
          full pint when you just want to try something.
        </p>

        <p class="bar-section-body">
          The card tracks what you pour. The wall keeps the rotation
          fresh. The bartenders, freed from the basic-pour grind, are
          over at the cocktail bar doing the work that actually
          requires them.
        </p>

        <ul class="bar-section-list">
          <li>28 taps total</li>
          <li>Beer, wine, and non-alcoholic options on rotation</li>
          <li>Pay-by-the-ounce card system</li>
          <li>Pour your own — no waiting</li>
        </ul>

        <a class="btn btn-outline" href="/menu/taps/">View what's on tap</a>
      </div>
    </div>
  </section>

  {/* ============================================================
      CRAFT COCKTAILS — image RIGHT, copy LEFT (desktop alternation)
      ============================================================ */}
  <section class="bar-section bar-section--reverse" aria-labelledby="bar-cocktails-h2">
    <div class="bar-section-grid">
      <div class="bar-section-frame">
        <picture>
          <source type="image/webp" srcset="/snap/bar-cocktails-540.webp 540w, /snap/bar-cocktails-900.webp 900w" sizes="(min-width: 1025px) 480px, 90vw" />
          <img
            class="bar-section-img"
            src="/snap/bar-cocktails-540.jpg"
            srcset="/snap/bar-cocktails-540.jpg 540w, /snap/bar-cocktails-900.jpg 900w"
            sizes="(min-width: 1025px) 480px, 90vw"
            alt="A copper cocktail shaker mid-pour at Twisted Pin's bar"
            width="540"
            height="960"
            loading="lazy"
            decoding="async"
          />
        </picture>
      </div>
      <div class="bar-section-copy">
        <p class="t-eyebrow">Craft Cocktails</p>
        <h2 class="t-display bar-section-title" id="bar-cocktails-h2">
          Curated by Brian Van Flandern, America's Top Mixologist.
        </h2>
        <p class="bar-section-aside">(their words, not ours)</p>

        <p class="bar-section-body">
          The bar program at Twisted Pin was built by Brian Van Flandern —
          named <em>America's Top Mixologist</em> by Food Network, with
          cocktails served in 40+ countries.
        </p>

        <p class="bar-section-body">
          He's not behind our bar nightly. But the program he designed is —
          every spec, every technique, every garnish, every rotation. He's
          back this summer to retrain the team firsthand.
        </p>

        {cocktailMenu.teaserPicks.length > 0 && (
          <>
            <p class="bar-section-callout">A few to start with:</p>
            <ul class="bar-cocktail-list">
              {cocktailMenu.teaserPicks.map((c) => (
                <li>
                  <span class="cocktail-name">{c.name}</span>
                  {c.ingredients && (
                    <span class="cocktail-desc">{c.ingredients}</span>
                  )}
                </li>
              ))}
            </ul>
          </>
        )}

        <a class="btn btn-outline" href="/menu/cocktails/">View the cocktail menu</a>
      </div>
    </div>
  </section>

  <SnapFooter />

  {/* JSON-LD. Same @id as homepage's BarOrPub for entity unification.
      Brian is a separate Person entity — co-occurrence on the page,
      not a structured employment link. */}
  <script type="application/ld+json" set:html={JSON.stringify(barOrPubSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(brianSchema)} />
</Base>

<style>
  /* ============================================================
     /bar — inner-page rhythm. Long-scroll, NO snap mechanic.
     Reuses global tokens from global.css; no new color/font work.
     ============================================================ */

  /* ---------- hero (typography-led, no image) ----------
     Title section sized to feel like a deliberate "title moment"
     without dominating the viewport. Padding clears the persistent
     SiteHeader at the top and the mobile sticky CTA bar at the bottom. */
  .bar-hero {
    position: relative;
    display: flex;
    align-items: center;
    /* Match the t2-hero values from global.css for consistency across
       pillar + tier-2 pages. Mobile bottom padding is intentionally small
       (24px) — the hero is never tall enough to overlap the sticky CTA
       bar, so reserving --bar-pad worth of space here was pure dead-zone
       between the subhead and the next section's media. */
    min-height: clamp(320px, 42vh, 420px);
    padding: calc(var(--header-height) + 28px) 22px 24px;
  }
  @media (min-width: 1025px) {
    .bar-hero {
      min-height: clamp(440px, 55vh, 640px);
      padding: calc(var(--header-height) + 64px) 64px 64px;
      /* Desktop: center the copy column horizontally too — typography-only
         hero reads as a "title page" moment. Mobile keeps the left-aligned
         editorial flow because center-stacked lines on a narrow viewport
         feel busier than they help. */
      justify-content: center;
    }
  }

  .bar-hero-copy {
    /* Flexbox parent centers vertically (and on desktop, horizontally too);
       copy column constrained to readable measure. Left-aligned on mobile,
       center-aligned on desktop (see media query below). */
    max-width: 720px;
    color: var(--warm-white);
  }
  @media (min-width: 1025px) {
    .bar-hero-copy {
      text-align: center;
    }
    .bar-hero-sub {
      /* Center the sub paragraph (which has its own max-width) within
         the copy column so it doesn't hang left despite text-align:center. */
      margin-left: auto;
      margin-right: auto;
    }
  }

  .bar-hero-headline {
    color: var(--warm-white);
    /* Slightly smaller than the homepage hero (which goes to 110px on
       desktop). Inner pages should not out-shout the homepage. */
    font-size: clamp(28px, 8vw, 56px);
    letter-spacing: -0.005em;
    line-height: 0.95;
    margin-top: 12px;
  }
  @media (min-width: 1025px) {
    .bar-hero-headline { font-size: clamp(48px, 5.2vw, 72px); }
  }

  .bar-hero-sub {
    margin-top: 18px;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.5;
    color: #ece6d6;
    max-width: 32em;
  }
  @media (min-width: 1025px) {
    .bar-hero-sub { margin-top: 22px; font-size: 19px; max-width: 36em; }
  }

  /* .hero-fade rule + reduced-motion override hoisted to global.css
     (2026-05-08 LCP fix). heroEntry() in motion.client.ts watches
     [data-hero] for .hero-fade and animates transform on load. */

  /* ============================================================
     section pattern — used by Tap Wall and Cocktails
     Two-column on desktop; stacked image-then-copy on mobile.
     ============================================================ */
  .bar-section {
    /* Transparent so the global body::before Pin Tilt watermark shows
       through in the section gutters. Hero is now transparent too (no
       image), so the watermark is continuous from page top to footer. */
    background: transparent;
    /* Mobile padding tightened: was 56px → 32 → 15 → 5. Desktop
       tightened from 96 → 24 in the same pass. The original 96/96
       desktop combined with align-items: center on the grid (image
       taller than copy) created ~340px of dead space below the copy
       column. Tight padding + align-items: start fixes both. */
    padding: 5px 22px;
  }
  @media (min-width: 1025px) {
    .bar-section { padding: 24px 64px; }
  }

  .bar-section-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    max-width: 1280px;
    margin: 0 auto;
    /* align-items: start so copy hangs at top of the section next to
       the image, not centered (which created empty space below the
       copy when the image was taller). */
    align-items: start;
  }
  @media (min-width: 1025px) {
    .bar-section-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
      gap: 64px;
    }
    /* Reverse layout for the second section (image right, copy left)
       — alternation gives editorial rhythm. */
    .bar-section--reverse .bar-section-grid > .bar-section-frame {
      order: 2;
    }
  }

  .bar-section-frame {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-surface);
    /* Mobile: 4:5 portrait crop, fits a phone screen well.
       Desktop: 3:4 portrait, taller frame matches editorial weight. */
    aspect-ratio: 4 / 5;
  }
  @media (min-width: 1025px) {
    .bar-section-frame { aspect-ratio: 3 / 4; max-height: 640px; }
  }

  .bar-section-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .bar-section-copy {
    color: var(--warm-white);
    max-width: 36em;
  }

  .bar-section-title {
    color: var(--warm-white);
    font-size: clamp(28px, 7.5vw, 42px);
    line-height: 0.98;
    letter-spacing: -0.005em;
    margin-top: 10px;
  }
  @media (min-width: 1025px) {
    .bar-section-title { font-size: clamp(40px, 4.2vw, 56px); }
  }

  .bar-section-aside {
    margin-top: 6px;
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--warm-dim);
  }
  @media (min-width: 1025px) {
    .bar-section-aside { font-size: 17px; }
  }

  .bar-section-body {
    margin-top: 18px;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    color: var(--warm-mid);
  }
  @media (min-width: 1025px) {
    .bar-section-body { font-size: 17.5px; line-height: 1.65; }
  }

  .bar-section-list {
    margin-top: 22px;
    padding-left: 0;
    list-style: none;
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--warm-white);
  }
  .bar-section-list li {
    padding: 8px 0 8px 22px;
    border-bottom: 1px solid rgba(244, 239, 227, 0.08);
    position: relative;
  }
  .bar-section-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--glow);
    opacity: 0.85;
  }

  .bar-section-callout {
    margin-top: 22px;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--warm-white);
    opacity: 0.9;
  }

  .bar-cocktail-list {
    margin-top: 12px;
    padding-left: 0;
    list-style: none;
  }
  .bar-cocktail-list li {
    padding: 12px 0;
    border-bottom: 1px solid rgba(244, 239, 227, 0.08);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .cocktail-name {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: 0.005em;
    color: var(--warm-white);
  }
  .cocktail-desc {
    font-family: var(--font-body);
    font-size: 14.5px;
    color: var(--warm-dim);
  }
  @media (min-width: 1025px) {
    .cocktail-name { font-size: 22px; }
    .cocktail-desc { font-size: 16px; }
  }

  .bar-section-copy .btn {
    margin-top: 28px;
  }

  /* The closing CTA band (.bar-cta) was removed 2026-05-04 — the global
     sticky CTA bar already carries Reserve / Plan, so a duplicate at the
     page bottom was visual debt. SnapFooter handles the "find us" beat. */

  /* Tap-list and cocktail-menu styles moved to /menu/taps and
     /menu/cocktails on 2026-05-05 — they live with the pages that own
     them. /bar is editorial-only. */
</style>
