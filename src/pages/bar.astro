---
/**
 * /bar/ — Bar program pillar page.
 *
 * First inner-page mock. Establishes the inner-page rhythm:
 *   - Hero: typography-led title section (no image — page identity comes
 *     from the headline against the body bg + global Pin Tilt watermark).
 *     2026-05-04: switched from full-bleed cocktail-bg image to type-only.
 *     The image was redundant with the homepage's cocktails snap, and a
 *     typography hero gets to body content faster.
 *   - Long-scroll editorial sections (image one side, copy the other,
 *     alternating)
 *   - SnapFooter (reused from homepage)
 *
 * Closing CTA band ("Come see for yourself.") was retired 2026-05-04 —
 * the global sticky CTA bar at the bottom of the viewport already carries
 * Reserve / Plan, so a duplicate at the page bottom was visual debt without
 * conversion lift. SnapFooter handles the "find us" beat at the bottom.
 *
 * Two thematic sections because the bar IS two things:
 *   1. Tap Wall (28 self-serve taps)
 *   2. Craft Cocktails (Brian Van Flandern program)
 *
 * NOT snap-mechanic — inner pages are normal long-scroll. Snap is reserved
 * for / where the tasting-menu format earns it.
 *
 * TODOs (non-blocking):
 *   - "View what's on tap" CTA: GoTab API integration future. Link is "#".
 *   - "View cocktail menu" CTA: GoTab API integration future. Link is "#".
 *   - 5 signature cocktail names + descriptions are placeholders.
 *   - Cocktail editorial photos for the Cocktails section: stand-in is
 *     cocktails-bg-540 (same as homepage). AIV01579 (copper shaker pour)
 *     and AIV01592 (cherry old fashioned) per visual-direction.md are the
 *     targets when real photography lands.
 */
import Base from "../layouts/Base.astro";
import SnapFooter from "../components/snap/SnapFooter.astro";
import { getCocktails } from "../lib/gotab-cocktails";
import { getTapList } from "../lib/untappd-taps";

// Build-time fetches. Both fail closed (return empty) if upstream is
// unreachable — the page still renders, only the affected section
// disappears. Fired in parallel to keep build time tight.
const [cocktailMenu, tapList] = await Promise.all([
  getCocktails(),
  getTapList(),
]);
---
<Base
  title="Craft Cocktails & a 28-Tap Self-Serve Beer Wall | Twisted Pin"
  description="A craft cocktail program built by America's Top Mixologist plus a 28-tap self-serve beer & wine wall — the only one in the immediate area. The bar at Twisted Pin, Plainfield IL."
>

  {/* ============================================================
      HERO — typography-led title section (no image)
      ============================================================ */}
  <section class="bar-hero" data-hero aria-labelledby="bar-hero-h1">
    <div class="bar-hero-copy">
      <p class="t-eyebrow hero-fade" data-delay-ms="0">Bar Program</p>
      <h1 class="t-display bar-hero-headline hero-fade" id="bar-hero-h1" data-delay-ms="120">
        Cocktails&nbsp;this&nbsp;serious aren't&nbsp;supposed to&nbsp;live at&nbsp;bowling alleys.
      </h1>
      <p class="bar-hero-sub hero-fade" data-delay-ms="320">
        28 self-serve taps and a craft cocktail program built by
        America's Top Mixologist. Yes, here. Right next to the lanes.
      </p>
    </div>
  </section>

  {/* ============================================================
      TAP WALL — image left, copy right (desktop)
      ============================================================ */}
  <section class="bar-section" aria-labelledby="bar-tapwall-h2">
    <div class="bar-section-grid">
      <div class="bar-section-frame">
        <picture>
          <source type="image/webp" srcset="/snap/beerwall-poster.webp" />
          <img
            class="bar-section-img"
            src="/snap/beerwall-poster.jpg"
            alt="The 28-tap self-serve beer & wine wall at Twisted Pin"
            width="900"
            height="1600"
            loading="lazy"
            decoding="async"
          />
        </picture>
      </div>
      <div class="bar-section-copy">
        <p class="t-eyebrow">The Tap Wall</p>
        <h2 class="t-display bar-section-title" id="bar-tapwall-h2">
          28 self-serve taps.
        </h2>
        <p class="bar-section-aside">(only wall in the immediate area)</p>

        <p class="bar-section-body">
          Twenty-eight taps. Beer, wine, and a few non-alcoholic options
          on rotation. Grab a card, pour your own, pay by the ounce.
          No flagging down a bartender for a refill. No committing to a
          full pint when you just want to try something.
        </p>

        <p class="bar-section-body">
          The card tracks what you pour. The wall keeps the rotation
          fresh. The bartenders, freed from the basic-pour grind, are
          over at the cocktail bar doing the work that actually
          requires them.
        </p>

        <ul class="bar-section-list">
          <li>28 taps total</li>
          <li>Beer, wine, and non-alcoholic options on rotation</li>
          <li>Pay-by-the-ounce card system</li>
          <li>Pour your own — no waiting</li>
        </ul>

        <a class="btn btn-outline" href="#tap-list">View what's on tap</a>
      </div>
    </div>
  </section>

  {/* ============================================================
      TAP LIST — full Untappd-driven list. List-led layout (not photo
      grid like the cocktail menu) — beer lists are scannable text-led
      formats, tap number is the anchor.
      Powered by getTapList() build-time fetch. Empty when Untappd is
      unreachable (section just doesn't render).
      ============================================================ */}
  {tapList.sections.length > 0 && (
    <section class="tap-list" id="tap-list" aria-labelledby="tap-list-h2">
      <div class="tap-list-inner">
        <header class="tap-list-header">
          <p class="t-eyebrow">Currently Pouring</p>
          <h2 class="t-display tap-list-title" id="tap-list-h2">
            What's on right now.
          </h2>
        </header>

        {tapList.sections.map((section) => (
          <div class="tap-section">
            <h3 class="tap-section-name">
              {section.name} <span class="tap-section-count">· {section.taps.length}</span>
            </h3>
            <ul class="tap-rows" role="list">
              {section.taps.map((tap) => (
                <li class="tap-row">
                  <span class="tap-number">{tap.tapNumber}</span>
                  <div class="tap-content">
                    <div class="tap-line-1">
                      <span class="tap-name">{tap.name}</span>
                      {tap.abv && <span class="tap-abv">{tap.abv}%</span>}
                    </div>
                    <div class="tap-line-2">
                      {[tap.brewery, tap.breweryLocation, tap.style]
                        .filter(Boolean)
                        .join(' · ')}
                    </div>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>
  )}

  {/* ============================================================
      CRAFT COCKTAILS — image RIGHT, copy LEFT (desktop alternation)
      ============================================================ */}
  <section class="bar-section bar-section--reverse" aria-labelledby="bar-cocktails-h2">
    <div class="bar-section-grid">
      <div class="bar-section-frame">
        <picture>
          <source type="image/webp" srcset="/snap/cocktails-bg-540.webp" />
          <img
            class="bar-section-img"
            src="/snap/cocktails-bg-540.jpg"
            alt="A craft cocktail at Twisted Pin's bar"
            width="540"
            height="960"
            loading="lazy"
            decoding="async"
          />
        </picture>
      </div>
      <div class="bar-section-copy">
        <p class="t-eyebrow">Craft Cocktails</p>
        <h2 class="t-display bar-section-title" id="bar-cocktails-h2">
          Built by America's Top Mixologist.
        </h2>
        <p class="bar-section-aside">(their words, not ours)</p>

        <p class="bar-section-body">
          The bar program at Twisted Pin was built by Brian Van Flandern —
          named <em>America's Top Mixologist</em> by Food Network, with
          cocktails served in 40+ countries.
        </p>

        <p class="bar-section-body">
          He's not behind our bar nightly. But the program he designed is —
          every spec, every technique, every garnish, every rotation. He's
          back this summer to retrain the team firsthand.
        </p>

        {cocktailMenu.teaserPicks.length > 0 && (
          <>
            <p class="bar-section-callout">A few to start with:</p>
            <ul class="bar-cocktail-list">
              {cocktailMenu.teaserPicks.map((c) => (
                <li>
                  <span class="cocktail-name">{c.name}</span>
                  {c.ingredients && (
                    <span class="cocktail-desc">{c.ingredients}</span>
                  )}
                </li>
              ))}
            </ul>
          </>
        )}

        <a class="btn btn-outline" href="#cocktail-menu">View the cocktail menu</a>
      </div>
    </div>
  </section>

  {/* ============================================================
      COCKTAIL MENU — full list grouped by GoTab category.
      Powered by getCocktails() build-time fetch. Empty when GoTab
      is unreachable (section just doesn't render).
      ============================================================ */}
  {cocktailMenu.categories.length > 0 && (
    <section class="cocktail-menu" id="cocktail-menu" aria-labelledby="cocktail-menu-h2">
      <div class="cocktail-menu-inner">
        <header class="cocktail-menu-header">
          <p class="t-eyebrow">The Menu</p>
          <h2 class="t-display cocktail-menu-title" id="cocktail-menu-h2">
            Every cocktail, on the rocks or up.
          </h2>
        </header>

        {cocktailMenu.categories.map((cat) => (
          <div class="cocktail-category">
            <h3 class="cocktail-category-name">{cat.name}</h3>
            <ul class="cocktail-grid" role="list">
              {cat.cocktails.map((c) => (
                <li class="cocktail-card">
                  {c.imageUrl && (
                    <div class="cocktail-card-frame">
                      <img
                        src={c.imageUrl}
                        srcset={c.imageUrlLg ? `${c.imageUrl} 480w, ${c.imageUrlLg} 720w` : undefined}
                        sizes="(min-width: 1025px) 360px, (min-width: 700px) 45vw, 92vw"
                        alt={c.name}
                        width="480"
                        height="270"
                        loading="lazy"
                        decoding="async"
                      />
                      {c.isStaffFavorite && (
                        <span class="cocktail-card-badge">Staff Pick</span>
                      )}
                    </div>
                  )}
                  <div class="cocktail-card-body">
                    <h4 class="cocktail-card-name">{c.name}</h4>
                    {c.ingredients && (
                      <p class="cocktail-card-ingredients">{c.ingredients}</p>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>
  )}

  <SnapFooter />
</Base>

<style>
  /* ============================================================
     /bar — inner-page rhythm. Long-scroll, NO snap mechanic.
     Reuses global tokens from global.css; no new color/font work.
     ============================================================ */

  /* ---------- hero (typography-led, no image) ----------
     Title section sized to feel like a deliberate "title moment"
     without dominating the viewport. Padding clears the persistent
     SiteHeader at the top and the mobile sticky CTA bar at the bottom. */
  .bar-hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: clamp(420px, 60vh, 560px);
    padding:
      calc(var(--header-height) + 32px) 22px
      calc(var(--bar-pad) + 32px);
  }
  @media (min-width: 1025px) {
    .bar-hero {
      min-height: clamp(440px, 55vh, 640px);
      padding: calc(var(--header-height) + 64px) 64px 64px;
      /* Desktop: center the copy column horizontally too — typography-only
         hero reads as a "title page" moment. Mobile keeps the left-aligned
         editorial flow because center-stacked lines on a narrow viewport
         feel busier than they help. */
      justify-content: center;
    }
  }

  .bar-hero-copy {
    /* Flexbox parent centers vertically (and on desktop, horizontally too);
       copy column constrained to readable measure. Left-aligned on mobile,
       center-aligned on desktop (see media query below). */
    max-width: 720px;
    color: var(--warm-white);
  }
  @media (min-width: 1025px) {
    .bar-hero-copy {
      text-align: center;
    }
    .bar-hero-sub {
      /* Center the sub paragraph (which has its own max-width) within
         the copy column so it doesn't hang left despite text-align:center. */
      margin-left: auto;
      margin-right: auto;
    }
  }

  .bar-hero-headline {
    color: var(--warm-white);
    /* Slightly smaller than the homepage hero (which goes to 110px on
       desktop). Inner pages should not out-shout the homepage. */
    font-size: clamp(28px, 8vw, 56px);
    letter-spacing: -0.005em;
    line-height: 0.95;
    margin-top: 12px;
  }
  @media (min-width: 1025px) {
    .bar-hero-headline { font-size: clamp(48px, 5.2vw, 72px); }
  }

  .bar-hero-sub {
    margin-top: 18px;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.5;
    color: #ece6d6;
    max-width: 32em;
  }
  @media (min-width: 1025px) {
    .bar-hero-sub { margin-top: 22px; font-size: 19px; max-width: 36em; }
  }

  /* hero-fade entry uses the same Motion One pipeline as the homepage hero
     (heroEntry() in motion.client.ts watches [data-hero] for .hero-fade).
     Initial state set here; Motion overrides on entry. */
  .hero-fade { opacity: 0; transform: translateY(12px); }
  @media (prefers-reduced-motion: reduce) {
    .hero-fade { opacity: 1; transform: none; }
  }

  /* ============================================================
     section pattern — used by Tap Wall and Cocktails
     Two-column on desktop; stacked image-then-copy on mobile.
     ============================================================ */
  .bar-section {
    /* Transparent so the global body::before Pin Tilt watermark shows
       through in the section gutters. Hero is now transparent too (no
       image), so the watermark is continuous from page top to footer. */
    background: transparent;
    padding: 56px 22px;
  }
  @media (min-width: 1025px) {
    .bar-section { padding: 96px 64px; }
  }

  .bar-section-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    max-width: 1280px;
    margin: 0 auto;
    align-items: center;
  }
  @media (min-width: 1025px) {
    .bar-section-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
      gap: 64px;
    }
    /* Reverse layout for the second section (image right, copy left)
       — alternation gives editorial rhythm. */
    .bar-section--reverse .bar-section-grid > .bar-section-frame {
      order: 2;
    }
  }

  .bar-section-frame {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-surface);
    /* Mobile: 4:5 portrait crop, fits a phone screen well.
       Desktop: 3:4 portrait, taller frame matches editorial weight. */
    aspect-ratio: 4 / 5;
  }
  @media (min-width: 1025px) {
    .bar-section-frame { aspect-ratio: 3 / 4; max-height: 640px; }
  }

  .bar-section-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .bar-section-copy {
    color: var(--warm-white);
    max-width: 36em;
  }

  .bar-section-title {
    color: var(--warm-white);
    font-size: clamp(28px, 7.5vw, 42px);
    line-height: 0.98;
    letter-spacing: -0.005em;
    margin-top: 10px;
  }
  @media (min-width: 1025px) {
    .bar-section-title { font-size: clamp(40px, 4.2vw, 56px); }
  }

  .bar-section-aside {
    margin-top: 6px;
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--warm-dim);
  }
  @media (min-width: 1025px) {
    .bar-section-aside { font-size: 17px; }
  }

  .bar-section-body {
    margin-top: 18px;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    color: var(--warm-mid);
  }
  @media (min-width: 1025px) {
    .bar-section-body { font-size: 17.5px; line-height: 1.65; }
  }

  .bar-section-list {
    margin-top: 22px;
    padding-left: 0;
    list-style: none;
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--warm-white);
  }
  .bar-section-list li {
    padding: 8px 0 8px 22px;
    border-bottom: 1px solid rgba(244, 239, 227, 0.08);
    position: relative;
  }
  .bar-section-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--glow);
    opacity: 0.85;
  }

  .bar-section-callout {
    margin-top: 22px;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--warm-white);
    opacity: 0.9;
  }

  .bar-cocktail-list {
    margin-top: 12px;
    padding-left: 0;
    list-style: none;
  }
  .bar-cocktail-list li {
    padding: 12px 0;
    border-bottom: 1px solid rgba(244, 239, 227, 0.08);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .cocktail-name {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: 0.005em;
    color: var(--warm-white);
  }
  .cocktail-desc {
    font-family: var(--font-body);
    font-size: 14.5px;
    color: var(--warm-dim);
  }
  @media (min-width: 1025px) {
    .cocktail-name { font-size: 22px; }
    .cocktail-desc { font-size: 16px; }
  }

  .bar-section-copy .btn {
    margin-top: 28px;
  }

  /* The closing CTA band (.bar-cta) was removed 2026-05-04 — the global
     sticky CTA bar already carries Reserve / Plan, so a duplicate at the
     page bottom was visual debt. SnapFooter handles the "find us" beat. */

  /* ============================================================
     TAP LIST — list-led layout for the 28-tap wall. Different rhythm
     than the cocktail menu (photo grid): tap number anchors each row,
     name dominates, brewery + location + style as metadata. 1 col on
     mobile, 2 cols on desktop to fill horizontal space.
     ============================================================ */
  .tap-list {
    background: transparent;
    padding: 56px 22px 72px;
  }
  @media (min-width: 1025px) {
    .tap-list { padding: 96px 64px 120px; }
  }

  .tap-list-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .tap-list-header {
    margin-bottom: 36px;
    color: var(--warm-white);
    max-width: 36em;
  }
  @media (min-width: 1025px) {
    .tap-list-header { margin-bottom: 56px; }
  }

  .tap-list-title {
    color: var(--warm-white);
    font-size: clamp(28px, 7.5vw, 42px);
    line-height: 0.98;
    letter-spacing: -0.005em;
    margin-top: 10px;
  }
  @media (min-width: 1025px) {
    .tap-list-title { font-size: clamp(40px, 4.2vw, 56px); }
  }

  .tap-section + .tap-section {
    margin-top: 40px;
  }
  @media (min-width: 1025px) {
    .tap-section + .tap-section { margin-top: 56px; }
  }

  .tap-section-name {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(20px, 5vw, 26px);
    text-transform: uppercase;
    letter-spacing: 0.01em;
    color: var(--warm-white);
    margin: 0 0 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(244, 239, 227, 0.14);
  }
  @media (min-width: 1025px) {
    .tap-section-name {
      font-size: 28px;
      margin-bottom: 20px;
      padding-bottom: 14px;
    }
  }

  /* The "· N" count next to each section name dims so the section title
     reads as the dominant element. */
  .tap-section-count {
    color: var(--warm-dim);
    font-weight: 700;
  }

  .tap-rows {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
  }
  @media (min-width: 1025px) {
    .tap-rows {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 48px;
    }
  }

  .tap-row {
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 14px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(244, 239, 227, 0.06);
    align-items: baseline;
  }
  @media (min-width: 1025px) {
    .tap-row {
      grid-template-columns: 44px 1fr;
      padding: 14px 0;
      gap: 16px;
    }
  }

  .tap-number {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 22px;
    color: var(--glow);
    line-height: 1;
    letter-spacing: -0.01em;
  }
  @media (min-width: 1025px) {
    .tap-number { font-size: 26px; }
  }

  .tap-content {
    min-width: 0;
  }

  .tap-line-1 {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 10px;
  }

  .tap-name {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    color: var(--warm-white);
    line-height: 1.2;
  }
  @media (min-width: 1025px) {
    .tap-name { font-size: 17px; }
  }

  .tap-abv {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--warm-mid);
    white-space: nowrap;
    flex-shrink: 0;
  }
  @media (min-width: 1025px) {
    .tap-abv { font-size: 12px; }
  }

  .tap-line-2 {
    margin-top: 4px;
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.4;
    color: var(--warm-dim);
  }
  @media (min-width: 1025px) {
    .tap-line-2 { font-size: 13px; }
  }

  /* ============================================================
     COCKTAIL MENU — full GoTab-driven list. Compact card grid grouped
     by category. Photos are 1:1 (sourced from GoTab img CDN). Mobile-
     first 2-col grid; desktop scales to 4 cols. Ingredients clamped to
     2 lines so card heights stay regular.
     ============================================================ */
  .cocktail-menu {
    background: transparent;
    padding: 56px 22px 72px;
  }
  @media (min-width: 1025px) {
    .cocktail-menu { padding: 96px 64px 120px; }
  }

  .cocktail-menu-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .cocktail-menu-header {
    margin-bottom: 40px;
    color: var(--warm-white);
    max-width: 36em;
  }
  @media (min-width: 1025px) {
    .cocktail-menu-header { margin-bottom: 56px; }
  }

  .cocktail-menu-title {
    color: var(--warm-white);
    font-size: clamp(28px, 7.5vw, 42px);
    line-height: 0.98;
    letter-spacing: -0.005em;
    margin-top: 10px;
  }
  @media (min-width: 1025px) {
    .cocktail-menu-title { font-size: clamp(40px, 4.2vw, 56px); }
  }

  .cocktail-category + .cocktail-category {
    margin-top: 56px;
  }
  @media (min-width: 1025px) {
    .cocktail-category + .cocktail-category { margin-top: 88px; }
  }

  .cocktail-category-name {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(20px, 5vw, 26px);
    text-transform: uppercase;
    letter-spacing: 0.01em;
