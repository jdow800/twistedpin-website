---
/**
 * /why-us/lockport-il/ — Service-area page (Lockport, IL).
 *
 * Tail page in the service-area set. Lockport doesn't appear in the
 * paid-market priority table in seo.md (Naperville/Bolingbrook/
 * Shorewood/Romeoville/Oswego/Plainfield), meaning measured search
 * demand from the city is below Plainfield's 4.9%. Built anyway
 * because (1) Lockport is geographically close (~8 miles east) with
 * a real direct connector via Renwick Rd, and (2) low-impression
 * pages cost nothing to host once the .svc-* skeleton is shared.
 *
 * Distance + route confirmed by ops 2026-05-08:
 *   - ~8 miles, Renwick Rd
 *   - No drive-time claim; mileage carries
 *
 * Lockport is east of Plainfield, so the directional copy goes
 * "west" (from Lockport's perspective heading toward us).
 */
import Base from "../../layouts/Base.astro";
import SnapFooter from "../../components/snap/SnapFooter.astro";
import BreadcrumbSchema from "../../components/BreadcrumbSchema.astro";
import {
  BUSINESS_URL,
  BUSINESS_ENTITY_ID,
  PLACE_ID,
  STREET,
  LOCALITY,
} from "../../lib/schema";

const ROLLER_URL = "https://ecom.roller.app/twistedpin/openbowl/en-us/home";
import { PLAN_EVENT_URL } from "../../lib/links";
const MAPS_DIR_HREF = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(
  `${STREET}, ${LOCALITY}`,
)}&destination_place_id=${PLACE_ID}`;

const PAGE_URL = `${BUSINESS_URL}/why-us/lockport-il/`;
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `${BUSINESS_URL}/#service-lockport`,
  name: "Twisted Pin — Bowling, Bar & Event Venue Near Lockport, IL",
  url: PAGE_URL,
  description:
    "Twisted Pin is eight miles west of Lockport down Renwick Rd — a craft cocktail program, a 28-tap self-serve beer & wine wall, 17 traditional lanes, and a 6-lane VIP suite for groups up to 80. Plainfield, IL.",
  provider: { "@id": BUSINESS_ENTITY_ID },
  areaServed: {
    "@type": "City",
    name: "Lockport",
    sameAs: "https://en.wikipedia.org/wiki/Lockport,_Illinois",
    containedInPlace: { "@type": "AdministrativeArea", name: "Illinois" },
  },
};
---
<Base
  title="Bowling Near Lockport, IL | Twisted Pin"
  description="Eight miles west of Lockport down Renwick Rd: cocktails, a 28-tap self-serve wall, and the only 6-lane VIP suite in the area. Reserve at Twisted Pin."
>

  <section class="svc-hero" data-hero aria-labelledby="svc-hero-h1">
    <div class="svc-hero-copy">
      <p class="t-eyebrow hero-fade" data-delay-ms="0">Lockport</p>
      <h1 class="t-display svc-hero-headline hero-fade" id="svc-hero-h1" data-delay-ms="120">
        Eight&nbsp;miles west on&nbsp;Renwick Rd.
      </h1>
      <p class="svc-hero-sub hero-fade" data-delay-ms="320">
        Twisted Pin sits eight miles west of Lockport down Renwick Rd
        in Plainfield, IL — a craft cocktail program, a 28-tap
        self-serve wall, and the only 6-lane VIP suite in the area.
      </p>
    </div>
  </section>

  {/* Drive ---------------------------------------------------- */}
  <section class="svc-section" aria-labelledby="svc-drive-h2">
    <div class="svc-section-grid">
      <div class="svc-section-frame">
        <picture>
          <source type="image/webp" srcset="/snap/events-bg-540.webp 540w, /snap/events-bg-900.webp 900w" sizes="(min-width: 1025px) 480px, 90vw" />
          <img class="svc-section-img"
            src="/snap/events-bg-540.jpg"
            srcset="/snap/events-bg-540.jpg 540w, /snap/events-bg-900.jpg 900w"
            sizes="(min-width: 1025px) 480px, 90vw"
            alt="A group enjoying a night out at Twisted Pin in Plainfield, IL"
            width="540" height="960" loading="lazy" decoding="async" />
        </picture>
      </div>
      <div class="svc-section-copy">
        <p class="t-eyebrow">Drive</p>
        <h2 class="t-display svc-section-title" id="svc-drive-h2">
          Renwick Rd, straight through.
        </h2>
        <p class="svc-section-aside">(no expressway, no toll)</p>

        <p class="svc-section-body">
          Renwick Rd runs east-west between Lockport and Plainfield.
          Eight miles, no toll, no I-355 detour. Free parking out
          front when you get here.
        </p>

        <p class="svc-section-body">
          For Lockport residents who've watched the same handful of
          local spots cycle through, eight miles is a short reset.
        </p>

        <ul class="svc-section-list">
          <li>~8 miles west of Lockport</li>
          <li>Renwick Rd — direct east-west connector</li>
          <li>No expressway, no toll</li>
          <li>Free parking out front</li>
        </ul>

        <a class="btn btn-outline" href={MAPS_DIR_HREF} target="_blank" rel="noopener">
          Get directions
        </a>
      </div>
    </div>
  </section>

  {/* Group Events --------------------------------------------- */}
  <section class="svc-section svc-section--reverse" aria-labelledby="svc-vip-h2">
    <div class="svc-section-grid">
      <div class="svc-section-frame">
        <picture>
          <source type="image/webp" srcset="/snap/vip-energy-540.webp 540w, /snap/vip-energy-900.webp 900w" sizes="(min-width: 1025px) 480px, 90vw" />
          <img class="svc-section-img"
            src="/snap/vip-energy-540.jpg"
            srcset="/snap/vip-energy-540.jpg 540w, /snap/vip-energy-900.jpg 900w"
            sizes="(min-width: 1025px) 480px, 90vw"
            alt="The 6-lane VIP suite at Twisted Pin — set apart from the traditional lanes"
            width="540" height="960" loading="lazy" decoding="async" />
        </picture>
      </div>
      <div class="svc-section-copy">
        <p class="t-eyebrow">Group Events</p>
        <h2 class="t-display svc-section-title" id="svc-vip-h2">
          Six lanes set apart. Up to 80 people.
        </h2>
        <p class="svc-section-aside">(adult birthdays, gender reveals, graduation parties)</p>

        <p class="svc-section-body">
          Adult birthdays, gender reveals, holiday parties, staff
          appreciation, graduation. The VIP suite holds up to 80 people
          across six lanes set apart from the traditional lanes by a
          wall, with AV hookups for slideshows and walk-in music, and
          in-house catering from the kitchen.
        </p>

        <p class="svc-section-body">
          Bar billing on a tab or drink tickets — your call. Eight
          miles up Renwick.
        </p>

        <ul class="svc-section-list">
          <li>6 lanes, set apart from the traditional lanes by a wall</li>
          <li>Capacity to 80 — full takeover</li>
          <li>AV hookups + in-house catering</li>
          <li>Tab or drink tickets — your call</li>
          <li>Yours for the night when you book the suite</li>
        </ul>

        <a class="btn btn-outline" href={PLAN_EVENT_URL} target="_blank" rel="noopener">
          Plan an event
        </a>
      </div>
    </div>
  </section>

  {/* Bar ------------------------------------------------------- */}
  <section class="svc-section" aria-labelledby="svc-bar-h2">
    <div class="svc-section-grid">
      <div class="svc-section-frame">
        <picture>
          <source type="image/webp" srcset="/snap/bar-cocktails-540.webp 540w, /snap/bar-cocktails-900.webp 900w" sizes="(min-width: 1025px) 480px, 90vw" />
          <img class="svc-section-img"
            src="/snap/bar-cocktails-540.jpg"
            srcset="/snap/bar-cocktails-540.jpg 540w, /snap/bar-cocktails-900.jpg 900w"
            sizes="(min-width: 1025px) 480px, 90vw"
            alt="A copper cocktail shaker mid-pour at Twisted Pin's bar"
            width="540" height="960" loading="lazy" decoding="async" />
        </picture>
      </div>
      <div class="svc-section-copy">
        <p class="t-eyebrow">The Bar</p>
        <h2 class="t-display svc-section-title" id="svc-bar-h2">
          America's Top Mixologist. Eight miles west.
        </h2>
        <p class="svc-section-aside">(plus the only 28-tap self-serve wall in the area)</p>

        <p class="svc-section-body">
          Twenty-eight self-serve taps and a craft cocktail program
          curated by the consulting mixologist Food Network calls
          <em>America's Top Mixologist</em>. Cocktails served in 40+
          countries.
        </p>

        <p class="svc-section-body">
          The kind of bar program that doesn't usually live next to
          bowling lanes. We'd argue it should.
        </p>

        <a class="btn btn-outline" href="/menu/cocktails/">View the cocktail menu</a>
      </div>
    </div>
  </section>

  {/* Closing CTA band ----------------------------------------- */}
  <section class="svc-cta" aria-labelledby="svc-cta-h2">
    <div class="svc-cta-inner">
      <p class="t-eyebrow">Worth the Drive</p>
      <h2 class="t-display svc-cta-title" id="svc-cta-h2">
        Eight miles. We'll save you a lane.
      </h2>
      <p class="svc-cta-body">
        Renwick Rd west. Reserve a lane for tonight or plan a group
        event for next quarter.
      </p>
      <div class="svc-cta-row">
        <a class="btn btn-solid" href={ROLLER_URL} target="_blank" rel="noopener">Reserve a lane</a>
        <a class="btn btn-outline" href={PLAN_EVENT_URL} target="_blank" rel="noopener">Plan an event</a>
      </div>
      <p class="svc-cta-nap">
        Twisted Pin · 15610 Joliet Rd, Plainfield, IL 60544 · 8 miles west of Lockport
      </p>
    </div>
  </section>

  <SnapFooter />

  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <BreadcrumbSchema crumbs={[
    { name: "Home", path: "/" },
    { name: "Lockport", path: "/why-us/lockport-il/" },
  ]} />
</Base>
