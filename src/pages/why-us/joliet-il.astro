---
/**
 * /why-us/joliet-il/ — Service-area page (Joliet, IL).
 *
 * Per Context/seo.md: Joliet = corporate-only angle. "Lead with VIP
 * suite for the I-80 logistics corridor." Distance + route confirmed
 * by ops 2026-05-08:
 *   - ~11 miles, Route 30 (verified 2026-05-17 via Google Maps research)
 *   - No drive-time claim; mileage carries
 *
 * Structural difference from the other svc-area pages: same skeleton,
 * but the Group Events copy carries more weight (corporate is the
 * lever) and the Drive section calls out the I-80 corridor framing
 * from the brief. Bar section stays short — secondary on this page.
 *
 * Note on the address: 15610 **Joliet Rd**, Plainfield, IL. Street
 * is named for the city of Joliet but the venue is in Plainfield.
 * The page acknowledges the awkward overlap explicitly so the reader
 * is never confused about which town we're in.
 */
import Base from "../../layouts/Base.astro";
import SnapFooter from "../../components/snap/SnapFooter.astro";
import BreadcrumbSchema from "../../components/BreadcrumbSchema.astro";
import {
  BUSINESS_URL,
  BUSINESS_ENTITY_ID,
  PLACE_ID,
  STREET,
  LOCALITY,
} from "../../lib/schema";

const ROLLER_URL = "https://ecom.roller.app/twistedpin/openbowl/en-us/home";
import { PLAN_EVENT_URL } from "../../lib/links";
const MAPS_DIR_HREF = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(
  `${STREET}, ${LOCALITY}`,
)}&destination_place_id=${PLACE_ID}`;

const PAGE_URL = `${BUSINESS_URL}/why-us/joliet-il/`;
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `${BUSINESS_URL}/#service-joliet`,
  name: "Twisted Pin — Corporate Event Venue & Bar Near Joliet, IL",
  url: PAGE_URL,
  description:
    "Twisted Pin sits eleven miles from downtown Joliet on Route 30 in Plainfield, IL — a 6-lane VIP suite for groups up to 80, a craft cocktail program curated by America's Top Mixologist, and a 28-tap self-serve wall. Built for the I-80 corridor.",
  provider: { "@id": BUSINESS_ENTITY_ID },
  areaServed: {
    "@type": "City",
    name: "Joliet",
    sameAs: "https://en.wikipedia.org/wiki/Joliet,_Illinois",
    containedInPlace: { "@type": "AdministrativeArea", name: "Illinois" },
  },
};
---
<Base
  title="Corporate Event Venue Near Joliet, IL | Twisted Pin"
  description="Eleven miles up Route 30 from Joliet: a 6-lane VIP suite for groups up to 80, a craft cocktail program curated by America's Top Mixologist, and a 28-tap self-serve wall. Plan an event."
>

  <section class="svc-hero" data-hero aria-labelledby="svc-hero-h1">
    <div class="svc-hero-copy">
      <p class="t-eyebrow hero-fade" data-delay-ms="0">Joliet</p>
      <h1 class="t-display svc-hero-headline hero-fade" id="svc-hero-h1" data-delay-ms="120">
        Eleven&nbsp;miles up&nbsp;Route 30. Built&nbsp;for the&nbsp;I-80 corridor.
      </h1>
      <p class="svc-hero-sub hero-fade" data-delay-ms="320">
        Twisted Pin sits eleven miles from downtown Joliet on Route 30
        in Plainfield, IL — a 6-lane VIP suite for groups up to 80, a
        craft cocktail program, and a 28-tap self-serve wall.
      </p>
    </div>
  </section>

  {/* Drive ---------------------------------------------------- */}
  <section class="svc-section" aria-labelledby="svc-drive-h2">
    <div class="svc-section-grid">
      <div class="svc-section-frame">
        <picture>
          <source type="image/webp" srcset="/snap/events-bg-540.webp 540w, /snap/events-bg-900.webp 900w" sizes="(min-width: 1025px) 480px, 90vw" />
          <img class="svc-section-img"
            src="/snap/events-bg-540.jpg"
            srcset="/snap/events-bg-540.jpg 540w, /snap/events-bg-900.jpg 900w"
            sizes="(min-width: 1025px) 480px, 90vw"
            alt="A group enjoying a night out at Twisted Pin in Plainfield, IL"
            width="540" height="960" loading="lazy" decoding="async" />
        </picture>
      </div>
      <div class="svc-section-copy">
        <p class="t-eyebrow">Drive</p>
        <h2 class="t-display svc-drive-h2 svc-section-title" id="svc-drive-h2">
          Eleven miles. Route 30.
        </h2>
        <p class="svc-section-aside">(yes, the street is named "Joliet Rd")</p>

        <p class="svc-section-body">
          Route 30 from Joliet, eleven miles. We're in Plainfield, on a
          street called Joliet Rd. Close enough to the city of Joliet
          that the road's named for it.
        </p>

        <p class="svc-section-body">
          For offices and crews along the I-80 corridor — the
          distribution centers, the rail yards, the office parks —
          we're the closest premium bowling and <a href="/events/">event venue</a> in
          either direction.
        </p>

        <ul class="svc-section-list">
          <li>~11 miles from downtown Joliet</li>
          <li>Route 30 west</li>
          <li>Free parking out front</li>
        </ul>

        <a class="btn btn-outline" href={MAPS_DIR_HREF} target="_blank" rel="noopener">
          Get directions
        </a>
      </div>
    </div>
  </section>

  {/* Group Events — heaviest weight on this page -------------- */}
  <section class="svc-section svc-section--reverse" aria-labelledby="svc-vip-h2">
    <div class="svc-section-grid">
      <div class="svc-section-frame">
        <picture>
          <source type="image/webp" srcset="/snap/vip-energy-540.webp 540w, /snap/vip-energy-900.webp 900w" sizes="(min-width: 1025px) 480px, 90vw" />
          <img class="svc-section-img"
            src="/snap/vip-energy-540.jpg"
            srcset="/snap/vip-energy-540.jpg 540w, /snap/vip-energy-900.jpg 900w"
            sizes="(min-width: 1025px) 480px, 90vw"
            alt="The 6-lane VIP suite at Twisted Pin — set apart from the traditional lanes"
            width="540" height="960" loading="lazy" decoding="async" />
        </picture>
      </div>
      <div class="svc-section-copy">
        <p class="t-eyebrow">Group Events</p>
        <h2 class="t-display svc-section-title" id="svc-vip-h2">
          Take over the 6-lane VIP suite. Built for company outings.
        </h2>
        <p class="svc-section-aside">(corporate offsites, holiday parties, staff appreciation)</p>

        <p class="svc-section-body">
          Companies along the I-80 corridor — distribution, logistics,
          manufacturing, professional services — book <a href="/vip-suite/">the VIP suite</a>
          for <a href="/corporate-events/">corporate offsites</a>, <a href="/holiday-parties/">holiday parties</a>, and staff
          appreciation nights. Six lanes set apart from the traditional
          lanes by a wall. Capacity to 80. AV hookups for slideshows
          and walk-in music. <a href="/eat/">In-house catering from the kitchen</a>. Bar
          billing on a tab or drink tickets — your call.
        </p>

        <p class="svc-section-body">
          The kind of event venue that doesn't really exist between
          Joliet and Naperville. Now it does — eleven miles up Route 30.
        </p>

        <ul class="svc-section-list">
          <li>6-lane VIP suite — only one in the immediate area</li>
          <li>Capacity to 80 — built for company outings</li>
          <li>AV hookups for slideshows + walk-in music</li>
          <li>In-house catering from the kitchen</li>
          <li>Run a tab or drink tickets — not "open bar"</li>
          <li>Closest premium event venue between Joliet and Naperville</li>
        </ul>

        <a class="btn btn-outline" href={PLAN_EVENT_URL} target="_blank" rel="noopener">
          Plan an event
        </a>
      </div>
    </div>
  </section>

  {/* Bar — secondary on this page ---------------------------- */}
  <section class="svc-section" aria-labelledby="svc-bar-h2">
    <div class="svc-section-grid">
      <div class="svc-section-frame">
        <picture>
          <source type="image/webp" srcset="/snap/bar-cocktails-540.webp 540w, /snap/bar-cocktails-900.webp 900w" sizes="(min-width: 1025px) 480px, 90vw" />
          <img class="svc-section-img"
            src="/snap/bar-cocktails-540.jpg"
            srcset="/snap/bar-cocktails-540.jpg 540w, /snap/bar-cocktails-900.jpg 900w"
            sizes="(min-width: 1025px) 480px, 90vw"
            alt="A copper cocktail shaker mid-pour at Twisted Pin's bar"
            width="540" height="960" loading="lazy" decoding="async" />
        </picture>
      </div>
      <div class="svc-section-copy">
        <p class="t-eyebrow">The Bar</p>
        <h2 class="t-display svc-section-title" id="svc-bar-h2">
          Cocktails you can take a client to.
        </h2>
        <p class="svc-section-aside">(plus the only 28-tap self-serve wall in the area)</p>

        <p class="svc-section-body">
          Joliet has its corner spots and its casino lounges. Neither is
          where you take a client. <a href="/bar/">The cocktail program at Twisted Pin
          was curated by the consulting mixologist Food Network calls
          <em>America's Top Mixologist</em></a>; <a href="/menu/taps/">the 28-tap self-serve wall</a>
          is the only one in the area.
        </p>

        <p class="svc-section-body">
          Eleven miles up Route 30 — same direction the I-80 corridor
          already drives for the offices and distribution centers.
        </p>

        <a class="btn btn-outline" href="/menu/cocktails/">View the cocktail menu</a>
      </div>
    </div>
  </section>

  {/* Closing CTA band ----------------------------------------- */}
  <section class="svc-cta" aria-labelledby="svc-cta-h2">
    <div class="svc-cta-inner">
      <p class="t-eyebrow">Worth the Drive</p>
      <h2 class="t-display svc-cta-title" id="svc-cta-h2">
        Up Route 30. We're holding a lane.
      </h2>
      <p class="svc-cta-body">
        Reserve a lane for tonight or plan a corporate event for next
        quarter. Either is worth the eleven miles.
      </p>
      <div class="svc-cta-row">
        <a class="btn btn-solid" href={ROLLER_URL} target="_blank" rel="noopener">Reserve a lane</a>
        <a class="btn btn-outline" href={PLAN_EVENT_URL} target="_blank" rel="noopener">Plan an event</a>
      </div>
      <p class="svc-cta-more">
        More: <a href="/vip-suite/">the VIP suite</a> · <a href="/menu/taps/">the 28-tap self-serve wall</a> · <a href="/events/">group events</a> · <a href="/fundraisers/">fundraisers</a>
      </p>
      <p class="svc-cta-nap">
        Twisted Pin · 15610 Joliet Rd, Plainfield, IL 60544 · 11 miles from downtown Joliet
      </p>
    </div>
  </section>

  <SnapFooter />

  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <BreadcrumbSchema crumbs={[
    { name: "Home", path: "/" },
    { name: "Joliet", path: "/why-us/joliet-il/" },
  ]} />
</Base>
