---
/**
 * /why-us/oswego-il/ — Service-area page (Oswego, IL).
 *
 * Per Context/seo.md: Oswego = under-penetrated, 7% of paid clicks.
 * Distance per ops 2026-05-08:
 *   - ~9 miles southeast (verified 2026-05-17 via Google Maps research)
 *   - User explicitly said leave route + drive time OFF the page
 *     ("that one is pushing 30 mins"). Mileage carries; we don't
 *     pretend it's a quick run.
 *
 * Different angle than the I-55-corridor pages: Oswego sits west of
 * Plainfield with no direct expressway connection, so the conversion
 * angle is "worth the drive — nothing closer to home looks like
 * this." Lean on differentiator, not proximity.
 */
import Base from "../../layouts/Base.astro";
import SnapFooter from "../../components/snap/SnapFooter.astro";
import BreadcrumbSchema from "../../components/BreadcrumbSchema.astro";
import {
  BUSINESS_URL,
  BUSINESS_ENTITY_ID,
  PLACE_ID,
  STREET,
  LOCALITY,
} from "../../lib/schema";

const ROLLER_URL = "https://ecom.roller.app/twistedpin/openbowl/en-us/home";
import { PLAN_EVENT_URL } from "../../lib/links";
const MAPS_DIR_HREF = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(
  `${STREET}, ${LOCALITY}`,
)}&destination_place_id=${PLACE_ID}`;

const PAGE_URL = `${BUSINESS_URL}/why-us/oswego-il/`;
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `${BUSINESS_URL}/#service-oswego`,
  name: "Twisted Pin — Bowling, Bar & Event Venue Near Oswego, IL",
  url: PAGE_URL,
  description:
    "Twisted Pin is nine miles southeast of Oswego — closer than you'd guess. A craft cocktail program curated by America's Top Mixologist, a 28-tap self-serve beer & wine wall, 17 traditional lanes, and a 6-lane VIP suite for groups up to 80. Plainfield, IL.",
  provider: { "@id": BUSINESS_ENTITY_ID },
  areaServed: {
    "@type": "City",
    name: "Oswego",
    sameAs: "https://en.wikipedia.org/wiki/Oswego,_Illinois",
    containedInPlace: { "@type": "AdministrativeArea", name: "Illinois" },
  },
};
---
<Base
  title="Bowling Near Oswego, IL | Twisted Pin"
  description="Nine miles southeast of Oswego — closer than you'd guess. Cocktails curated by America's Top Mixologist, a 28-tap self-serve wall, and the only 6-lane VIP suite in the area. Reserve at Twisted Pin."
>

  <section class="svc-hero" data-hero aria-labelledby="svc-hero-h1">
    <div class="svc-hero-copy">
      <p class="t-eyebrow hero-fade" data-delay-ms="0">Oswego</p>
      <h1 class="t-display svc-hero-headline hero-fade" id="svc-hero-h1" data-delay-ms="120">
        Nine&nbsp;miles southeast. Closer&nbsp;than you'd&nbsp;guess.
      </h1>
      <p class="svc-hero-sub hero-fade" data-delay-ms="320">
        Twisted Pin sits nine miles southeast of Oswego in Plainfield,
        IL — a craft cocktail program, a 28-tap self-serve wall, and
        the only 6-lane VIP suite in the area. Nothing closer to home
        looks like this.
      </p>
    </div>
  </section>

  {/* Drive — distance only, no time, no route per ops --------- */}
  <section class="svc-section" aria-labelledby="svc-drive-h2">
    <div class="svc-section-grid">
      <div class="svc-section-frame">
        <picture>
          <source type="image/webp" srcset="/snap/events-bg-540.webp 540w, /snap/events-bg-900.webp 900w" sizes="(min-width: 1025px) 480px, 90vw" />
          <img class="svc-section-img"
            src="/snap/events-bg-540.jpg"
            srcset="/snap/events-bg-540.jpg 540w, /snap/events-bg-900.jpg 900w"
            sizes="(min-width: 1025px) 480px, 90vw"
            alt="A group enjoying a night out at Twisted Pin in Plainfield, IL"
            width="540" height="960" loading="lazy" decoding="async" />
        </picture>
      </div>
      <div class="svc-section-copy">
        <p class="t-eyebrow">Drive</p>
        <h2 class="t-display svc-section-title" id="svc-drive-h2">
          Nine miles southeast. Closer than you'd guess.
        </h2>
        <p class="svc-section-aside">(nothing this side of Naperville looks like it)</p>

        <p class="svc-section-body">
          Nine miles southeast on Plainfield Road. About sixteen minutes
          off-peak. What you get for it: <a href="/bar/">a craft cocktail program
          curated by the consulting mixologist Food Network calls
          <em>America's Top Mixologist</em></a>, <a href="/menu/taps/">the only 28-tap self-serve
          beer and wine wall in the area</a>, and a 6-lane VIP suite that
          doesn't exist anywhere closer to Oswego than Naperville.
        </p>

        <p class="svc-section-body">
          Closer than the drive to Naperville, sharper than what's
          between.
        </p>

        <ul class="svc-section-list">
          <li>~9 miles southeast of Oswego</li>
          <li>Free parking out front</li>
          <li>Closer than Chicago, sharper than what's between</li>
        </ul>

        <a class="btn btn-outline" href={MAPS_DIR_HREF} target="_blank" rel="noopener">
          Get directions
        </a>
      </div>
    </div>
  </section>

  {/* Group Events --------------------------------------------- */}
  <section class="svc-section svc-section--reverse" aria-labelledby="svc-vip-h2">
    <div class="svc-section-grid">
      <div class="svc-section-frame">
        <picture>
          <source type="image/webp" srcset="/snap/vip-energy-540.webp 540w, /snap/vip-energy-900.webp 900w" sizes="(min-width: 1025px) 480px, 90vw" />
          <img class="svc-section-img"
            src="/snap/vip-energy-540.jpg"
            srcset="/snap/vip-energy-540.jpg 540w, /snap/vip-energy-900.jpg 900w"
            sizes="(min-width: 1025px) 480px, 90vw"
            alt="The 6-lane VIP suite at Twisted Pin — set apart from the traditional lanes"
            width="540" height="960" loading="lazy" decoding="async" />
        </picture>
      </div>
      <div class="svc-section-copy">
        <p class="t-eyebrow">Group Events</p>
        <h2 class="t-display svc-section-title" id="svc-vip-h2">
          For the night that has to land.
        </h2>
        <p class="svc-section-aside">(milestone birthdays, gender reveals, holiday parties)</p>

        <p class="svc-section-body">
          Adult birthdays, gender reveals, <a href="/holiday-parties/">holiday parties</a>, milestone
          celebrations — they land in <a href="/vip-suite/">the VIP suite</a>. Six lanes set
          apart from the traditional lanes by a wall, capacity to 80,
          AV hookups, <a href="/eat/">in-house catering</a>. Yours for the night when you
          book the suite.
        </p>

        <p class="svc-section-body">
          For a once-a-year night that has to land, nine miles southeast
          is a short reset.
        </p>

        <ul class="svc-section-list">
          <li>6-lane VIP suite — nothing closer to Oswego has one</li>
          <li>Up to 80 people, full takeover</li>
          <li>AV hookups + in-house catering</li>
          <li>Bar tab or drink tickets, your call</li>
          <li>Yours for the night — set apart by a wall</li>
        </ul>

        <a class="btn btn-outline" href={PLAN_EVENT_URL} target="_blank" rel="noopener">
          Plan an event
        </a>
      </div>
    </div>
  </section>

  {/* Bar ------------------------------------------------------- */}
  <section class="svc-section" aria-labelledby="svc-bar-h2">
    <div class="svc-section-grid">
      <div class="svc-section-frame">
        <picture>
          <source type="image/webp" srcset="/snap/bar-cocktails-540.webp 540w, /snap/bar-cocktails-900.webp 900w" sizes="(min-width: 1025px) 480px, 90vw" />
          <img class="svc-section-img"
            src="/snap/bar-cocktails-540.jpg"
            srcset="/snap/bar-cocktails-540.jpg 540w, /snap/bar-cocktails-900.jpg 900w"
            sizes="(min-width: 1025px) 480px, 90vw"
            alt="A copper cocktail shaker mid-pour at Twisted Pin's bar"
            width="540" height="960" loading="lazy" decoding="async" />
        </picture>
      </div>
      <div class="svc-section-copy">
        <p class="t-eyebrow">The Bar</p>
        <h2 class="t-display svc-section-title" id="svc-bar-h2">
          Worth the drive for the bar program alone.
        </h2>
        <p class="svc-section-aside">(plus the only 28-tap self-serve wall in the area)</p>

        <p class="svc-section-body">
          <a href="/bar/">The bar program at Twisted Pin was curated by the consulting
          mixologist Food Network calls <em>America's Top Mixologist</em></a>.
          <a href="/menu/taps/">Twenty-eight self-serve taps</a> where you grab a card, pour
          your own, and pay by the ounce.
        </p>

        <p class="svc-section-body">
          You'd drive to River North or downtown Naperville for this
          kind of program. Or you head southeast. Same drink, less
          traffic.
        </p>

        <a class="btn btn-outline" href="/menu/cocktails/">View the cocktail menu</a>
      </div>
    </div>
  </section>

  {/* Closing CTA band ----------------------------------------- */}
  <section class="svc-cta" aria-labelledby="svc-cta-h2">
    <div class="svc-cta-inner">
      <p class="t-eyebrow">Worth the Drive</p>
      <h2 class="t-display svc-cta-title" id="svc-cta-h2">
        Closer than Naperville. Sharper than what's between.
      </h2>
      <p class="svc-cta-body">
        Nine miles southeast. Reserve a lane for tonight or plan a
        group event for next quarter.
      </p>
      <div class="svc-cta-row">
        <a class="btn btn-solid" href={ROLLER_URL} target="_blank" rel="noopener">Reserve a lane</a>
        <a class="btn btn-outline" href={PLAN_EVENT_URL} target="_blank" rel="noopener">Plan an event</a>
      </div>
      <p class="svc-cta-more">
        More: <a href="/vip-suite/">the VIP suite</a> · <a href="/menu/taps/">the 28-tap self-serve wall</a> · <a href="/events/">group events</a> · <a href="/fundraisers/">fundraisers</a>
      </p>
      <p class="svc-cta-nap">
        Twisted Pin · 15610 Joliet Rd, Plainfield, IL 60544 · 9 miles southeast of Oswego
      </p>
    </div>
  </section>

  <SnapFooter />

  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <BreadcrumbSchema crumbs={[
    { name: "Home", path: "/" },
    { name: "Oswego", path: "/why-us/oswego-il/" },
  ]} />
</Base>
