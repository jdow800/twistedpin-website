---
/**
 * /gift-cards — gift card info page.
 *
 * Live twistedpin.com/gift-cards/ returns 404 — the page DOESN'T
 * exist on the current site. But the live FAQ confirms gift cards
 * ARE sold:
 *   - "available to purchase in-store at the front desk"
 *   - "valid on bowling and arcade related purchases in our facility"
 *   - (no online purchase option)
 *
 * So this page exists to surface that fact for users who land on
 * /gift-cards/ via search or the MORE/drawer. It explains the
 * in-store-only flow and points users to visit.
 *
 * Voice rule check: "cheap/discount/value/deals/budget-friendly"
 * hard-banned per CLAUDE.md Working Preferences. Gift cards aren't
 * discount language — they're a purchase product. Frame as "give
 * the night, not a coupon" — premium-positioning angle.
 *
 * TODOs (non-blocking):
 *   - Confirm with ops: are there standard denominations? Custom
 *     amounts? Both? Currently hand-waved to "any amount" pending
 *     verification.
 *   - "valid on bowling and arcade related purchases" — does NOT
 *     include food/drinks per the live FAQ. Surfaced clearly so
 *     gift recipients aren't surprised.
 *   - Future: online purchase via a gift card platform (Toast,
 *     Square, etc.) — would graduate this page from info-only to
 *     a transactional page.
 */
import Base from "../layouts/Base.astro";
import SnapFooter from "../components/snap/SnapFooter.astro";
import BreadcrumbSchema from "../components/BreadcrumbSchema.astro";
import { BUSINESS_URL, BUSINESS_ENTITY_ID } from "../lib/schema";
import { PLAN_EVENT_URL } from "../lib/links";

// JSON-LD: Product + Offer. Gift cards are sold in-person at the front
// desk only — availability: InStoreOnly captures that exactly. The
// $25 minPrice is a conservative placeholder until ops confirms
// denomination policy ("any amount" per current copy); update both
// minPrice here and the page body when ops gives real denominations.
// Eligible for product knowledge-graph inclusion even without a single
// fixed price (Offer's priceSpecification.minPrice satisfies validation).
const PAGE_URL = `${BUSINESS_URL}/gift-cards/`;
const GIFT_CARD_MIN_PRICE = "25.00";
const giftCardSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": `${BUSINESS_URL}/#gift-card`,
  name: "Twisted Pin Gift Card",
  description:
    "Twisted Pin gift card — available at the front desk in any amount. Good for bowling and arcade purchases at the venue in Plainfield, IL. No expiration, no maintenance fees (per Illinois gift card law).",
  brand: { "@id": BUSINESS_ENTITY_ID },
  url: PAGE_URL,
  offers: {
    "@type": "Offer",
    availability: "https://schema.org/InStoreOnly",
    priceSpecification: {
      "@type": "PriceSpecification",
      priceCurrency: "USD",
      minPrice: GIFT_CARD_MIN_PRICE,
    },
    seller: { "@id": BUSINESS_ENTITY_ID },
    areaServed: {
      "@type": "Place",
      name: "Twisted Pin, 15610 Joliet Rd, Plainfield, IL 60544",
    },
  },
};
---
<Base
  title="Gift Cards in Plainfield, IL | Twisted Pin"
  description="Pick up a Twisted Pin gift card at the front desk in any amount, good for bowling and the arcade. The gift that doesn't sit in a drawer. Plainfield, IL."
>

  <section class="t2-hero" data-hero aria-labelledby="giftcards-h1">
    <div class="t2-hero-copy">
      <p class="t-eyebrow hero-fade" data-delay-ms="0">Gift Cards</p>
      <h1 class="t-display t2-hero-headline hero-fade" id="giftcards-h1" data-delay-ms="120">
        Give the night.
      </h1>
      <p class="t2-hero-sub hero-fade" data-delay-ms="320">
        Twisted Pin gift cards — available at the front desk. Good
        for bowling and arcade.
      </p>
    </div>
  </section>

  <section class="t2-section" aria-labelledby="giftcards-h2">
    <div class="t2-section-inner">
      <h2 class="t-eyebrow" id="giftcards-h2" style="font-size:11px;">How It Works</h2>
      <p class="t2-section-body">
        Stop by the front desk during open hours and pick up a gift
        card in any amount. We don't sell them online (yet) — it's
        an in-person stop.
      </p>

      <p class="t2-section-body">
        <strong>What gift cards cover:</strong> bowling and arcade
        purchases at Twisted Pin. They don't cover food or bar tabs —
        those are settled the regular way at checkout.
      </p>

      <p class="t2-section-body">
        We're at <a href="#find-us">15610 Joliet Rd, Plainfield, IL</a>.
        Footer shows current hours.
      </p>

    </div>
  </section>

  {/* SEO body block — gifting use cases + local context. Voice rule:
      "give the night, not a coupon" framing extended through specific
      use-case scenarios. Distinct copy from /coupon (gift card vs
      credit are different products). */}
  <section class="t2-section" aria-labelledby="giftcards-info-h2">
    <div class="t2-section-inner">
      <h2 class="t-eyebrow" id="giftcards-info-h2" style="font-size:11px;">When It's The Right Gift</h2>
      <p class="t2-section-body">
        Birthdays, retirements, last-minute office white elephants, or
        the host who's seen every wine bottle &mdash; a Twisted Pin
        gift card is something they'll actually use. Lane time, shoes,
        and a few rounds in the arcade all work; the card covers
        exactly the parts of a night out that the recipient picks.
      </p>
      <p class="t2-section-body">
        Most gift cards we sell go to local buyers: Plainfield
        neighbors picking one up before a birthday party, or Will County
        regulars who treat it as a default holiday gift. The lane spread
        fits a casual couples' night, a small group, or a kids' birthday
        afternoon &mdash; pick the visit that fits the recipient, not
        the other way around.
      </p>
      <p class="t2-section-body">
        Cards stay valid as long as the venue's open; no expiration,
        no monthly maintenance fees eating into the balance (Illinois
        gift card law). See <a href="/pricing/">walk-in pricing</a> for
        what each day's bowling costs, <a href="/bowl/">more on the
        lanes here</a>, or <a href={PLAN_EVENT_URL} target="_blank" rel="noopener">plan a group event</a>
        if you'd rather book the room than gift a card.
      </p>
    </div>
  </section>

  <SnapFooter />

  <script type="application/ld+json" set:html={JSON.stringify(giftCardSchema)} />
  <BreadcrumbSchema crumbs={[
    { name: "Home", path: "/" },
    { name: "Gift Cards", path: "/gift-cards/" },
  ]} />
</Base>
