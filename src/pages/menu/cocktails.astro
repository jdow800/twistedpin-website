---
/**
 * /menu/cocktails — dedicated cocktail menu page.
 *
 * Extracted from /bar's #cocktail-menu section (2026-05-05) so the bar
 * pillar page can stay editorial-focused and short. Reference content
 * lives at its own URL where it can be linked, shared, and crawled
 * independently.
 *
 * Layout: typography-led hero (no image) + the cocktail card grid.
 * Mirrors the rhythm of all three menu pages — no editorial drift.
 *
 * Data: build-time fetch from GoTab via getCocktails(). Daily 4am cron
 * keeps it fresh.
 */
import Base from "../../layouts/Base.astro";
import SnapFooter from "../../components/snap/SnapFooter.astro";
import BreadcrumbSchema from "../../components/BreadcrumbSchema.astro";
import MenuPillNav from "../../components/MenuPillNav.astro";
import { getCocktails } from "../../lib/gotab-cocktails";
import {
  BUSINESS_URL,
  BUSINESS_ENTITY_ID,
  BRIAN_ID,
  MENU_COCKTAILS_ID,
} from "../../lib/schema";
import { cdnImage } from "../../lib/cdn-image";

const cocktailMenu = await getCocktails();

// Guard against silent thin-content deploy: if GoTab fetch failed at build
// (network blip, expired creds, API outage), `getCocktails()` returns
// EMPTY rather than throwing — page still ships with hero + SEO body but
// zero menu items. noindex the page in that state so Google doesn't index
// the empty shell; next successful build restores indexing automatically.
const isMenuEmpty = cocktailMenu.categories.length === 0;

// Pill-rail wayfinding: slugify the GoTab category name for an in-page
// anchor. Same slug is applied as the `id` on the corresponding category
// div below so the pill links target each section directly. Pill labels
// use the full GoTab name — long names (e.g. "Cocktails - Reimagined &
// Handcrafted Fav") horizontal-scroll the rail; we accept that for v1
// rather than guessing at smart truncation that might drop meaning.
function slugify(s: string): string {
  return s.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "");
}
const pills = cocktailMenu.categories.map((cat) => ({
  id: `cat-${slugify(cat.name)}`,
  name: cat.name,
}));

// JSON-LD: Menu → MenuSection → MenuItem. Stable @id so other pages
// can cross-reference (e.g. /bar's hasMenu). provider references the
// LocalBusiness via @id — entity graph closes. contributor references
// Brian's Person @id (defined on /bar) — Schema.org `contributor` is the
// correct relationship for "curated by" (consultant who helped shape the
// CreativeWork). NOT `creator` (he didn't author the menu) and NOT
// `author` (same overclaim). See project_brian_van_flandern_relationship.md
const PAGE_URL = `${BUSINESS_URL}/menu/cocktails/`;
const menuSchema = {
  "@context": "https://schema.org",
  "@type": "Menu",
  "@id": MENU_COCKTAILS_ID,
  name: "Cocktail Menu",
  url: PAGE_URL,
  inLanguage: "en-US",
  provider: { "@id": BUSINESS_ENTITY_ID },
  contributor: { "@id": BRIAN_ID },
  hasMenuSection: cocktailMenu.categories.map((cat) => ({
    "@type": "MenuSection",
    name: cat.name,
    hasMenuItem: cat.cocktails.map((c) => {
      const item: Record<string, unknown> = {
        "@type": "MenuItem",
        name: c.name,
      };
      if (c.ingredients) item.description = c.ingredients;
      if (c.imageUrlLg || c.imageUrl) item.image = c.imageUrlLg ?? c.imageUrl;
      return item;
    }),
  })),
};
---
<Base
  title="Cocktail Menu in Plainfield, IL | Twisted Pin"
  description="The cocktail program at Twisted Pin — curated by America's Top Mixologist. Original craft cocktails, reimagined classics, and seasonal pours. Plainfield, IL."
>
  {isMenuEmpty && (
    <Fragment slot="head">
      <meta name="robots" content="noindex,follow" />
    </Fragment>
  )}

  <section class="menu-hero" data-hero aria-labelledby="menu-h1">
    <p class="t-eyebrow hero-fade" data-delay-ms="0">The Bar Program</p>
    <h1 class="t-display menu-hero-headline hero-fade" id="menu-h1" data-delay-ms="120">
      Cocktails
    </h1>
    <p class="menu-hero-sub hero-fade" data-delay-ms="320">
      A craft cocktail program curated by America's Top Mixologist.
      Twenty-eight cocktails, served at Twisted Pin in Plainfield, IL.
    </p>
  </section>

  {cocktailMenu.categories.length > 0 && (
    <section class="cocktail-menu" id="cocktail-menu" aria-labelledby="cocktail-menu-h2">
      <div class="cocktail-menu-inner">
        {pills.length > 1 && (
          <MenuPillNav pills={pills} label="Cocktail menu sections" />
        )}
        {cocktailMenu.categories.map((cat, catIdx) => (
          <div class="cocktail-category" id={`cat-${slugify(cat.name)}`}>
            <h2 class="cocktail-category-name">{cat.name}</h2>
            <ul class="cocktail-grid" role="list">
              {cat.cocktails.map((c, idx) => (
                <li class="cocktail-card">
                  {c.imageUrl && (
                    <div class="cocktail-card-frame">
                      {/* Per-device image strategy (2026-05-14):
                          Desktop (>=1025px) loads GoTab's native JPEG
                          directly — no Vercel re-encoding, no generational
                          compression loss. Cocktail product photography
                          shown at 270px CSS / 540-810 device pixels needs
                          source fidelity that the AVIF re-encode at q85
                          was visibly softening (especially detail-heavy
                          shots: garnishes, ice clarity, glassware). Cost
                          accepted: cross-origin to img.gotab.io for
                          desktop variant, larger payload (~50-80KB JPEG
                          vs ~25-40KB AVIF), no Vercel CDN benefit on
                          that variant. Mobile keeps Vercel AVIF — smaller
                          display + glance behavior hides compression. */}
                      <picture>
                        {c.imageUrlLg && (
                          <source media="(min-width: 1025px)" srcset={c.imageUrlLg} />
                        )}
                        <img
                          src={cdnImage(c.imageUrl, 480, 70)}
                          srcset={`${cdnImage(c.imageUrl, 320, 70)} 320w, ${cdnImage(c.imageUrl, 480, 70)} 480w`}
                          sizes="(min-width: 700px) 30vw, 46vw"
                          alt={c.name}
                          width="480"
                          height="480"
                          loading={catIdx === 0 && idx < 4 ? "eager" : "lazy"}
                          fetchpriority={catIdx === 0 && idx === 0 ? "high" : "auto"}
                          decoding="async"
                        />
                      </picture>
                      {c.isStaffFavorite && (
                        <span class="cocktail-card-badge">Staff Pick</span>
                      )}
                    </div>
                  )}
                  <div class="cocktail-card-body">
                    <h3 class="cocktail-card-name">{c.name}</h3>
                    {c.ingredients && (
                      <p class="cocktail-card-ingredients">{c.ingredients}</p>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="menu-seo" aria-labelledby="menu-seo-h2">
    <div class="menu-seo-inner">
      <h2 class="menu-seo-title" id="menu-seo-h2">About the cocktail program</h2>
      <p>
        Twisted Pin's cocktail program was curated by Brian Van Flandern —
        named America's Top Mixologist by Food Network, with cocktails
        served in 40+ countries. The menu rotates around three categories:
        original craft cocktails built specifically for this bar, reimagined
        classics (Old Fashioneds, Negronis, Cosmopolitans, Aperol Spritzes —
        done with fresh juice, house-made syrup, and the right bitters), and
        a small seasonal lineup that turns over a few times a year.
      </p>
      <p>
        Cocktails are served all hours the bar is open. Find us at
        15610 Joliet Rd, Plainfield, IL — minutes from Naperville,
        Bolingbrook, and Romeoville.
      </p>
    </div>
  </section>

  <SnapFooter />

  <script type="application/ld+json" set:html={JSON.stringify(menuSchema)} />
  <BreadcrumbSchema crumbs={[
    { name: "Home", path: "/" },
    { name: "Bar", path: "/bar/" },
    { name: "Cocktails", path: "/menu/cocktails/" },
  ]} />
</Base>

<style>
  /* ============================================================
     Menu page hero — typography-led, no image. Tighter than the
     pillar-page hero (no min-height) so the menu starts quickly.
     ============================================================ */
  .menu-hero {
    padding: calc(var(--header-height) + 32px) 22px 24px;
    color: var(--warm-white);
    max-width: 1280px;
    margin: 0 auto;
  }
  @media (min-width: 1025px) {
    .menu-hero {
      padding: calc(var(--header-height) + 56px) 64px 32px;
    }
  }

  .menu-hero-headline {
    color: var(--warm-white);
    font-size: clamp(36px, 9vw, 56px);
    letter-spacing: -0.005em;
    line-height: 0.95;
    margin-top: 12px;
  }
  @media (min-width: 1025px) {
    .menu-hero-headline { font-size: clamp(56px, 6vw, 84px); }
  }

  .menu-hero-sub {
    margin-top: 14px;
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.5;
    color: var(--warm-mid);
    max-width: 36em;
  }
  @media (min-width: 1025px) {
    .menu-hero-sub { font-size: 17px; max-width: 42em; }
  }

  /* .hero-fade hoisted to global.css (2026-05-08 LCP fix). */

  /* ============================================================
     COCKTAIL MENU — same compact grid as before. Moved here from
     /bar 2026-05-05.
     ============================================================ */
  .cocktail-menu {
    background: transparent;
    padding: 24px 22px 72px;
  }
  @media (min-width: 1025px) {
    .cocktail-menu { padding: 32px 64px 120px; }
  }

  .cocktail-menu-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .cocktail-category + .cocktail-category {
    margin-top: 56px;
  }
  @media (min-width: 1025px) {
    .cocktail-category + .cocktail-category { margin-top: 88px; }
  }

  /* Anchor-jump offset so pill-nav clicks land below the sticky
     SiteHeader + MenuPillNav (combined ~120px mobile / ~140px desktop). */
  .cocktail-category {
    scroll-margin-top: 120px;
  }
  @media (min-width: 1025px) {
    .cocktail-category { scroll-margin-top: 140px; }
  }

  .cocktail-category-name {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(20px, 5vw, 26px);
    text-transform: uppercase;
    letter-spacing: 0.01em;
    color: var(--warm-white);
    margin: 0 0 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(244, 239, 227, 0.14);
  }
  @media (min-width: 1025px) {
    .cocktail-category-name {
      font-size: 32px;
      margin-bottom: 28px;
      padding-bottom: 16px;
    }
  }

  .cocktail-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px 12px;
  }
  @media (min-width: 700px) {
    .cocktail-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 28px 20px;
    }
  }
  @media (min-width: 1025px) {
    .cocktail-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 32px 24px;
    }
  }

  .cocktail-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .cocktail-card-frame {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-surface);
    aspect-ratio: 1 / 1;
    background: rgba(244, 239, 227, 0.04);
  }

  .cocktail-card-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .cocktail-card-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--indigo-deep);
    background: var(--glow);
    padding: 5px 9px;
    border-radius: 4px;
    line-height: 1;
  }

  .cocktail-card-body {
    padding: 0 2px;
  }

  .cocktail-card-name {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    color: var(--warm-white);
    margin: 0 0 4px;
    line-height: 1.1;
  }
  @media (min-width: 700px) {
    .cocktail-card-name { font-size: 17px; }
  }
  @media (min-width: 1025px) {
    .cocktail-card-name { font-size: 18px; }
  }

  .cocktail-card-ingredients {
    margin: 0;
    font-family: var(--font-body);
    font-size: 12.5px;
    line-height: 1.4;
    color: var(--warm-dim);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (min-width: 1025px) {
    .cocktail-card-ingredients { font-size: 13.5px; }
  }

  /* ============================================================
     SEO copy block — modest, type-only, sits above SnapFooter.
     Provides keyword-relevant context for cold search traffic landing
     on this page. Dimmed color so it reads as supporting copy, not
     primary content.
     ============================================================ */
  .menu-seo {
    background: transparent;
    padding: 24px 22px 56px;
  }
  @media (min-width: 1025px) {
    .menu-seo { padding: 32px 64px 96px; }
  }

  .menu-seo-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .menu-seo-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--warm-white);
    margin: 0 0 14px;
  }
  @media (min-width: 1025px) {
    .menu-seo-title { font-size: 22px; margin-bottom: 18px; }
  }

  .menu-seo p {
    margin: 0 0 14px;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.6;
    color: var(--warm-dim);
  }
  .menu-seo p:last-child { margin-bottom: 0; }
  @media (min-width: 1025px) {
    .menu-seo p { font-size: 15px; line-height: 1.65; }
  }
</style>
