---
/**
 * /menu/food — dedicated food menu page.
 *
 * Extracted from /eat's #menu section (2026-05-05) so the food pillar
 * stays editorial-focused. Reference content lives at its own URL.
 *
 * Layout: typography-led hero (no image) + the food card grid (mirrors
 * the cocktail menu's card rhythm).
 *
 * Data: build-time fetch from GoTab via getFood(). Daily 4am cron
 * keeps it fresh.
 */
import Base from "../../layouts/Base.astro";
import SnapFooter from "../../components/snap/SnapFooter.astro";
import BreadcrumbSchema from "../../components/BreadcrumbSchema.astro";
import MenuPillNav from "../../components/MenuPillNav.astro";
import { getFood } from "../../lib/gotab-food";
import { BUSINESS_URL, BUSINESS_ENTITY_ID } from "../../lib/schema";
import { cdnImage } from "../../lib/cdn-image";

const foodMenu = await getFood();

// Pill-rail wayfinding: slugify GoTab category name for in-page anchors.
// Same slug applied as the id on each .food-category below.
function slugify(s: string): string {
  return s.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "");
}
const pills = foodMenu.categories.map((cat) => ({
  id: `cat-${slugify(cat.name)}`,
  name: cat.name,
}));

// Map GoTab's free-form `tags: string[]` to Schema.org's RestrictedDiet
// enumeration. Best-effort match against known patterns — silently skips
// tags that don't map (`go:staff favorite`, etc). If GoTab returns no
// dietary tags the field is simply omitted from the MenuItem.
//
// Schema.org RestrictedDiet:
// https://schema.org/RestrictedDiet
const DIET_MAP: Array<{ pattern: RegExp; url: string }> = [
  { pattern: /\bvegan\b/i,                            url: "https://schema.org/VeganDiet" },
  { pattern: /\bvegetarian\b/i,                       url: "https://schema.org/VegetarianDiet" },
  { pattern: /\b(gluten[- ]?free|gf)\b/i,             url: "https://schema.org/GlutenFreeDiet" },
  { pattern: /\bhalal\b/i,                            url: "https://schema.org/HalalDiet" },
  { pattern: /\bkosher\b/i,                           url: "https://schema.org/KosherDiet" },
  { pattern: /\blow[- ]?fat\b/i,                      url: "https://schema.org/LowFatDiet" },
  { pattern: /\blow[- ]?(cal|calorie)\b/i,            url: "https://schema.org/LowCalorieDiet" },
];

function suitableForDiet(tags: string[] | undefined): string[] {
  if (!tags || tags.length === 0) return [];
  const out: string[] = [];
  for (const tag of tags) {
    for (const { pattern, url } of DIET_MAP) {
      if (pattern.test(tag) && !out.includes(url)) out.push(url);
    }
  }
  return out;
}

// JSON-LD: Menu → MenuSection → MenuItem. /eat's hasMenu URL points
// at this page; the @id below is the canonical entity reference.
const PAGE_URL = `${BUSINESS_URL}/menu/food/`;
const menuSchema = {
  "@context": "https://schema.org",
  "@type": "Menu",
  "@id": `${BUSINESS_URL}/#menu-food`,
  name: "Food Menu",
  url: PAGE_URL,
  inLanguage: "en-US",
  provider: { "@id": BUSINESS_ENTITY_ID },
  hasMenuSection: foodMenu.categories.map((cat) => ({
    "@type": "MenuSection",
    name: cat.name.trim(),
    hasMenuItem: cat.items.map((it) => {
      const item: Record<string, unknown> = {
        "@type": "MenuItem",
        name: it.name,
      };
      if (it.description) item.description = it.description;
      if (it.imageUrlLg || it.imageUrl) item.image = it.imageUrlLg ?? it.imageUrl;
      const diets = suitableForDiet(it.tags);
      if (diets.length > 0) item.suitableForDiet = diets;
      return item;
    }),
  })),
};
---
<Base
  title="Food Menu in Plainfield, IL | Twisted Pin"
  description="The food menu at Twisted Pin — real plates built to share. Starters, handhelds, pizza, salads, and desserts. Plainfield, IL."
>
  {/* Desktop variant uses img.gotab.io pass-through (2026-05-14 fidelity
      decision). Mobile goes through /_vercel/image (same-origin). Preconnect
      scoped to desktop. See /menu/cocktails for rationale. */}
  <Fragment slot="head">
    <link rel="preconnect" href="https://img.gotab.io" crossorigin media="(min-width: 1025px)" />
  </Fragment>

  <section class="menu-hero" data-hero aria-labelledby="menu-h1">
    <p class="t-eyebrow hero-fade" data-delay-ms="0">The Kitchen</p>
    <h1 class="t-display menu-hero-headline hero-fade" id="menu-h1" data-delay-ms="120">
      Food
    </h1>
    <p class="menu-hero-sub hero-fade" data-delay-ms="320">
      Real plates, built to share. Starters, handhelds,
      pizza, salads, and desserts. Twisted Pin, Plainfield, IL.
    </p>
  </section>

  {foodMenu.categories.length > 0 && (
    <section class="food-menu" id="menu" aria-labelledby="food-menu-h2">
      <div class="food-menu-inner">
        {pills.length > 1 && (
          <MenuPillNav pills={pills} label="Food menu sections" />
        )}
        {foodMenu.categories.map((cat, catIdx) => (
          <div class="food-category" id={`cat-${slugify(cat.name)}`}>
            <h2 class="food-category-name">{cat.name}</h2>
            <ul class="food-grid" role="list">
              {cat.items.map((it, idx) => (
                <li class="food-card">
                  {it.imageUrl ? (
                    <div class="food-card-frame">
                      {/* Per-device image strategy (2026-05-14):
                          Desktop loads GoTab's native JPEG directly to
                          preserve source fidelity. Vercel AVIF re-encode
                          at q85 was visibly softening food photography
                          on retina displays — texture detail (fries,
                          sesame seeds, sauce drips) gets smoothed by AVIF
                          even at high quality settings. Mobile keeps
                          Vercel AVIF for speed. See cocktails.astro for
                          full rationale. */}
                      <picture>
                        {it.imageUrlLg && (
                          <source media="(min-width: 1025px)" srcset={it.imageUrlLg} />
                        )}
                        <img
                          src={cdnImage(it.imageUrl, 480, 70)}
                          srcset={`${cdnImage(it.imageUrl, 320, 70)} 320w, ${cdnImage(it.imageUrl, 480, 70)} 480w`}
                          sizes="(min-width: 700px) 30vw, 46vw"
                          alt={it.name}
                          width="480"
                          height="480"
                          loading={catIdx === 0 && idx < 4 ? "eager" : "lazy"}
                          fetchpriority={catIdx === 0 && idx === 0 ? "high" : "auto"}
                          decoding="async"
                        />
                      </picture>
                      {it.isStaffFavorite && (
                        <span class="food-card-badge">Staff Pick</span>
                      )}
                    </div>
                  ) : (
                    <div class="food-card-frame food-card-frame--empty" aria-hidden="true">
                      {it.isStaffFavorite && (
                        <span class="food-card-badge">Staff Pick</span>
                      )}
                    </div>
                  )}
                  <div class="food-card-body">
                    <h3 class="food-card-name">{it.name}</h3>
                    {it.description && (
                      <p class="food-card-description">{it.description}</p>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="menu-seo" aria-labelledby="menu-seo-h2">
    <div class="menu-seo-inner">
      <h2 class="menu-seo-title" id="menu-seo-h2">About the kitchen</h2>
      <p>
        The kitchen at Twisted Pin runs a menu of plates built to share —
        starters and snack platters for the table, handhelds (sliders,
        burgers, tacos, and fried chicken sandwiches), pizza and flatbreads,
        salads, a kids menu, and house-made desserts. Pairs deliberately
        with the cocktail program — a few of the bar's signatures were
        specced for plates on this menu, and a few of the snacks were
        specced for the bar.
      </p>
      <p>
        Find us at 15610 Joliet Rd, Plainfield, IL — minutes from
        Naperville, Bolingbrook, and Romeoville.
      </p>
    </div>
  </section>

  <SnapFooter />

  <script type="application/ld+json" set:html={JSON.stringify(menuSchema)} />
  <BreadcrumbSchema crumbs={[
    { name: "Home", path: "/" },
    { name: "Menu", path: "/menu/" },
    { name: "Food", path: "/menu/food/" },
  ]} />
</Base>

<style>
  /* ============================================================
     Menu page hero — shared shape across /menu/* pages.
     ============================================================ */
  .menu-hero {
    padding: calc(var(--header-height) + 32px) 22px 24px;
    color: var(--warm-white);
    max-width: 1280px;
    margin: 0 auto;
  }
  @media (min-width: 1025px) {
    .menu-hero {
      padding: calc(var(--header-height) + 56px) 64px 32px;
    }
  }

  .menu-hero-headline {
    color: var(--warm-white);
    font-size: clamp(36px, 9vw, 56px);
    letter-spacing: -0.005em;
    line-height: 0.95;
    margin-top: 12px;
  }
  @media (min-width: 1025px) {
    .menu-hero-headline { font-size: clamp(56px, 6vw, 84px); }
  }

  .menu-hero-sub {
    margin-top: 14px;
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.5;
    color: var(--warm-mid);
    max-width: 36em;
  }
  @media (min-width: 1025px) {
    .menu-hero-sub { font-size: 17px; max-width: 42em; }
  }

  /* .hero-fade hoisted to global.css (2026-05-08 LCP fix). */

  /* ============================================================
     FOOD MENU — same compact grid as cocktails. Moved here from
     /eat 2026-05-05.
     ============================================================ */
  .food-menu {
    background: transparent;
    padding: 24px 22px 72px;
  }
  @media (min-width: 1025px) {
    .food-menu { padding: 32px 64px 120px; }
  }

  .food-menu-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .food-category + .food-category {
    margin-top: 56px;
  }
  @media (min-width: 1025px) {
    .food-category + .food-category { margin-top: 88px; }
  }

  /* Anchor-jump offset so pill-nav clicks land below the sticky
     SiteHeader + MenuPillNav (combined ~120px mobile / ~140px desktop). */
  .food-category {
    scroll-margin-top: 120px;
  }
  @media (min-width: 1025px) {
    .food-category { scroll-margin-top: 140px; }
  }

  .food-category-name {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(20px, 5vw, 26px);
    text-transform: uppercase;
    letter-spacing: 0.01em;
    color: var(--warm-white);
    margin: 0 0 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(244, 239, 227, 0.14);
  }
  @media (min-width: 1025px) {
    .food-category-name {
      font-size: 32px;
      margin-bottom: 28px;
      padding-bottom: 16px;
    }
  }

  .food-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px 12px;
  }
  @media (min-width: 700px) {
    .food-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 28px 20px;
    }
  }
  @media (min-width: 1025px) {
    .food-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 32px 24px;
    }
  }

  .food-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .food-card-frame {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-surface);
    aspect-ratio: 1 / 1;
    background: rgba(244, 239, 227, 0.04);
  }

  .food-card-frame--empty {
    background:
      linear-gradient(135deg, rgba(244, 239, 227, 0.04), rgba(244, 239, 227, 0.02));
  }

  .food-card-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .food-card-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--indigo-deep);
    background: var(--glow);
    padding: 5px 9px;
    border-radius: 4px;
    line-height: 1;
  }

  .food-card-body {
    padding: 0 2px;
  }

  .food-card-name {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    color: var(--warm-white);
    margin: 0 0 4px;
    line-height: 1.1;
  }
  @media (min-width: 700px) {
    .food-card-name { font-size: 17px; }
  }
  @media (min-width: 1025px) {
    .food-card-name { font-size: 18px; }
  }

  .food-card-description {
    margin: 0;
    font-family: var(--font-body);
    font-size: 12.5px;
    line-height: 1.4;
    color: var(--warm-dim);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (min-width: 1025px) {
    .food-card-description { font-size: 13.5px; }
  }

  /* ============================================================
     SEO copy block — see /menu/cocktails for shape rationale.
     ============================================================ */
  .menu-seo {
    background: transparent;
    padding: 24px 22px 56px;
  }
  @media (min-width: 1025px) {
    .menu-seo { padding: 32px 64px 96px; }
  }

  .menu-seo-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .menu-seo-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--warm-white);
    margin: 0 0 14px;
  }
  @media (min-width: 1025px) {
    .menu-seo-title { font-size: 22px; margin-bottom: 18px; }
  }

  .menu-seo p {
    margin: 0 0 14px;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.6;
    color: var(--warm-dim);
  }
  .menu-seo p:last-child { margin-bottom: 0; }
  @media (min-width: 1025px) {
    .menu-seo p { font-size: 15px; line-height: 1.65; }
  }
</style>
