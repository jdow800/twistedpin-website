---
/**
 * /snap-test/ — POC for mobile snap-scroll pattern.
 *
 * Mobile (≤1024): the <main> container becomes the scroll container,
 *   100dvh tall, with `scroll-snap-type: y mandatory` + `scroll-snap-stop: always`.
 *   Each section is 100dvh tall with `scroll-snap-align: start`.
 *
 * Desktop (≥1025): no snap. <main> is normal block flow; sections collapse to
 *   their content height (or 100dvh if the section says so). Pure POC of mobile
 *   gesture, not desktop.
 *
 * StickyCTABar is ON for this route — sits over the bottom of every snapped
 *   section (position:fixed). Sections include extra bottom padding so the
 *   bar doesn't crash into call-to-action content (form button, link).
 *
 * NOT linked from anywhere. Standalone proof-of-concept.
 */
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
---
<Base
  title="Snap-scroll POC — Twisted Pin"
  description="Internal POC. Three full-screen sections with mobile scroll-snap."
>
  <main class="snap">
    {/* Section 1 — existing hero, reused as-is. */}
    <Hero />

    {/* Section 2 — coupon signup. Bar liquor-wall photo backdrop + dark scrim. */}
    <section class="snap-section section-coupon" aria-labelledby="coupon-h1">
      {/* Backdrop image — loading="lazy" defers fetch until near viewport.
          Source: Bar - liquor wall.jpg via scripts/build-snap-images.mjs. */}
      <picture class="coupon-bg" aria-hidden="true">
        <source
          type="image/webp"
          srcset="/snap/coupon-bg-540.webp 540w, /snap/coupon-bg-1080.webp 1080w, /snap/coupon-bg-1280.webp 1280w"
          sizes="100vw"
        />
        <img
          src="/snap/coupon-bg-1080.jpg"
          srcset="/snap/coupon-bg-540.jpg 540w, /snap/coupon-bg-1080.jpg 1080w, /snap/coupon-bg-1280.jpg 1280w"
          sizes="100vw"
          alt=""
          loading="lazy"
          decoding="async"
          width="1080"
          height="1350"
        />
      </picture>
      <div class="coupon-scrim" aria-hidden="true"></div>

      <div class="section-inner">
        <p class="t-eyebrow eyebrow">Text club</p>
        <h1 class="t-display coupon-h1" id="coupon-h1">$10&nbsp;off your first&nbsp;visit</h1>
        <p class="coupon-sub">Sign up for the text club. We'll send the code now.</p>

        <form class="coupon-form" data-coupon-form novalidate>
          <label class="visually-hidden" for="coupon-phone">Phone number</label>
          <input
            id="coupon-phone"
            class="coupon-input"
            type="tel"
            inputmode="tel"
            autocomplete="tel"
            placeholder="(555) 555-5555"
            required
            pattern="[\d\s().+\-]{7,}"
            aria-describedby="coupon-disclaimer"
          />
          <button type="submit" class="btn btn-solid coupon-submit">
            Send the code
          </button>
        </form>

        <p class="coupon-disclaimer" id="coupon-disclaimer">
          Standard message rates apply. Reply STOP to opt out.
        </p>

        <div class="coupon-success" data-coupon-success aria-live="polite" hidden>
          <p class="t-display success-h">Code sent. See you Friday.</p>
          <p class="success-sub">Check your messages — code expires in 30 days.</p>
        </div>
      </div>
    </section>

    {/* Section 3 — 28 taps, real beer-wall video.
        Lazy: <video preload="none">; IntersectionObserver below calls .load()
        when section 3 enters the rootMargin window, then .play() on full
        intersect. Poster shows during the buffer window. */}
    <section class="snap-section section-tapwall" data-tapwall-section aria-labelledby="tapwall-h1">
      <video
        class="tapwall-video"
        data-tapwall-video
        preload="none"
        muted
        loop
        playsinline
        poster="/snap/beerwall-poster.webp"
        aria-hidden="true"
      >
        <source data-src="/snap/beerwall-mobile-av1-1080.mp4" type="video/mp4; codecs=av01.0.05M.08" />
        <source data-src="/snap/beerwall-mobile-h264-1080.mp4" type="video/mp4" />
      </video>
      <div class="tapwall-scrim" aria-hidden="true"></div>

      <div class="section-inner">
        <p class="t-eyebrow eyebrow">The wall</p>
        <h1 class="t-display tapwall-h1" id="tapwall-h1">28&nbsp;taps. Pour your&nbsp;own.</h1>
        <p class="tapwall-sub">The only self-serve wall in the area.</p>
        <a class="tapwall-link" href="/craft-bar/">
          Learn more <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>
  </main>
</Base>

<script>
  /* ---------- Coupon form (POC, no network) ---------- */
  const form = document.querySelector<HTMLFormElement>("[data-coupon-form]");
  const success = document.querySelector<HTMLElement>("[data-coupon-success]");
  const disclaimer = document.querySelector<HTMLElement>("#coupon-disclaimer");

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const input = form.querySelector<HTMLInputElement>("#coupon-phone");
    if (!input) return;

    const digits = (input.value.match(/\d/g) ?? []).length;
    if (digits < 10) {
      input.setCustomValidity("Enter a 10-digit phone number.");
      input.reportValidity();
      input.addEventListener("input", () => input.setCustomValidity(""), { once: true });
      return;
    }

    input.blur();
    form.hidden = true;
    if (disclaimer) disclaimer.hidden = true;
    if (success) success.hidden = false;
  });

  /* ---------- Beer-wall video lazy load ----------
     Pattern: <source data-src="…">. We don't promote to `src` until
     IntersectionObserver fires. That keeps every byte off the wire on first
     paint — the section's poster is the only image fetched (lazy itself).
     Once promoted: video.load() materializes the element, then .play() once
     the section is fully visible. Reduced-motion users get the poster only,
     no autoplay. */
  const tapwallSection = document.querySelector<HTMLElement>("[data-tapwall-section]");
  const tapwallVideo = document.querySelector<HTMLVideoElement>("[data-tapwall-video]");
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (tapwallSection && tapwallVideo && !reducedMotion) {
    let promoted = false;
    const promoteSources = () => {
      if (promoted) return;
      promoted = true;
      tapwallVideo.querySelectorAll<HTMLSourceElement>("source[data-src]").forEach((s) => {
        const src = s.getAttribute("data-src");
        if (src) s.setAttribute("src", src);
      });
      tapwallVideo.load();
    };

    const tryPlay = () => {
      promoteSources();
      tapwallVideo.play().catch(() => { /* autoplay blocked; poster stays */ });
    };

    if ("IntersectionObserver" in window) {
      // Stage 1: promote sources when the section is within ~1 viewport.
      const preloadObs = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              promoteSources();
              preloadObs.disconnect();
            }
          }
        },
        { rootMargin: "100% 0px 100% 0px", threshold: 0.01 },
      );
      preloadObs.observe(tapwallSection);

      // Stage 2: autoplay when fully in view, pause when it leaves.
      const playObs = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) tryPlay();
            else tapwallVideo.pause();
          }
        },
        { threshold: 0.6 },
      );
      playObs.observe(tapwallSection);
    }

    // Fallback: scroll listener on the snap container. Belt + suspenders for
    // browsers (or environments) where IO doesn't fire reliably on
    // sub-scroller intersection. Cheap — only inspects rect, no work per tick.
    const snapEl = document.querySelector<HTMLElement>(".snap");
    if (snapEl) {
      const onScroll = () => {
        const rect = tapwallSection.getBoundingClientRect();
        const vh = window.innerHeight;
        // within 1 viewport of being visible -> promote
        if (rect.top < vh * 2 && rect.bottom > -vh) promoteSources();
        // mostly-visible -> play
        if (rect.top < vh * 0.4 && rect.bottom > vh * 0.6) tryPlay();
      };
      snapEl.addEventListener("scroll", onScroll, { passive: true });
      // First tick in case the page loads already scrolled to section 3.
      onScroll();
    }
  }
</script>

<style>
  /* ---------- snap container ---------- */
  .snap {
    /* desktop default: normal block layout */
  }

  @media (max-width: 1024px) {
    .snap {
      height: 100dvh;
      height: 100vh;
      height: 100dvh;
      overflow-y: scroll;
      overflow-x: hidden;
      scroll-snap-type: y mandatory;
      -webkit-overflow-scrolling: touch;
      overscroll-behavior-y: contain;
    }
    /* :global(.hero) needed because Astro scopes the .hero class to the Hero
       component — without it, section 1 has snap-align:none and the browser
       lands on section 2 on first paint (mandatory snap aligns to the
       nearest valid snap target). */
    .snap > :global(.hero),
    .snap > .snap-section {
      scroll-snap-align: start;
      scroll-snap-stop: always;
    }
  }

  /* ---------- shared section chrome ---------- */
  .snap-section {
    position: relative;
    width: 100%;
    min-height: 100dvh;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
    /* Reserve breathing room at the bottom so the sticky CTA bar doesn't
       crash into the form button / Learn-more link. --bar-pad already
       accounts for var(--bar-height) + safe-area inset. */
    padding-bottom: calc(var(--bar-pad) + 32px);
  }
  @media (min-width: 1025px) {
    .snap-section { padding-bottom: 0; }
  }

  .section-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 640px;
    margin: 0 auto;
    padding: 0 22px;
    color: var(--warm-white);
  }

  @media (min-width: 1025px) {
    .section-inner { padding: 0 64px; max-width: 880px; margin: 0; }
  }

  .eyebrow { margin-bottom: 18px; }

  /* ---------- section 2 — coupon, with bar-photo backdrop ---------- */
  .section-coupon { background: #100912; }

  .coupon-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .coupon-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .coupon-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg,
        rgba(14, 10, 31, 0.55) 0%,
        rgba(14, 10, 31, 0.28) 30%,
        rgba(14, 10, 31, 0.55) 60%,
        rgba(14, 10, 31, 0.92) 100%);
  }

  .coupon-h1 {
    color: var(--warm-white);
    font-size: clamp(40px, 12vw, 88px);
    letter-spacing: -0.015em;
    line-height: 0.92;
    margin-bottom: 14px;
    text-shadow: 0 2px 12px rgba(14, 10, 31, 0.45);
  }
  @media (min-width: 1025px) {
    .coupon-h1 { font-size: clamp(72px, 7vw, 110px); letter-spacing: 0.005em; }
  }

  .coupon-sub {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.45;
    color: #ece6d6;
    max-width: 28em;
    margin-bottom: 28px;
  }
  @media (min-width: 1025px) {
    .coupon-sub { font-size: 19px; line-height: 1.5; margin-bottom: 36px; }
  }

  .coupon-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: 420px;
  }

  .coupon-input {
    width: 100%;
    padding: 16px 18px;
    font: inherit;
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 16px; /* 16px+ prevents iOS zoom-on-focus */
    letter-spacing: 0.02em;
    color: var(--warm-white);
    background: rgba(14, 10, 31, 0.55);
    border: 1px solid rgba(244, 239, 227, 0.22);
    border-radius: var(--radius-button);
    outline: none;
    backdrop-filter: blur(6px) saturate(120%);
    -webkit-backdrop-filter: blur(6px) saturate(120%);
    transition: border-color 150ms ease-out, background-color 150ms ease-out;
  }
  .coupon-input::placeholder { color: var(--warm-dim); }
  .coupon-input:focus {
    border-color: var(--glow);
    background: rgba(14, 10, 31, 0.7);
  }
  .coupon-input:invalid:not(:placeholder-shown) {
    border-color: rgba(216, 139, 92, 0.7);
  }

  .coupon-submit {
    width: 100%;
    padding: 16px 22px;
    font-size: 12.5px;
  }

  .coupon-disclaimer {
    margin-top: 14px;
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--warm-dim);
    max-width: 32em;
  }

  .coupon-success { max-width: 480px; }
  .success-h {
    color: var(--glow);
    font-size: clamp(32px, 9vw, 64px);
    letter-spacing: -0.01em;
    line-height: 0.96;
    margin-bottom: 12px;
  }
  .success-sub {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.45;
    color: #ece6d6;
  }

  /* ---------- section 3 — beer wall video ---------- */
  .section-tapwall { background: #0a0604; }

  .tapwall-video {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .tapwall-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg,
        rgba(14, 10, 31, 0.45) 0%,
        rgba(14, 10, 31, 0.10) 28%,
        rgba(14, 10, 31, 0.10) 55%,
        rgba(14, 10, 31, 0.92) 100%);
  }

  .tapwall-h1 {
    color: var(--warm-white);
    font-size: clamp(40px, 12vw, 88px);
    letter-spacing: -0.015em;
    line-height: 0.92;
    margin-bottom: 14px;
    text-shadow: 0 2px 12px rgba(14, 10, 31, 0.45);
  }
  @media (min-width: 1025px) {
    .tapwall-h1 { font-size: clamp(72px, 7vw, 110px); letter-spacing: 0.005em; }
  }

  .tapwall-sub {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.45;
    color: #ece6d6;
    max-width: 26em;
    margin-bottom: 22px;
  }
  @media (min-width: 1025px) {
    .tapwall-sub { font-size: 19px; line-height: 1.5; margin-bottom: 28px; }
  }

  .tapwall-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--glow);
    padding: 10px 0;
    border-bottom: 1px solid rgba(78, 236, 196, 0.4);
    transition: color 150ms ease-out, border-color 150ms ease-out, transform 150ms ease-out;
  }
  .tapwall-link:hover {
    color: var(--warm-white);
    border-bottom-color: var(--warm-white);
    transform: translateX(2px);
  }

  /* ---------- a11y helper ---------- */
  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }
</style>
