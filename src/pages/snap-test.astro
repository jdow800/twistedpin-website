---
/**
 * /snap-test/ — staging route for the 8-snap homepage architecture.
 *
 * Snap order (locked in the architecture brief):
 *   1. Hero (revised: no eyebrow, no stat bar, new subhead)
 *   2. Events / Suite Life       (stub — solid Midnight Indigo)
 *   3. Tap Wall                  (real beer-wall video, lazy-loaded)
 *   4. Craft Cocktails           (stub)
 *   5. Food                      (stub)
 *   6. Bowl                      (stub)
 *   7. Arcade                    (stub)
 *   8. Hours / Location / Footer (sticky CTA bar hidden here)
 *
 * Snap mechanic: container-driven scroll-snap on mobile (≤1024), normal
 *   long-scroll on desktop. See the .snap CSS block for specifics.
 *
 * Hero is INLINED (not the shared <Hero /> component) because the brief's
 *   revisions — drop eyebrow + stat bar, new subhead, bottom-only scrim —
 *   would change the live homepage if applied to the shared component.
 *   Promotion to / happens after staging review.
 *
 * Sticky CTA bar (rendered by Base) stays visible on snaps 1–7; the
 *   page-level scroll watcher toggles `body.snap-cta-hidden` when snap 8
 *   is in view, fading the bar out.
 */
import Base from "../layouts/Base.astro";
import SnapStub from "../components/snap/SnapStub.astro";
import SnapFooter from "../components/snap/SnapFooter.astro";
---
<Base
  title="Snap-scroll architecture POC — Twisted Pin"
  description="Staging route for the 8-snap homepage architecture."
>
  <main class="snap">
    {/* ================================================
        SNAP 1 — HERO (revised per brief)
        Inlined: shared <Hero /> stays untouched until staging review.
        ================================================ */}
    <section class="snap-section snap-hero" data-hero aria-labelledby="hero-h1">
      <a class="hero-brand" href="/" aria-label="Twisted Pin home">
        <picture>
          <source type="image/webp" srcset="/logo/twisted-pin-horizontal-white.webp" />
          <img
            src="/logo/twisted-pin-horizontal-white.png"
            alt="Twisted Pin"
            width="298"
            height="128"
            decoding="async"
            fetchpriority="high"
          />
        </picture>
      </a>

      {/* Mobile vertical 9:16 video — same source as the live hero. */}
      <video
        class="hero-video hero-video-mobile"
        preload="metadata"
        muted
        autoplay
        loop
        playsinline
        poster="/hero/hero-poster.webp"
        aria-hidden="true"
      >
        <source src="/hero/hero-mobile-av1-1080.mp4" type="video/mp4; codecs=av01.0.05M.08" />
        <source src="/hero/hero-mobile-h264-1080.mp4" type="video/mp4" />
      </video>

      {/* Desktop 16:9 video. */}
      <video
        class="hero-video hero-video-desktop"
        preload="metadata"
        muted
        autoplay
        loop
        playsinline
        poster="/hero/hero-desktop-poster.webp"
        aria-hidden="true"
      >
        <source src="/hero/hero-desktop-av1.mp4" type="video/mp4; codecs=av01.0.05M.08" />
        <source src="/hero/hero-desktop-h264.mp4" type="video/mp4" />
      </video>

      {/* Bottom-only scrim — dark fade up from the bottom. */}
      <div class="hero-scrim" aria-hidden="true"></div>

      <div class="hero-copy">
        <h1 class="t-display hero-headline" id="hero-h1">
          <span class="hero-headline-line hero-fade" data-delay-ms="0">Built&nbsp;for&nbsp;adults.</span>
          <span class="hero-headline-line hero-fade" data-delay-ms="300">Fine,&nbsp;bring&nbsp;the&nbsp;kids.</span>
        </h1>
        <p class="hero-sub hero-fade" data-delay-ms="380">
          Plainfield's premier night out. Bowling optional.
        </p>
      </div>
    </section>

    {/* ================================================
        SNAP 2 — EVENTS THAT DON'T SUCK  (stub)
        ================================================ */}
    <SnapStub
      title="Events That Don't Suck"
      subhead="Privatize the suite. Run the night your way."
      href="#"
    />

    {/* ================================================
        SNAP 3 — THE TAP WALL  (real beer-wall video, lazy-loaded)
        ================================================ */}
    <section class="snap-section snap-tapwall" data-tapwall-section aria-labelledby="tapwall-h1">
      {/* Lazy: <video preload="none">; sources held in data-src until the
          page-level lazy-loader promotes them on near-viewport entry. */}
      <video
        class="tapwall-video"
        data-tapwall-video
        preload="none"
        muted
        loop
        playsinline
        poster="/snap/beerwall-poster.webp"
        aria-hidden="true"
      >
        <source data-src="/snap/beerwall-mobile-av1-1080.mp4" type="video/mp4; codecs=av01.0.05M.08" />
        <source data-src="/snap/beerwall-mobile-h264-1080.mp4" type="video/mp4" />
      </video>
      <div class="tapwall-scrim" aria-hidden="true"></div>

      <div class="tapwall-inner">
        <h2 class="tapwall-title" id="tapwall-h1">The tap wall</h2>
        <p class="tapwall-sub">
          <span class="tapwall-sub-main">28 self-serve taps</span>
          <span class="tapwall-sub-paren">(only wall in the area)</span>
        </p>
        <a class="stub-learn" href="#">Learn more <span aria-hidden="true">→</span></a>
      </div>
    </section>

    {/* ================================================
        SNAP 4 — CRAFT COCKTAILS  (stub; reserved-copy subhead, line-break form)
        Title-case "Top Mixologist" preserved per voice.md locked copy —
        worth confirming if you wanted strict sentence-case here.
        ================================================ */}
    <SnapStub
      title="Craft Cocktails"
      subhead="Built by America's Top Mixologist."
      subheadParen="their words, not ours"
      href="#"
    />

    {/* ================================================
        SNAP 5 — FOOD  (stub; food-focused copy, no bar reference)
        ================================================ */}
    <SnapStub
      title="Food"
      subhead="Chef-inspired menu."
      subheadParen="built to share"
      href="#"
    />

    {/* ================================================
        SNAP 6 — BOWL  (stub; uses locked lane phrasing)
        ================================================ */}
    <SnapStub
      title="Bowl"
      subhead="17 traditional lanes plus a 6-lane VIP suite."
      href="#"
    />

    {/* ================================================
        SNAP 7 — ARCADE  (stub)
        ================================================ */}
    <SnapStub
      title="Arcade"
      subhead="Tickets, prizes, bragging rights."
      href="#"
    />

    {/* ================================================
        SNAP 8 — HOURS / LOCATION / FOOTER
        Sticky CTA bar fades out when this snap is in view.
        ================================================ */}
    <SnapFooter />
  </main>
</Base>

<script>
  /* ============================================================
     Beer-wall video lazy-load (snap 3). Same pattern as before:
     <source data-src="…"> until IntersectionObserver promotes to src.
     Scroll-listener fallback covers environments where IO doesn't
     fire reliably for sub-scroller intersections.
     ============================================================ */
  const tapwallSection = document.querySelector<HTMLElement>("[data-tapwall-section]");
  const tapwallVideo = document.querySelector<HTMLVideoElement>("[data-tapwall-video]");
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (tapwallSection && tapwallVideo && !reducedMotion) {
    let promoted = false;
    const promoteSources = () => {
      if (promoted) return;
      promoted = true;
      tapwallVideo.querySelectorAll<HTMLSourceElement>("source[data-src]").forEach((s) => {
        const src = s.getAttribute("data-src");
        if (src) s.setAttribute("src", src);
      });
      tapwallVideo.load();
    };
    const tryPlay = () => {
      promoteSources();
      tapwallVideo.play().catch(() => { /* autoplay blocked; poster stays */ });
    };

    if ("IntersectionObserver" in window) {
      const preloadObs = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              promoteSources();
              preloadObs.disconnect();
            }
          }
        },
        { rootMargin: "100% 0px 100% 0px", threshold: 0.01 },
      );
      preloadObs.observe(tapwallSection);

      const playObs = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) tryPlay();
            else tapwallVideo.pause();
          }
        },
        { threshold: 0.6 },
      );
      playObs.observe(tapwallSection);
    }

    const snapEl = document.querySelector<HTMLElement>(".snap");
    if (snapEl) {
      const onScroll = () => {
        const rect = tapwallSection.getBoundingClientRect();
        const vh = window.innerHeight;
        if (rect.top < vh * 2 && rect.bottom > -vh) promoteSources();
        if (rect.top < vh * 0.4 && rect.bottom > vh * 0.6) tryPlay();
      };
      snapEl.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    }
  }

  /* ============================================================
     Sticky-CTA hide on snap 8.
     Toggles `body.snap-cta-hidden` while the footer snap is the
     dominant section in view (>50% intersection). The CSS in the
     <style is:global> block below fades the bar out smoothly.
     ============================================================ */
  const footer = document.querySelector<HTMLElement>(".snap-footer");
  if (footer) {
    const toggleHide = (hide: boolean) => {
      document.body.classList.toggle("snap-cta-hidden", hide);
    };

    if ("IntersectionObserver" in window) {
      const footerObs = new IntersectionObserver(
        (entries) => {
          for (const e of entries) toggleHide(e.intersectionRatio > 0.5);
        },
        { threshold: [0, 0.25, 0.5, 0.75, 1] },
      );
      footerObs.observe(footer);
    }

    // Scroll-listener fallback (same reasoning as beer-wall lazy-load).
    const snapEl = document.querySelector<HTMLElement>(".snap");
    if (snapEl) {
      const onScroll = () => {
        const rect = footer.getBoundingClientRect();
        const vh = window.innerHeight;
        const visible = Math.max(0, Math.min(rect.bottom, vh) - Math.max(rect.top, 0));
        toggleHide(visible / vh > 0.5);
      };
      snapEl.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    }
  }
</script>

<style is:global>
  /* Sticky CTA hide-on-snap-8. Lives in a global block because the bar
     is rendered by Base.astro's <StickyCTABar /> — outside this page's
     scoped styles.

     `!important` is necessary on opacity/transform because Motion One
     writes inline styles on the bar after its entry animation — inline
     styles win specificity over a regular stylesheet rule. The
     transition itself is also marked important so the un-hide path
     animates back smoothly. */
  body.snap-cta-hidden [data-cta-bar] {
    opacity: 0 !important;
    transform: translateY(120%) !important;
    pointer-events: none;
    transition:
      opacity 280ms ease-out,
      transform 280ms ease-out !important;
  }
</style>

<style>
  /* ============================================================
     Snap container. Mobile (≤1024) takes over the viewport as the
     scroll surface; desktop falls back to normal page flow.
     ============================================================ */
  .snap {
    /* desktop default: normal block layout */
  }
  @media (max-width: 1024px) {
    .snap {
      height: 100dvh;
      height: 100vh;
      height: 100dvh;
      overflow-y: scroll;
      overflow-x: hidden;
      scroll-snap-type: y mandatory;
      -webkit-overflow-scrolling: touch;
      overscroll-behavior-y: contain;
    }
    /* Direct children become snap stops. `:global(.snap-section)` is needed
       because SnapStub and SnapFooter are child components — Astro scopes
       their `.snap-section` differently from this page's, so the unscoped
       selector misses them. (Same Astro-scoping gotcha as the live homepage
       Hero used in earlier rounds — see CLAUDE.md decisions log.) */
    .snap > :global(.snap-section) {
      scroll-snap-align: start;
      scroll-snap-stop: always;
    }
  }

  /* Shared section chrome — wrapped in :global so the rule matches both
     this page's inline sections AND component-rendered ones. */
  :global(.snap-section) {
    position: relative;
    width: 100%;
    min-height: 100dvh;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
    /* Reserve room for the sticky CTA bar so its glass face doesn't crash
       into bottom-anchored copy. SnapFooter overrides this back to 0. */
    padding-bottom: calc(var(--bar-pad) + 32px);
  }
  @media (min-width: 1025px) {
    :global(.snap-section) { padding-bottom: 0; }
  }

  /* ============================================================
     SNAP 1 — HERO
     ============================================================ */
  .snap-hero {
    background: #000;
  }

  .hero-brand {
    position: absolute;
    z-index: 4;
    top: calc(20px + var(--safe-top));
    left: 22px;
    line-height: 0;
    filter: drop-shadow(0 1px 6px rgba(14, 10, 31, 0.5));
  }
  .hero-brand img {
    height: 41px;
    width: auto;
    display: block;
  }
  @media (min-width: 1025px) {
    .hero-brand { top: calc(28px + var(--safe-top)); left: 40px; }
    .hero-brand img { height: 56px; }
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-video-mobile  { display: block; }
  .hero-video-desktop { display: none; }
  @media (min-width: 1025px) {
    .hero-video-mobile  { display: none; }
    .hero-video-desktop { display: block; }
  }

  /* Bottom-only scrim per the brief. Stronger near the bottom so headline
     reads against any video frame. */
  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg,
      rgba(14, 10, 31, 0)    0%,
      rgba(14, 10, 31, 0)    35%,
      rgba(14, 10, 31, 0.55) 70%,
      rgba(14, 10, 31, 0.95) 100%);
  }
  @media (min-width: 1025px) {
    /* Desktop: keep a left-side fade as well so copy on the lower-left has
       its own backstop. Same bottom emphasis. */
    .hero-scrim {
      background:
        linear-gradient(90deg,
          rgba(14, 10, 31, 0.65) 0%,
          rgba(14, 10, 31, 0.20) 40%,
          rgba(14, 10, 31, 0)    70%),
        linear-gradient(180deg,
          rgba(14, 10, 31, 0)    0%,
          rgba(14, 10, 31, 0)    45%,
          rgba(14, 10, 31, 0.55) 75%,
          rgba(14, 10, 31, 0.95) 100%);
    }
  }

  .hero-copy {
    position: absolute;
    z-index: 2;
    left: 22px;
    right: 22px;
    bottom: calc(var(--bar-pad) + 24px);
    color: var(--warm-white);
  }
  @media (min-width: 1025px) {
    .hero-copy {
      left: 64px;
      right: auto;
      bottom: 88px;
      max-width: 640px;
    }
  }

  .hero-headline {
    color: var(--warm-white);
    font-size: clamp(34px, 11vw, 80px);
    letter-spacing: -0.015em;
    line-height: 0.92;
  }
  .hero-headline-line { display: block; }
  .hero-headline-line + .hero-headline-line { margin-top: 2px; }
  @media (min-width: 1025px) {
    .hero-headline { font-size: clamp(72px, 7vw, 110px); letter-spacing: 0.005em; }
  }

  .hero-sub {
    margin-top: 16px;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.45;
    color: #ece6d6;
    max-width: 24em;
  }
  @media (min-width: 1025px) {
    .hero-sub { margin-top: 22px; font-size: 20px; line-height: 1.5; max-width: 30em; }
  }

  .hero-fade { opacity: 0; transform: translateY(12px); }
  @media (prefers-reduced-motion: reduce) {
    .hero-fade { opacity: 1; transform: none; }
  }

  /* ============================================================
     SNAP 3 — TAP WALL
     ============================================================ */
  .snap-tapwall { background: #0a0604; }

  .tapwall-video {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .tapwall-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg,
      rgba(14, 10, 31, 0)    0%,
      rgba(14, 10, 31, 0)    35%,
      rgba(14, 10, 31, 0.55) 70%,
      rgba(14, 10, 31, 0.95) 100%);
  }
  .tapwall-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 640px;
    margin: 0 auto;
    margin-top: auto;
    padding: 0 22px;
    text-align: center;
    color: var(--warm-white);
  }
  @media (min-width: 1025px) {
    .tapwall-inner { max-width: 880px; padding: 0 64px; }
  }

  /* Use the same UI-font title treatment as SnapStub so all snap titles
     beyond the hero share one rhythm. (Snap 3 is the one section with a
     real video; everything else about its title type matches the stubs.) */
  .tapwall-title {
    font-family: var(--font-ui);
    font-weight: 700;
    text-transform: uppercase;
    color: var(--warm-white);
    font-size: clamp(34px, 9vw, 60px);
    letter-spacing: 0.02em;
    line-height: 1.0;
    margin-bottom: 14px;
    text-shadow: 0 2px 12px rgba(14, 10, 31, 0.45);
  }
  @media (min-width: 1025px) {
    .tapwall-title { font-size: clamp(48px, 5.5vw, 72px); }
  }

  .tapwall-sub {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 16px;
    line-height: 1.45;
    color: #ece6d6;
    max-width: 32em;
    margin: 0 auto 22px;
  }
  /* Same two-line pattern as SnapStub. Spans become block so the line break
     is structural — easier to reason about than relying on whitespace. */
  .tapwall-sub-main,
  .tapwall-sub-paren { display: block; }
  .tapwall-sub-paren {
    color: var(--warm-dim);
    margin-top: 4px;
    font-size: 0.9em;
  }
  @media (min-width: 1025px) {
    .tapwall-sub { font-size: 19px; line-height: 1.5; margin-bottom: 28px; }
    .tapwall-sub-paren { margin-top: 6px; }
  }

  /* Shared learn-more chip — also used inline by snap 3.
     SnapStub defines its own copy of these styles in its scoped block. */
  .stub-learn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--glow);
    padding: 10px 0;
    border-bottom: 1px solid rgba(78, 236, 196, 0.4);
    transition: color 150ms ease-out, border-color 150ms ease-out, transform 150ms ease-out;
  }
  .stub-learn:hover {
    color: var(--warm-white);
    border-bottom-color: var(--warm-white);
    transform: translateX(2px);
  }
</style>
