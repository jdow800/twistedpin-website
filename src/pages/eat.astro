---
/**
 * /eat/ — Food pillar page.
 *
 * Second inner-page mock. Mirrors the rhythm in /bar:
 *   - Hero: typography-led title section (no image — page identity comes
 *     from the headline against the body bg + global Pin Tilt watermark).
 *     2026-05-04: switched from full-bleed image hero to type-only.
 *   - Two long-scroll editorial sections (image one side, copy the other,
 *     alternating)
 *   - SnapFooter
 *
 * Closing CTA band ("Skip the drive-thru.") was retired 2026-05-04 — the
 * global sticky CTA bar already carries Reserve / Plan, so a duplicate at
 * the page bottom was visual debt without conversion lift.
 *
 * Two thematic sections because the food story IS two beats:
 *   1. The Kitchen — chef-inspired, not bowling-alley-food philosophy
 *   2. Built to Share — shareable plates, social-eating angle
 *
 * Aligns with the locked snap-5 subhead "Chef-inspired menu. (built to
 * share)" — the page expands those two phrases into full sections.
 *
 * Per voice.md "specifics beat adjectives" — but per the user's tap-wall
 * note ("don't get specific, people will hold us to it") the food copy
 * stays generic for now. Claims like "fresh, never frozen" are easy to
 * write and hard to defend at every plate; staying generic is safer
 * until the kitchen team locks the operational truth.
 *
 * TODOs (non-blocking):
 *   - "View the menu" CTAs are placeholder ("#"). GoTab API integration
 *     queued — quick-start says GraphQL + OAuth 2.0 (Client Credentials
 *     or Authorization Code Grant). Menu endpoint + data shape live in
 *     separate docs ("Products & Menus 101"); spike that before building.
 *   - Signature dishes (5 placeholders in section 2) are placeholders;
 *     real dish names/descriptions come with menu integration.
 */
import Base from "../layouts/Base.astro";
import SnapFooter from "../components/snap/SnapFooter.astro";
import { getFood } from "../lib/gotab-food";

// Build-time fetch from GoTab. Fails closed (returns empty menu) if the
// upstream is unreachable — the page still renders, the menu sections just
// don't appear. See src/lib/gotab-food.ts.
const foodMenu = await getFood();
---
<Base
  title="Chef-Inspired Food in Plainfield, IL | Twisted Pin"
  description="Chef-inspired plates built to share — not the food you'd expect at a bowling alley. The kitchen at Twisted Pin, Plainfield IL."
>

  {/* ============================================================
      HERO — typography-led title section (no image)
      ============================================================ */}
  <section class="eat-hero" data-hero aria-labelledby="eat-hero-h1">
    <div class="eat-hero-copy">
      <p class="t-eyebrow hero-fade" data-delay-ms="0">The Kitchen</p>
      <h1 class="t-display eat-hero-headline hero-fade" id="eat-hero-h1" data-delay-ms="120">
        Not&nbsp;the&nbsp;food you'd&nbsp;expect.
      </h1>
      <p class="eat-hero-sub hero-fade" data-delay-ms="320">
        Chef-inspired plates, built to share. The kitchen is the second
        reason to come back. (The bar is the first.)
      </p>
    </div>
  </section>

  {/* ============================================================
      THE KITCHEN — image left, copy right (desktop)
      ============================================================ */}
  <section class="eat-section" aria-labelledby="eat-kitchen-h2">
    <div class="eat-section-grid">
      <div class="eat-section-frame">
        <picture>
          <source type="image/webp" srcset="/snap/stage-eat-600.webp" />
          <img
            class="eat-section-img"
            src="/snap/stage-eat-600.jpg"
            alt="Plates from the Twisted Pin kitchen"
            width="600"
            height="1067"
            loading="lazy"
            decoding="async"
          />
        </picture>
      </div>
      <div class="eat-section-copy">
        <p class="t-eyebrow">The Kitchen</p>
        <h2 class="t-display eat-section-title" id="eat-kitchen-h2">
          Real cooking. No fryer hideout.
        </h2>
        <p class="eat-section-aside">(yes, you can still get fries)</p>

        <p class="eat-section-body">
          Bowling-alley food has a reputation: cardboard pizza, sad
          chicken tenders, the kind of nachos that exist only because
          someone had to put something on the menu. We are aware of
          this reputation. We do not earn it.
        </p>

        <p class="eat-section-body">
          The kitchen runs on a chef-driven menu — plates that taste
          like someone cared, sauces that didn't come out of a #10 can,
          a rotation that changes when the season says it should. Not
          fine dining. Not trying to be. Just food worth eating after
          you bowl, before you bowl, or instead of bowling.
        </p>

        {/* TODO: GoTab API integration. View-only menu link for now. */}
        <a class="btn btn-outline" href="#menu">View the menu</a>
      </div>
    </div>
  </section>

  {/* ============================================================
      BUILT TO SHARE — image RIGHT, copy LEFT (desktop alternation)
      ============================================================ */}
  <section class="eat-section eat-section--reverse" aria-labelledby="eat-share-h2">
    <div class="eat-section-grid">
      <div class="eat-section-frame">
        <picture>
          <source type="image/webp" srcset="/snap/stage-eat-540.webp" />
          <img
            class="eat-section-img"
            src="/snap/stage-eat-540.jpg"
            alt="Shareable plates set for a group at Twisted Pin"
            width="540"
            height="960"
            loading="lazy"
            decoding="async"
          />
        </picture>
      </div>
      <div class="eat-section-copy">
        <p class="t-eyebrow">Built to Share</p>
        <h2 class="t-display eat-section-title" id="eat-share-h2">
          Plates that pass.
        </h2>
        <p class="eat-section-aside">(no one's ordering for themselves)</p>

        <p class="eat-section-body">
          The menu is built around the table, not the place setting.
          Boards, snacks, things you put in the middle and reach for
          while someone's lining up their next throw. Big enough to
          split, small enough to order three of.
        </p>

        <p class="eat-section-body">
          Pairs with the cocktail program on purpose — a few of the
          bar's signatures were specced for the food on this menu, and
          a few of the snacks were specced for the bar. Order both;
          they know each other.
        </p>

        {foodMenu.teaserPicks.length > 0 && (
          <>
            <p class="eat-section-callout">A few staff favorites:</p>
            <ul class="eat-dish-list">
              {foodMenu.teaserPicks.map((it) => (
                <li>
                  <span class="dish-name">{it.name}</span>
                  {it.description && (
                    <span class="dish-desc">{it.description}</span>
                  )}
                </li>
              ))}
            </ul>
          </>
        )}

        <a class="btn btn-outline" href="#menu">View the full menu</a>
      </div>
    </div>
  </section>

  {/* ============================================================
      FOOD MENU — full list grouped by GoTab category.
      Powered by getFood() build-time fetch. Empty when GoTab is
      unreachable (section just doesn't render).
      Layout mirrors /bar #cocktail-menu (compact 2/3/4-col grid,
      square photos, 3-line description clamp).
      ============================================================ */}
  {foodMenu.categories.length > 0 && (
    <section class="food-menu" id="menu" aria-labelledby="food-menu-h2">
      <div class="food-menu-inner">
        <header class="food-menu-header">
          <p class="t-eyebrow">The Menu</p>
          <h2 class="t-display food-menu-title" id="food-menu-h2">
            The whole spread, one scroll.
          </h2>
        </header>

        {foodMenu.categories.map((cat) => (
          <div class="food-category">
            <h3 class="food-category-name">{cat.name}</h3>
            <ul class="food-grid" role="list">
              {cat.items.map((it) => (
                <li class="food-card">
                  {it.imageUrl ? (
                    <div class="food-card-frame">
                      <img
                        src={it.imageUrl}
                        srcset={it.imageUrlLg ? `${it.imageUrl} 480w, ${it.imageUrlLg} 720w` : undefined}
                        sizes="(min-width: 1025px) 270px, (min-width: 700px) 30vw, 46vw"
                        alt={it.name}
                        width="480"
                        height="480"
                        loading="lazy"
                        decoding="async"
                      />
                      {it.isStaffFavorite && (
                        <span class="food-card-badge">Staff Pick</span>
                      )}
                    </div>
                  ) : (
                    <div class="food-card-frame food-card-frame--empty" aria-hidden="true">
                      {it.isStaffFavorite && (
                        <span class="food-card-badge">Staff Pick</span>
                      )}
                    </div>
                  )}
                  <div class="food-card-body">
                    <h4 class="food-card-name">{it.name}</h4>
                    {it.description && (
                      <p class="food-card-description">{it.description}</p>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>
  )}

  <SnapFooter />
</Base>

<style>
  /* ============================================================
     /eat — inner-page rhythm. Mirrors /bar's pattern.
     Reuses global tokens from global.css; no new theme work.
     Class names prefixed `.eat-*` to keep scoped styles distinct from
     `.bar-*` while sharing the same CSS shape — when the third pillar
     lands and the rule-of-three triggers, hoist the shared bits up to
     a `.pillar-*` utility.
     ============================================================ */

  /* ---------- hero (typography-led, no image) ---------- */
  .eat-hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: clamp(420px, 60vh, 560px);
    padding:
      calc(var(--header-height) + 32px) 22px
      calc(var(--bar-pad) + 32px);
  }
  @media (min-width: 1025px) {
    .eat-hero {
      min-height: clamp(440px, 55vh, 640px);
      padding: calc(var(--header-height) + 64px) 64px 64px;
      /* Desktop center — see /bar.astro for full explanation. */
      justify-content: center;
    }
  }

  .eat-hero-copy {
    max-width: 720px;
    color: var(--warm-white);
  }
  @media (min-width: 1025px) {
    .eat-hero-copy {
      text-align: center;
    }
    .eat-hero-sub {
      margin-left: auto;
      margin-right: auto;
    }
  }

  .eat-hero-headline {
    color: var(--warm-white);
    font-size: clamp(28px, 8vw, 56px);
    letter-spacing: -0.005em;
    line-height: 0.95;
    margin-top: 12px;
  }
  @media (min-width: 1025px) {
    .eat-hero-headline { font-size: clamp(48px, 5.2vw, 72px); }
  }

  .eat-hero-sub {
    margin-top: 18px;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.5;
    color: #ece6d6;
    max-width: 32em;
  }
  @media (min-width: 1025px) {
    .eat-hero-sub { margin-top: 22px; font-size: 19px; max-width: 36em; }
  }

  .hero-fade { opacity: 0; transform: translateY(12px); }
  @media (prefers-reduced-motion: reduce) {
    .hero-fade { opacity: 1; transform: none; }
  }

  /* ============================================================
     section pattern (mirrors /bar; will be hoisted to a shared
     `.pillar-section` utility once the third pillar lands and the
     rule of three triggers)
     ============================================================ */
  .eat-section {
    /* Transparent so the global body::before Pin Tilt watermark shows
       through. Hero is now transparent too (no image), so the watermark
       is continuous from page top to footer. */
    background: transparent;
    padding: 56px 22px;
  }
  @media (min-width: 1025px) {
    .eat-section { padding: 96px 64px; }
  }

  .eat-section-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    max-width: 1280px;
    margin: 0 auto;
    align-items: center;
  }
  @media (min-width: 1025px) {
    .eat-section-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
      gap: 64px;
    }
    .eat-section--reverse .eat-section-grid > .eat-section-frame {
      order: 2;
    }
  }

  .eat-section-frame {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-surface);
    aspect-ratio: 4 / 5;
  }
  @media (min-width: 1025px) {
    .eat-section-frame { aspect-ratio: 3 / 4; max-height: 640px; }
  }

  .eat-section-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .eat-section-copy {
    color: var(--warm-white);
    max-width: 36em;
  }

  .eat-section-title {
    color: var(--warm-white);
    font-size: clamp(28px, 7.5vw, 42px);
    line-height: 0.98;
    letter-spacing: -0.005em;
    margin-top: 10px;
  }
  @media (min-width: 1025px) {
    .eat-section-title { font-size: clamp(40px, 4.2vw, 56px); }
  }

  .eat-section-aside {
    margin-top: 6px;
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--warm-dim);
  }
  @media (min-width: 1025px) {
    .eat-section-aside { font-size: 17px; }
  }

  .eat-section-body {
    margin-top: 18px;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    color: var(--warm-mid);
  }
  @media (min-width: 1025px) {
    .eat-section-body { font-size: 17.5px; line-height: 1.65; }
  }

  .eat-section-callout {
    margin-top: 22px;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--warm-white);
    opacity: 0.9;
  }

  .eat-dish-list {
    margin-top: 12px;
    padding-left: 0;
    list-style: none;
  }
  .eat-dish-list li {
    padding: 12px 0;
    border-bottom: 1px solid rgba(244, 239, 227, 0.08);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .dish-name {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: 0.005em;
    color: var(--warm-white);
  }
  .dish-desc {
    font-family: var(--font-body);
    font-size: 14.5px;
    color: var(--warm-dim);
  }
  @media (min-width: 1025px) {
    .dish-name { font-size: 22px; }
    .dish-desc { font-size: 16px; }
  }

  .eat-section-copy .btn {
    margin-top: 28px;
  }

  /* The closing CTA band (.eat-cta) was removed 2026-05-04 — same
     reasoning as /bar. Sticky bar carries Reserve / Plan; SnapFooter
     handles the "find us" beat at the bottom. */

  /* ============================================================
     FOOD MENU — mirrors /bar #cocktail-menu styling. When the
     rule-of-three triggers (third menu pillar lands), hoist the
     shared bits up to a `.menu-*` utility.
     ============================================================ */
  .food-menu {
    background: transparent;
    padding: 56px 22px 72px;
  }
  @media (min-width: 1025px) {
    .food-menu { padding: 96px 64px 120px; }
  }

  .food-menu-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .food-menu-header {
    margin-bottom: 40px;
    color: var(--warm-white);
    max-width: 36em;
  }
  @media (min-width: 1025px) {
    .food-menu-header { margin-bottom: 56px; }
  }

  .food-menu-title {
    color: var(--warm-white);
    font-size: clamp(28px, 7.5vw, 42px);
    line-height: 0.98;
    letter-spacing: -0.005em;
    margin-top: 10px;
  }
  @media (min-width: 1025px) {
    .food-menu-title { font-size: clamp(40px, 4.2vw, 56px); }
  }

  .food-category + .food-category {
    margin-top: 56px;
  }
  @media (min-width: 1025px) {
    .food-category + .food-category { margin-top: 88px; }
  }

  .food-category-name {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(20px, 5vw, 26px);
    text-transform: uppercase;
    letter-spacing: 0.01em;
    color: var(--warm-white);
    margin: 0 0 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(244, 239, 227, 0.14);
  }
  @media (min-width: 1025px) {
    .food-category-name {
      font-size: 32px;
      margin-bottom: 28px;
      padding-bottom: 16px;
    }
  }

  .food-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px 12px;
  }
  @media (min-width: 700px) {
    .food-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 28px 20px;
    }
  }
  @media (min-width: 1025px) {
    .food-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 32px 24px;
    }
  }

  .food-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .food-card-frame {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-surface);
    aspect-ratio: 1 / 1;
    background: rgba(244, 239, 227, 0.04);
  }

  /* Some food items in GoTab don't have photos (Bottled Water, juice boxes,
     a few sides). The frame stays rendered with the placeholder background
     so the grid stays geometrically uniform — name+description still read
     as a card; absence of a photo doesn't break the row. */
  .food-card-frame--empty {
    background:
      linear-gradient(135deg, rgba(244, 239, 227, 0.04), rgba(244, 239, 227, 0.02));
  }

  .food-card-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .food-card-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--indigo-deep);
    background: var(--glow);
    padding: 5px 9px;
    border-radius: 4px;
    line-height: 1;
  }

  .food-card-body {
    padding: 0 2px;
  }

  .food-card-name {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    color: var(--warm-white);
    margin: 0 0 4px;
    line-height: 1.1;
  }
  @media (min-width: 700px) {
    .food-card-name { font-size: 17px; }
  }
  @media (min-width: 1025px) {
    .food-card-name { font-size: 18px; }
  }

  .food-card-description {
    margin: 0;
    font-family: var(--font-body);
    font-size: 12.5px;
    line-height: 1.4;
    color: var(--warm-dim);
    /* Clamp to 3 lines so card heights stay regular across items with
       wildly different description lengths. Full text remains in the
       DOM for SEO / accessibility. */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (min-width: 1025px) {
    .food-card-description { font-size: 13.5px; }
  }
</style>
