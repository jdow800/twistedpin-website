---
/**
 * /events — Group Events pillar page.
 *
 * **The most important unbuilt page on the site** per Context/seo.md and
 * Context/launch-checklist.md — ad spend lands here for the
 * `corporate event venue near me` / `event spaces near me` /
 * `adult birthday party venue` / `team building venue` clusters that
 * drive $2K-$10K+ bookings (40% of corporate leads via Google).
 *
 * Strategy: pre-qualify + persuade, then hand off to Zite. The Zite app
 * (currently `twistedevents.zite.so`) is the inquiry form + facility tour; this
 * page is the brand-voiced landing layer above it. A direct redirect
 * to Zite would convert the bottom-of-funnel (already-decided users)
 * but waste the top-of-funnel (researchers needing to learn what we
 * offer first). Landing page filters AND educates → higher-intent form
 * fills, fewer junk submissions, plus organic SEO that a redirect can't
 * earn.
 *
 * Same skeleton as /bar /eat /vip-suite (rule of four — .pillar-* CSS
 * hoist is now overdue):
 *   - Hero: typography-led title section (no image)
 *   - Two long-scroll editorial sections (image + copy, alternating)
 *   - Closing CTA band (NEW pattern for this page — single dominant
 *     "Plan an event" CTA → Zite)
 *   - SnapFooter
 *
 * Voice rules applied (per Context/voice.md):
 *   - Brian Van Flandern named only as "America's Top Mixologist"
 *     credential, in service of "the bar program is the same one
 *     designed by..." (allowed mention per voice.md)
 *   - "private" hard-banned — used "take over," "yours for the night,"
 *     "set apart from the main floor"
 *   - Specifics > adjectives — 6-lane VIP suite, up to 80, 28 self-serve
 *     taps, 50% of bowling revenue back to fundraiser hosts
 *   - Adults-first, not Chuck E Cheese
 *
 * TODOs (non-blocking):
 *   - Capacity numbers for full-venue buyouts not yet confirmed by ops.
 *     "More for full-venue buyouts" hand-waves until ops gives a number.
 *   - Section photos reuse homepage events-bg + cocktails-bg shots.
 *     Distinct event-energy photography flagged in Context/media-needs.md.
 *   - Real success-story content (e.g. "X companies hosted last quarter")
 *     would land hard but not in scope until ops gives numbers.
 */
import Base from "../layouts/Base.astro";
import SnapFooter from "../components/snap/SnapFooter.astro";
import BreadcrumbSchema from "../components/BreadcrumbSchema.astro";
import { localBusinessBase, BUSINESS_URL } from "../lib/schema";

// Zite-hosted group events platform. May get a vanity subdomain
// (events.twistedpin.com) later; URL not yet final.
const ZITE_URL = "https://twistedevents.zite.so/";

// JSON-LD: EventVenue subtype on the canonical venue @id. Tells AI
// "the venue, viewed as an event venue" — same multi-faceted entity
// as the BarOrPub / BowlingAlley / Restaurant / EntertainmentBusiness
// declarations on other pages. The VIP suite gets its own @id
// (#vip-suite) on /vip-suite — that's the contained-place with the
// specific capacity claim.
const PAGE_URL = `${BUSINESS_URL}/events/`;
const eventVenueSchema = {
  ...(await localBusinessBase({
    url: PAGE_URL,
    image: `${BUSINESS_URL}/snap/events-bg-600.webp`,
    description:
      "Group events at Twisted Pin: take over the 6-lane VIP suite, custom catering, craft cocktails. Adult birthdays, corporate offsites, fundraisers, holiday parties. Plainfield, IL.",
  })),
  "@type": "EventVenue",
};
---
<Base
  title="Group Events in Plainfield, IL | Twisted Pin"
  description="VIP suite for up to 80, custom catering, craft cocktails. Adult birthdays, corporate offsites, fundraisers, holiday parties — Plainfield, IL."
  ogImage="/og/og-events.jpg"
  ogImageAlt="A group event at Twisted Pin in Plainfield, IL"
>

  {/* ============================================================
      HERO — typography-led title section (no image)
      ============================================================ */}
  <section class="events-hero" data-hero aria-labelledby="events-hero-h1">
    <div class="events-hero-copy">
      <p class="t-eyebrow hero-fade" data-delay-ms="0">Group Events</p>
      <h1 class="t-display events-hero-headline hero-fade" id="events-hero-h1" data-delay-ms="120">
        Events that don't&nbsp;suck.
      </h1>
      <p class="events-hero-sub hero-fade" data-delay-ms="320">
        Take over the 6-lane VIP suite. In-house catering. The bar program
        your guests will text you about the next morning.
      </p>
    </div>
  </section>

  {/* ============================================================
      WHAT YOU CAN HOST — image left, copy right
      ============================================================ */}
  <section class="events-section" aria-labelledby="events-host-h2">
    <div class="events-section-grid">
      <div class="events-section-frame">
        {/* Buffet "before & after" video — autoplay-muted-loop in the
            editorial frame, same single-active-video rule as the
            homepage Tap Wall via sectionVideo() in motion.client.ts.
            data-src lazy-promotion: bytes don't load until the section
            enters the viewport. Encoded by scripts/build-buffet-video.sh. */}
        <video
          class="events-section-img"
          data-section-video
          preload="none"
          muted
          loop
          playsinline
          data-poster="/snap/buffet-poster.webp"
          aria-label="A buffet of catering food set up for a group event at Twisted Pin"
        >
          <source media="(max-width: 480px)" data-src="/snap/buffet-mobile-av1-540.mp4"  type="video/mp4; codecs=av01.0.05M.08" />
          <source media="(max-width: 480px)" data-src="/snap/buffet-mobile-h264-540.mp4" type="video/mp4" />
          <source data-src="/snap/buffet-mobile-av1-1080.mp4"  type="video/mp4; codecs=av01.0.05M.08" />
          <source data-src="/snap/buffet-mobile-h264-1080.mp4" type="video/mp4" />
        </video>
      </div>
      <div class="events-section-copy">
        <p class="t-eyebrow">What You Can Host</p>
        <h2 class="t-display events-section-title" id="events-host-h2">
          Birthdays. Corporate. Fundraisers.
        </h2>
        <p class="events-section-aside">(or whatever you can talk us into)</p>

        <p class="events-section-body">
          Adult birthdays. Corporate offsites and holiday parties.
          Fundraisers, retirements, after-parties of after-parties — if
          it's a group of adults that wants to have a night, we can host it.
          Bridal showers, gender reveals, graduation parties, kids' birthdays
          too.
        </p>

        <p class="events-section-body">
          Fundraisers get a real package: <strong>50% of bowling, shoe,
          and arcade revenue back to your organization</strong>, Thursday
          nights 5–9pm. Schools, churches, community groups. <a href="/fundraisers/">Full fundraiser details →</a>
        </p>

        <ul class="events-section-list">
          <li>Adult birthday parties</li>
          <li>Corporate offsites + team building</li>
          <li>Holiday parties (December books fast — reach out by October)</li>
          <li><a href="/fundraisers/">Fundraisers</a> — 50% back to the host</li>
          <li>Retirements + farewells</li>
          <li>After-parties + group functions</li>
          <li>Bridal showers + gender reveals</li>
          <li>Graduation parties</li>
          <li>Kids' birthday parties</li>
        </ul>
      </div>
    </div>
  </section>

  {/* ============================================================
      WHY IT WORKS — image RIGHT, copy LEFT (alternation)
      ============================================================ */}
  <section class="events-section events-section--reverse" aria-labelledby="events-why-h2">
    <div class="events-section-grid">
      <div class="events-section-frame">
        <picture>
          <source type="image/webp" srcset="/snap/bar-cocktails-540.webp 540w, /snap/bar-cocktails-900.webp 900w" sizes="(min-width: 1025px) 480px, 90vw" />
          <img
            class="events-section-img"
            src="/snap/bar-cocktails-540.jpg"
            srcset="/snap/bar-cocktails-540.jpg 540w, /snap/bar-cocktails-900.jpg 900w"
            sizes="(min-width: 1025px) 480px, 90vw"
            alt="A copper cocktail shaker mid-pour at Twisted Pin's bar"
            width="540"
            height="960"
            loading="lazy"
            decoding="async"
          />
        </picture>
      </div>
      <div class="events-section-copy">
        <p class="t-eyebrow">Why It Works</p>
        <h2 class="t-display events-section-title" id="events-why-h2">
          Six lanes set apart. The bar and kitchen take care of the rest.
        </h2>

        <p class="events-section-body">
          The 6-lane VIP suite sits behind a wall, set apart from the
          traditional lanes — semi-private, yours when you book it. Up
          to 80 people. LED video wall for slideshows, sports, or
          whatever you want playing. AV solutions available. Couch
          seating wraps the lanes for the people who'd rather watch than
          throw.
        </p>

        <p class="events-section-body">
          The 28-tap self-serve wall sits next door. The cocktail bar
          runs the program curated by Brian Van Flandern,
          <em>America's Top Mixologist</em> — same drinks, same
          execution as the rest of the venue. The kitchen handles custom
          catering through the night.
        </p>

        <p class="events-section-body">
          Run a tab or hand out drink tickets — pick whatever billing
          model fits your group.
        </p>

        <ul class="events-section-list">
          <li>6-lane VIP suite, up to 80 (more for full-venue buyouts)</li>
          <li>28-tap self-serve beer &amp; wine wall</li>
          <li>Cocktail program curated by Brian Van Flandern</li>
          <li>Custom catering through the kitchen</li>
          <li>Run a tab or drink tickets — your call</li>
          <li>LED video wall + AV solutions</li>
        </ul>
      </div>
    </div>
  </section>

  {/* ============================================================
      CLOSING CTA BAND — single dominant "Plan an event" → Zite.
      Different visual treatment from the editorial sections (lifted
      indigo, centered, spacious) so the conversion moment lands as
      a moment, not as another scroll beat.
      ============================================================ */}
  <section class="events-cta" aria-labelledby="events-cta-h2">
    <div class="events-cta-inner">
      <p class="t-eyebrow">Tell Us What You Want</p>
      <h2 class="t-display events-cta-title" id="events-cta-h2">
        We'll set it up.
      </h2>
      <p class="events-cta-body">
        Quick form. Tour the venue, see the suite, get a quote.
      </p>
      <a class="btn btn-solid events-cta-btn" href={ZITE_URL} target="_blank" rel="noopener">
        Plan an event
      </a>
    </div>
  </section>

  <SnapFooter />

  <script type="application/ld+json" set:html={JSON.stringify(eventVenueSchema)} />
  <BreadcrumbSchema crumbs={[
    { name: "Home", path: "/" },
    { name: "Events", path: "/events/" },
  ]} />
</Base>

<style>
  /* ============================================================
     /events — same pillar skeleton as /bar /eat /vip-suite for
     hero + editorial sections, plus a NEW closing CTA band pattern
     specific to this page (highest-conversion page on the site).
     Class names .events-* mirror .bar-* / .eat-* / .vip-* / .waitlist-* —
     rule of four hit; .pillar-* CSS hoist overdue (flagged in
     Context/launch-checklist.md tech debt).
     ============================================================ */

  /* ---------- hero (typography-led, no image) ---------- */
  .events-hero {
    position: relative;
    display: flex;
    align-items: center;
    /* Match t2-hero — see /bar.astro for rationale. */
    min-height: clamp(320px, 42vh, 420px);
    padding: calc(var(--header-height) + 28px) 22px 24px;
  }
  @media (min-width: 1025px) {
    .events-hero {
      min-height: clamp(440px, 55vh, 640px);
      padding: calc(var(--header-height) + 64px) 64px 64px;
      justify-content: center;
    }
  }

  .events-hero-copy {
    max-width: 760px;
    color: var(--warm-white);
  }
  @media (min-width: 1025px) {
    .events-hero-copy { text-align: center; }
    .events-hero-sub { margin-left: auto; margin-right: auto; }
  }

  .events-hero-headline {
    color: var(--warm-white);
    font-size: clamp(34px, 10vw, 64px);
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-top: 12px;
  }
  @media (min-width: 1025px) {
    .events-hero-headline { font-size: clamp(56px, 6vw, 88px); }
  }

  .events-hero-sub {
    margin-top: 18px;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.5;
    color: #ece6d6;
    max-width: 34em;
  }
  @media (min-width: 1025px) {
    .events-hero-sub { margin-top: 22px; font-size: 19px; max-width: 38em; }
  }

  /* .hero-fade hoisted to global.css (2026-05-08 LCP fix). */

  /* ============================================================
     section pattern (same shape as .vip-section etc.)
     ============================================================ */
  .events-section {
    background: transparent; /* Pin Tilt watermark shows through */
    /* Tightened — see /bar.astro for rationale. */
    padding: 5px 22px;
  }
  @media (min-width: 1025px) {
    .events-section { padding: 24px 64px; }
  }

  .events-section-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    max-width: 1280px;
    margin: 0 auto;
    align-items: start;
  }
  @media (min-width: 1025px) {
    .events-section-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
      gap: 64px;
    }
    .events-section--reverse .events-section-grid > .events-section-frame {
      order: 2;
    }
  }

  .events-section-frame {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-surface);
    aspect-ratio: 4 / 5;
  }
  @media (min-width: 1025px) {
    .events-section-frame { aspect-ratio: 3 / 4; max-height: 640px; }
  }

  .events-section-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .events-section-copy {
    color: var(--warm-white);
    max-width: 36em;
  }

  .events-section-title {
    color: var(--warm-white);
    font-size: clamp(28px, 7.5vw, 42px);
    line-height: 0.98;
    letter-spacing: -0.005em;
    margin-top: 10px;
  }
  @media (min-width: 1025px) {
    .events-section-title { font-size: clamp(40px, 4.2vw, 56px); }
  }

  .events-section-aside {
    margin-top: 6px;
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--warm-dim);
  }
  @media (min-width: 1025px) {
    .events-section-aside { font-size: 17px; }
  }

  .events-section-body {
    margin-top: 18px;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    color: var(--warm-mid);
  }
  @media (min-width: 1025px) {
    .events-section-body { font-size: 17.5px; line-height: 1.65; }
  }

  .events-section-body strong {
    color: var(--warm-white);
    font-weight: 700;
  }

  .events-section-list {
    margin-top: 22px;
    padding-left: 0;
    list-style: none;
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--warm-white);
  }
  .events-section-list li {
    padding: 8px 0 8px 22px;
    border-bottom: 1px solid rgba(244, 239, 227, 0.08);
    position: relative;
  }
  .events-section-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--glow);
    opacity: 0.85;
  }

  /* ============================================================
     CLOSING CTA BAND — distinct from editorial sections.
     Lifted indigo background gives the conversion moment its own
     visual presence (vs the transparent editorial sections that let
     the watermark show through). Centered content, prominent CTA.
     This is the "moment that earns its space" pattern from
     visual-direction.md.
     ============================================================ */
  .events-cta {
    /* Lifted indigo — slight elevation from the editorial body. Not
       a gradient (we removed those per visual-direction.md), just a
       solid that's marginally lighter than the indigo-deep page bg. */
    background: rgba(26, 21, 48, 0.92);
    border-top: 1px solid rgba(244, 239, 227, 0.06);
    padding: 72px 22px 88px;
  }
  @media (min-width: 1025px) {
    .events-cta { padding: 112px 64px 128px; }
  }

  .events-cta-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    color: var(--warm-white);
  }

  .events-cta-title {
    color: var(--warm-white);
    font-size: clamp(36px, 9vw, 56px);
    line-height: 0.98;
    letter-spacing: -0.005em;
    margin-top: 10px;
  }
  @media (min-width: 1025px) {
    .events-cta-title { font-size: clamp(56px, 5vw, 72px); }
  }

  .events-cta-body {
    margin-top: 18px;
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.5;
    color: var(--warm-mid);
    max-width: 32em;
    margin-left: auto;
    margin-right: auto;
  }
  @media (min-width: 1025px) {
    .events-cta-body { font-size: 19px; }
  }

  .events-cta-btn {
    margin-top: 32px;
    /* Slightly bigger than default button to land as the page's
       conversion moment — not a sticky-bar-sized button. */
    padding: 16px 32px;
    font-size: 14px;
    letter-spacing: 0.16em;
  }
  @media (min-width: 1025px) {
    .events-cta-btn { padding: 18px 40px; font-size: 15px; }
  }
</style>
