---
/**
 * /leagues — Bowling leagues page.
 *
 * Tier-2 utility page. Live twistedpin.com/leagues/ exists but the
 * actual league schedule + signup form are JS-rendered (couldn't
 * scrape via curl). Page acknowledges leagues exist + lists service
 * area + provides contact path until ops gives the schedule.
 *
 * Service area pulled verbatim from live page intro: "Plainfield,
 * Joliet, Romeoville, Naperville, Shorewood, Lockport, Crest Hill
 * and beyond" — this Will County coverage is SEO-relevant per
 * Context/seo.md (Naperville is the #1 paid market, near-zero
 * organic presence to capture).
 *
 * TODOs (non-blocking):
 *   - League schedule (nights, season dates, format, prices) pending
 *     ops. Page will need a real schedule block before launch.
 *   - Signup form / contact email — currently routes to
 *     contactus@twistedpin.com per the SnapFooter pattern.
 *   - When ops provides the schedule, this page graduates from a
 *     tier-2 stub into a content-heavy page (probably gets the
 *     pillar treatment with sections per league type).
 */
import Base from "../layouts/Base.astro";
import SnapFooter from "../components/snap/SnapFooter.astro";
---
<Base
  title="Bowling Leagues in Plainfield IL — Twisted Pin"
  description="Mixed leagues, casual and competitive, all skill levels. Will County league bowlers welcome — Plainfield, Joliet, Romeoville, Naperville, Shorewood and beyond."
>

  <section class="t2-hero" data-hero aria-labelledby="leagues-h1">
    <div class="t2-hero-copy">
      <p class="t-eyebrow hero-fade" data-delay-ms="0">Leagues</p>
      <h1 class="t-display t2-hero-headline hero-fade" id="leagues-h1" data-delay-ms="120">
        Find your league.
      </h1>
      <p class="t2-hero-sub hero-fade" data-delay-ms="320">
        Casual to competitive. Mixed nights, themed nights, scratch
        leagues. Will County bowlers welcome.
      </p>
    </div>
  </section>

  <section class="t2-section" aria-labelledby="leagues-h2">
    <div class="t2-section-inner">
      <h2 class="t-eyebrow" id="leagues-h2" style="font-size:11px;">Service Area</h2>
      <p class="t2-section-body">
        We host league bowlers from across Will County — Plainfield,
        Joliet, Romeoville, Naperville, Shorewood, Lockport, Crest
        Hill, and beyond.
      </p>

      <p class="t2-section-body">
        <strong>League schedule and signups</strong> change by season.
        For current openings, league nights, and format, email
        <a href="mailto:contactus@twistedpin.com">contactus@twistedpin.com</a>
        or call the front desk.
      </p>

      <p class="t2-section-body">
        Looking for fundraiser leagues or one-time group bookings instead?
        <a href="/events/">See group events →</a>
      </p>
    </div>
  </section>

  <SnapFooter />
</Base>
