---
/**
 * /privacy — Privacy Policy.
 *
 * Updated 2026-05-13: analytics disclosure rewritten post-migration.
 *   - Removed Google Analytics claim (GA4 deferred until ad campaigns
 *     start; not currently installed)
 *   - Added Vercel Web Analytics disclosure (cookieless pageview data;
 *     Vercel, Inc. as data processor)
 *   - Added Microsoft Clarity disclosure (cookieless session replay +
 *     heatmaps; Microsoft Corporation as data processor; sensitive form
 *     fields auto-masked)
 *   - Section 4 service-provider list expanded to include website
 *     hosting and analytics platforms
 *
 * Updated 2026-05-08: substantive rewrite to support SMS messaging
 * approval. Major additions:
 *   - Dow Holdings Inc named as the operating legal entity
 *   - Verbal phone opt-in path documented (Section 3) — AI receptionist
 *     captures consent during calls; logged with timestamp + recording
 *   - CTIA-mandated "no mobile sharing for marketing" boilerplate
 *   - AI communication agents/platforms disclosed under service providers
 *   - Subcontractor categories enumerated for SMS opt-in data scope
 *
 * Voice cleanup applied:
 *   - Tightened section headings to t2 register
 *   - Long paragraphs broken into scannable bullets where possible
 *
 * Legal note: This is the working draft for SMS messaging program
 * approval. Counsel should confirm pre-launch — at minimum to verify
 * the disclosures match current data flows (the integrations: GoTab,
 * Untappd, Roller, TablesReady, Vercel hosting, Vercel Web Analytics,
 * Microsoft Clarity, Google Places, Heyflow, Zite, Freshdesk, AI
 * receptionist).
 */
import Base from "../layouts/Base.astro";
import SnapFooter from "../components/snap/SnapFooter.astro";
import BreadcrumbSchema from "../components/BreadcrumbSchema.astro";

const LAST_UPDATED = "May 13, 2026";
---
<Base
  title="Privacy Policy | Twisted Pin"
  description="How Twisted Pin collects, uses, and protects personal information from website, event, phone, and SMS interactions. Plainfield, IL."
>

  <section class="t2-hero" data-hero aria-labelledby="privacy-h1">
    <div class="t2-hero-copy">
      <p class="t-eyebrow hero-fade" data-delay-ms="0">Twisted Pin</p>
      <h1 class="t-display t2-hero-headline hero-fade" id="privacy-h1" data-delay-ms="120">
        Privacy Policy.
      </h1>
      <p class="t2-hero-sub hero-fade" data-delay-ms="320">
        Last updated {LAST_UPDATED}. How we handle your information when
        you visit twistedpin.com, submit an event inquiry, call our
        business phone line, or interact with our SMS messaging program.
      </p>
    </div>
  </section>

  <section class="t2-section legal-section" aria-labelledby="privacy-h2-1">
    <div class="t2-section-inner">
      <p class="legal-preamble">
        Twisted Pin ("Twisted Pin," "we," "us," "our") is a brand operated
        by Dow Holdings Inc, an Illinois corporation. We are committed to
        protecting your privacy. This Privacy Policy explains how we
        collect, use, and protect your personal information when you
        visit our website at twistedpin.com, submit an event inquiry,
        call our business phone line, or interact with our SMS messaging
        program.
      </p>

      <h2 class="legal-h2" id="privacy-h2-1">1. Information We Collect</h2>
      <p>We collect information you provide directly to us, including:</p>
      <ul>
        <li><strong>Contact information:</strong> name, phone number, and email address submitted through our event inquiry form or provided during a phone call</li>
        <li><strong>Event details:</strong> event type, date, estimated guest count, and any special requests</li>
        <li><strong>Communications:</strong> messages you send us via SMS, email, or contact forms, and information shared during phone calls with our business line</li>
        <li><strong>Website usage data:</strong> IP address, browser type, pages visited, and referring URLs collected automatically via cookies and analytics tools</li>
      </ul>

      <h2 class="legal-h2" id="privacy-h2-2">2. How We Use Your Information</h2>
      <p>We use the information we collect to:</p>
      <ul>
        <li>Respond to your event inquiry and provide custom pricing and availability information</li>
        <li>Send SMS messages related to your inquiry or call, including informational links, quotes, booking confirmations, and event reminders</li>
        <li>Process and manage your event booking</li>
        <li>Improve our website, services, and customer experience</li>
        <li>Comply with legal obligations</li>
      </ul>

      <h2 class="legal-h2" id="privacy-h2-3">3. SMS Messaging Program</h2>
      <p>You may consent to receive SMS messages from Twisted Pin in one of two ways:</p>
      <p><strong>(a)</strong> By submitting an event inquiry form on our website and opting in to SMS communications related to your inquiry; or</p>
      <p><strong>(b)</strong> By verbally requesting information (such as pricing, hours, directions, or location) during a phone call to our business line, at which point we may send a single informational text message containing the requested link.</p>

      <p>Regarding our SMS program:</p>
      <ul>
        <li>We send SMS messages only in response to your inquiry, request, or booking — including quotes, availability, booking details, informational links, and customer service follow-up</li>
        <li>We do not send unsolicited promotional SMS messages</li>
        <li>Message frequency varies based on your inquiry or request</li>
        <li>Message and data rates may apply</li>
        <li>You may opt out at any time by replying STOP to any message</li>
        <li>Reply HELP for assistance</li>
      </ul>

      <p>No mobile information will be shared with third parties or affiliates for marketing or promotional purposes. Information sharing with subcontractors in support of services we provide (such as SMS delivery platforms, AI communication agents, and customer service vendors) is permitted solely to deliver the services you have requested. All other categories exclude text messaging originator opt-in data and consent; this information will not be shared with any third parties.</p>

      <h2 class="legal-h2" id="privacy-h2-4">4. How We Share Your Information</h2>
      <p>We do not sell, trade, or rent your personal information to third parties. We may share your information only in the following limited circumstances:</p>
      <ul>
        <li><strong>Service providers:</strong> trusted vendors who help us operate our business (such as website hosting, booking software, payment processors, analytics platforms, AI communication platforms, and SMS delivery providers), bound by confidentiality agreements</li>
        <li><strong>Legal requirements:</strong> when required by law or to protect the rights and safety of Twisted Pin, Dow Holdings Inc, or others</li>
        <li><strong>Business transfers:</strong> in connection with a merger, acquisition, or sale of assets, with notice provided to you</li>
      </ul>

      <h2 class="legal-h2" id="privacy-h2-5">5. Analytics and Session Recording</h2>
      <p>To understand how visitors interact with our website, we use two analytics tools. Both are cookieless and do not track you across other websites for advertising purposes.</p>
      <ul>
        <li><strong>Vercel Web Analytics</strong> (operated by Vercel, Inc.): collects aggregated pageview data including pages visited, referring URLs, device type, browser, and approximate geographic region derived from IP address.</li>
        <li><strong>Microsoft Clarity</strong> (operated by Microsoft Corporation): collects session replay data including mouse movement, click patterns, scroll behavior, IP address, and aggregated heatmaps showing how visitors interact with each page. Sensitive form fields (such as passwords or payment information) are automatically masked from recordings.</li>
      </ul>
      <p>Neither tool collects personal information such as names, addresses, or email addresses you enter into form fields. Data collected by these tools is processed by their respective operators (Vercel, Inc. and Microsoft Corporation) under their own privacy policies. We do not sell, share, or rent analytics data to third parties beyond these service providers.</p>
      <p>If you wish to opt out of analytics tracking on our site, you may use browser extensions that block third-party scripts (such as uBlock Origin or Privacy Badger), or enable a tracking protection feature in your browser settings.</p>

      <h2 class="legal-h2" id="privacy-h2-6">6. Data Retention</h2>
      <p>We retain your personal information for as long as necessary to fulfill the purposes described in this policy, including completing your event booking and maintaining records for legal and accounting purposes. Event inquiry data is typically retained for up to 3 years. You may request deletion of your data at any time (see Section 8).</p>

      <h2 class="legal-h2" id="privacy-h2-7">7. Data Security</h2>
      <p>We implement reasonable technical and organizational measures to protect your personal information from unauthorized access, disclosure, or misuse. In the event of a data breach that affects your personal information, we will notify you via email within a reasonable timeframe as required by applicable law.</p>

      <h2 class="legal-h2" id="privacy-h2-8">8. Your Rights</h2>
      <p>You have the right to:</p>
      <ul>
        <li>Request a copy of the personal information we hold about you</li>
        <li>Request correction of inaccurate information</li>
        <li>Request deletion of your personal information (subject to legal retention requirements)</li>
        <li>Opt out of SMS communications at any time by replying STOP</li>
        <li>Request that we not use your information for marketing purposes</li>
      </ul>
      <p>To exercise any of these rights, contact us using the information in Section 10.</p>

      <h2 class="legal-h2" id="privacy-h2-9">9. Children's Privacy</h2>
      <p>Our website and services are not directed to children under the age of 13. We do not knowingly collect personal information from children under 13. If you believe we have inadvertently collected such information, please contact us immediately and we will promptly delete it.</p>

      <h2 class="legal-h2" id="privacy-h2-10">10. Contact Us</h2>
      <p>For questions about this Privacy Policy, to exercise your data rights, or for any privacy-related concerns, please contact us:</p>
      <ul class="legal-contact">
        <li><strong>Business:</strong> Twisted Pin (operated by Dow Holdings Inc)</li>
        <li><strong>Address:</strong> 15610 Joliet Rd, Plainfield, IL 60544</li>
        <li><strong>Phone:</strong> 815-782-7790</li>
        <li><strong>Email:</strong> <a href="mailto:contactus@twistedpin.com">contactus@twistedpin.com</a></li>
        <li><strong>Website:</strong> <a href="/">twistedpin.com</a></li>
      </ul>

      <h2 class="legal-h2" id="privacy-h2-11">11. Changes to This Policy</h2>
      <p>We may update this Privacy Policy from time to time. When we do, we will revise the "Last Updated" date at the top of this page. We encourage you to review this policy periodically. Continued use of our website or SMS program after changes are posted constitutes your acceptance of the updated policy.</p>

      <p class="legal-jurisdiction">Twisted Pin is located in Plainfield, Illinois and serves the greater Chicagoland area. Our SMS program is operated in compliance with TCPA regulations and CTIA messaging guidelines.</p>
    </div>
  </section>

  <SnapFooter />
  <BreadcrumbSchema crumbs={[
    { name: "Home", path: "/" },
    { name: "Privacy", path: "/privacy/" },
  ]} />
</Base>

<style>
  /* Legal pages share a vocabulary — tighter line-height, scannable
     section breaks, dim long-form copy on indigo. Same recipe for
     /privacy and /terms. */
  .legal-section .t2-section-inner {
    max-width: 720px;
  }

  /* Preamble paragraph — sits before Section 1, sets the legal-entity
     and scope context. Slightly heavier than body to mark its role. */
  .legal-preamble {
    font-family: var(--font-body);
    font-size: 15.5px;
    line-height: 1.65;
    color: var(--warm-mid);
    margin: 0 0 24px;
    padding: 16px 18px;
    background: rgba(244, 239, 227, 0.04);
    border-left: 2px solid var(--glow);
    border-radius: 0 8px 8px 0;
  }

  .legal-h2 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 22px;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    color: var(--warm-white);
    margin: 40px 0 14px;
  }
  .legal-h2:first-child { margin-top: 8px; }
  @media (min-width: 760px) {
    .legal-h2 { font-size: 26px; margin-top: 48px; }
  }

  .legal-section p,
  .legal-section li {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.6;
    color: var(--warm-mid);
  }
  .legal-section p { margin: 0 0 14px; }

  .legal-section ul {
    margin: 0 0 14px;
    padding-left: 22px;
  }
  .legal-section li { margin-bottom: 6px; }

  .legal-section strong { color: var(--warm-white); font-weight: 700; }

  .legal-section a {
    color: var(--glow);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .legal-contact {
    list-style: none;
    padding-left: 0;
  }

  .legal-jurisdiction {
    margin-top: 32px;
    padding-top: 20px;
    border-top: 1px solid rgba(244, 239, 227, 0.10);
    font-size: 13px !important;
    color: var(--warm-dim) !important;
    font-style: italic;
  }
</style>
