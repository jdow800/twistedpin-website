---
/**
 * /upcoming-events — public event calendar.
 *
 * Reads from the `events` content collection (src/content/events/*.md).
 * Adding an event = drop a markdown file with frontmatter and push.
 * Daily 4am cron rebuild keeps the page fresh; past events fall off
 * automatically after their end (or start, if no end) is in the past.
 *
 * Layout: typography hero → month-grouped cards → bottom hand-off
 * (host-your-own-night + leagues). Empty state replaces the cards
 * grid when nothing is scheduled.
 *
 * Per launch-checklist.md: legacy /event-directory/ also gets a 301
 * to /upcoming-events/ at launch (consolidation).
 */
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import SnapFooter from "../components/snap/SnapFooter.astro";
import BreadcrumbSchema from "../components/BreadcrumbSchema.astro";
import { BUSINESS_URL, eventSchema } from "../lib/schema";
import { PLAN_EVENT_URL } from "../lib/links";

// At-build cutoff: an event is "past" when its end (or start, if no
// end) is before today. Cron rebuilds nightly at 9 UTC so this re-runs
// once a day in production — close enough to "live."
//
// Lookahead window: events also have to start within LOOKAHEAD_DAYS to
// surface here. Keeps the calendar focused on imminent nights instead
// of advertising things 6+ months out (NYE etc.) all year. The seasonal
// nav system also gates promotion of those pages independently. If a
// specific event ever needs a longer runway, add an optional
// `lookaheadDays` field in the markdown frontmatter and override here.
const LOOKAHEAD_DAYS = 60;
const now = new Date();
const lookaheadCutoff = new Date(now.getTime() + LOOKAHEAD_DAYS * 24 * 60 * 60 * 1000);

const events = (await getCollection("events"))
  .filter((e) => !e.data.draft)
  .filter((e) => {
    const cutoff = e.data.end ?? e.data.start;
    return cutoff >= now;
  })
  .filter((e) => e.data.start <= lookaheadCutoff)
  .sort((a, b) => a.data.start.getTime() - b.data.start.getTime());

// Group by year-month (UTC keys for stability across DST).
type Group = { key: string; label: string; events: typeof events };
const groups: Group[] = [];
const monthFmt = new Intl.DateTimeFormat("en-US", {
  month: "long",
  year: "numeric",
});
for (const e of events) {
  const d = e.data.start;
  const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;
  const label = monthFmt.format(d).toUpperCase();
  let g = groups.find((x) => x.key === key);
  if (!g) {
    g = { key, label, events: [] };
    groups.push(g);
  }
  g.events.push(e);
}

const monthShort = (d: Date) =>
  new Intl.DateTimeFormat("en-US", { month: "short" }).format(d).toUpperCase();
const dayNum = (d: Date) => String(d.getDate());

// Day block — handles single day, multi-day same-month, multi-day cross-month.
function dayBlock(start: Date, end?: Date) {
  if (!end || sameDay(start, end)) {
    return { day: dayNum(start), month: monthShort(start), range: false };
  }
  const sameMonth =
    start.getMonth() === end.getMonth() && start.getFullYear() === end.getFullYear();
  if (sameMonth) {
    return {
      day: `${dayNum(start)}–${dayNum(end)}`,
      month: monthShort(start),
      range: true,
    };
  }
  return {
    day: `${dayNum(start)}–${dayNum(end)}`,
    month: `${monthShort(start)}/${monthShort(end)}`,
    range: true,
  };
}

function sameDay(a: Date, b: Date) {
  return (
    a.getFullYear() === b.getFullYear() &&
    a.getMonth() === b.getMonth() &&
    a.getDate() === b.getDate()
  );
}

// Time formatting — Plainfield IL is Central Time. Hardcode CT label
// instead of relying on the visitor's locale (which would render in
// their local zone and confuse anyone planning to attend).
const timeFmt = new Intl.DateTimeFormat("en-US", {
  hour: "numeric",
  minute: "2-digit",
  hour12: true,
  timeZone: "America/Chicago",
});

function timeRange(start: Date, end?: Date) {
  const s = timeFmt.format(start).toLowerCase();
  if (!end) return `${s} CT`;
  const e = timeFmt.format(end).toLowerCase();
  return `${s} – ${e} CT`;
}

// JSON-LD: ItemList of Events. Same `events` array the page renders —
// schema and display can't drift. Skipped when no events are scheduled
// (calendar's clear → no ItemList to ship). Each Event:
//   - eventStatus: EventScheduled (default; flip via markdown if needed)
//   - eventAttendanceMode: OfflineEventAttendanceMode
//   - location + organizer reference the venue via @id
//   - url prefers the cta.href when it's an internal page (lets crawlers
//     follow to the dedicated detail page e.g. /new-years-eve/), falls
//     back to the upcoming-events page itself.
const upcomingEventsJsonLd = events.length === 0 ? null : {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: events.map((e, i) => {
    const cta = e.data.cta?.href;
    const ctaIsInternal = cta && cta.startsWith("/");
    const eventUrl = ctaIsInternal
      ? `${BUSINESS_URL}${cta}`
      : `${BUSINESS_URL}/upcoming-events/`;
    return {
      "@type": "ListItem",
      position: i + 1,
      item: eventSchema({
        name: e.data.title,
        start: e.data.start,
        end: e.data.end,
        description: e.body?.trim(),
        url: eventUrl,
      }),
    };
  }),
};
---
<Base
  title="Upcoming Events in Plainfield, IL | Twisted Pin"
  description="Themed nights, seasonal events, and holiday parties at Twisted Pin in Plainfield, IL. The live calendar — see what's coming up, or plan your own night."
>

  <section class="t2-hero" data-hero aria-labelledby="upcoming-h1">
    <div class="t2-hero-copy">
      <p class="t-eyebrow hero-fade" data-delay-ms="0">What's On</p>
      <h1 class="t-display t2-hero-headline hero-fade" id="upcoming-h1" data-delay-ms="120">
        Upcoming events.
      </h1>
      <p class="t2-hero-sub hero-fade" data-delay-ms="320">
        Themed nights, seasonal events, holiday parties.
      </p>
    </div>
  </section>

  {events.length === 0 ? (
    <section class="t2-section ev-empty" aria-labelledby="ev-empty-h2">
      <div class="t2-section-inner">
        <h2 id="ev-empty-h2" class="ev-empty-headline">Calendar's clear right now.</h2>
        <p class="t2-section-body">
          New nights drop here as we lock them in — keep an eye out.
        </p>
        <p class="t2-section-body">
          Want to fill it? <a href={PLAN_EVENT_URL} target="_blank" rel="noopener">Plan an event &rarr;</a>
        </p>
      </div>
    </section>
  ) : (
    <section class="ev-list" aria-label="Upcoming events">
      {groups.map((group) => (
        <div class="ev-month">
          <h2 class="ev-month-label">{group.label}</h2>
          <ul class="ev-cards" role="list">
            {group.events.map((e) => {
              const block = dayBlock(e.data.start, e.data.end);
              const time = timeRange(e.data.start, e.data.end);
              const desc = e.body?.trim();
              return (
                <li class="ev-card">
                  <div class="ev-date" aria-hidden="true">
                    <div class="ev-date-day" class:list={[block.range && "is-range"]}>
                      {block.day}
                    </div>
                    <div class="ev-date-month">{block.month}</div>
                  </div>
                  <div class="ev-body">
                    <div class="ev-flags">
                      {e.data.tentative && <span class="ev-flag ev-flag-tentative">Tentative</span>}
                      {e.data.virtual && <span class="ev-flag ev-flag-virtual">Virtual</span>}
                    </div>
                    <h3 class="ev-title">{e.data.title}</h3>
                    <p class="ev-meta ev-meta-time">
                      <span class="ev-meta-glyph" aria-hidden="true">&#9719;</span>
                      <span class="visually-hidden">When: </span>{time}
                    </p>
                    {e.data.location && (
                      <p class="ev-meta ev-meta-loc">
                        <span class="ev-meta-glyph" aria-hidden="true">&#9678;</span>
                        <span class="visually-hidden">Where: </span>{e.data.location}
                      </p>
                    )}
                    {desc && <p class="ev-desc">{desc}</p>}
                    {e.data.cta && (
                      <a
                        class="btn btn-outline ev-cta"
                        href={e.data.cta.href}
                        {...(/^https?:\/\//.test(e.data.cta.href)
                          ? { target: "_blank", rel: "noopener" }
                          : {})}
                      >
                        {e.data.cta.label}
                      </a>
                    )}
                  </div>
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </section>
  )}

  {/* SEO body block — substantive content for the calendar page so
      the empty-state version isn't ~30 words around a single Zite link.
      Sets expectation re: lookahead window, names what runs even when
      the calendar is clear, and links out to /bar/, /game/, and the
      Naperville service area. Distinct copy from the other 4 thin
      pages (calendar context, not iframe / credit / hiring). */}
  <section class="t2-section" aria-labelledby="upcoming-info-h2">
    <div class="t2-section-inner">
      <h2 class="t-eyebrow" id="upcoming-info-h2" style="font-size:11px;">What Goes On The Calendar</h2>
      <p class="t2-section-body">
        The calendar above tracks the bigger nights: themed events,
        holiday programming, seasonal pop-ups, and one-off
        collaborations. Most fall in the 4&ndash;8 weeks out window;
        we don't post six months ahead because the calendar tends to
        shift, and stale dates do nobody any favors. New things get
        added as we lock them in.
      </p>
      <p class="t2-section-body">
        Standard programming runs even when the calendar's empty.
        Walk-in bowling all year, cocktails by
        <a href="/bar/">America's Top Mixologist</a> every night the
        bar's open, the 28-tap self-serve wall, the kitchen, the
        <a href="/game/">arcade</a>. The calendar is for the bigger
        or one-off nights &mdash; not everyday operations, which run
        on a standard schedule.
      </p>
      <p class="t2-section-body">
        Plainfield, IL is the venue, with most weekend regulars
        driving in from <a href="/why-us/naperville-il/">Naperville</a>,
        Bolingbrook, Joliet, and the rest of Will County. Want to put
        your own night on this calendar? <a href={PLAN_EVENT_URL} target="_blank" rel="noopener">Plan an event &rarr;</a>
        &mdash; group buyouts and corporate offsites are how most
        non-themed nights start.
      </p>
    </div>
  </section>

  <section class="t2-section ev-handoff" aria-labelledby="upcoming-h2">
    <div class="t2-section-inner">
      <h2 class="t-eyebrow" id="upcoming-h2" style="font-size:11px;">More Ways In</h2>
      <p class="t2-section-body">
        Want to host your own night? Group events, corporate offsites,
        and birthdays all run through our event team — <a href={PLAN_EVENT_URL} target="_blank" rel="noopener">plan an event &rarr;</a>
      </p>

      <p class="t2-section-body">
        Looking for league nights specifically?
        <a href="/leagues/">See leagues &rarr;</a>
      </p>
    </div>
  </section>

  <SnapFooter />

  {upcomingEventsJsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(upcomingEventsJsonLd)} />
  )}
  <BreadcrumbSchema crumbs={[
    { name: "Home", path: "/" },
    { name: "Upcoming Events", path: "/upcoming-events/" },
  ]} />
</Base>

<style>
  /* List wrapper. Same horizontal rhythm as t2-section but with its
     own vertical pacing — month headers and cards stack tighter than
     a typical editorial section. */
  .ev-list {
    padding: 24px 24px 64px;
    max-width: 800px;
    margin: 0 auto;
  }
  @media (min-width: 1025px) {
    .ev-list {
      padding: 32px 64px 96px;
    }
  }

  .ev-month + .ev-month {
    margin-top: 48px;
  }

  .ev-month-label {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(32px, 7vw, 44px);
    letter-spacing: 0.01em;
    line-height: 1;
    color: var(--warm-white);
    margin: 0 0 20px;
    text-transform: uppercase;
  }

  .ev-cards {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 16px;
  }

  /* Card chrome — Indigo Deep base, warm-white border at 14% opacity.
     Same vocabulary as Tap Wall / Cocktails section frames. */
  .ev-card {
    display: grid;
    grid-template-columns: 84px 1fr;
    gap: 20px;
    padding: 20px;
    background: rgba(255, 252, 245, 0.04);
    border: 1px solid rgba(255, 252, 245, 0.14);
    border-radius: 12px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
  }
  @media (min-width: 1025px) {
    .ev-card {
      grid-template-columns: 110px 1fr;
      gap: 32px;
      padding: 28px 32px;
    }
  }

  /* Date block — Glow as accent to anchor the eye to the date. Same
     restraint principle as the rest of the site: Glow used sparingly. */
  .ev-date {
    border-right: 1px solid rgba(255, 252, 245, 0.12);
    padding-right: 16px;
    text-align: center;
    align-self: start;
  }
  @media (min-width: 1025px) {
    .ev-date {
      padding-right: 24px;
    }
  }
  .ev-date-day {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(40px, 9vw, 56px);
    line-height: 0.95;
    color: var(--glow);
    letter-spacing: -0.01em;
  }
  /* Range form (e.g. "28-29") is wider — shrink it to fit the column. */
  .ev-date-day.is-range {
    font-size: clamp(26px, 6vw, 36px);
    letter-spacing: 0;
  }
  .ev-date-month {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 14px;
    color: var(--warm-white);
    letter-spacing: 0.12em;
    margin-top: 4px;
  }

  .ev-body {
    min-width: 0; /* let text wrap inside grid */
  }

  .ev-flags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 8px;
  }
  .ev-flag {
    display: inline-block;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 999px;
    line-height: 1;
  }
  .ev-flag-tentative {
    background: rgba(216, 139, 92, 0.18);
    color: #f0b289; /* Copper, lifted for contrast on Indigo Deep */
    border: 1px solid rgba(216, 139, 92, 0.42);
  }
  .ev-flag-virtual {
    background: rgba(159, 245, 202, 0.14);
    color: var(--glow);
    border: 1px solid rgba(159, 245, 202, 0.42);
  }

  .ev-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(22px, 5.5vw, 28px);
    line-height: 1.05;
    margin: 0 0 12px;
    color: var(--warm-white);
    text-transform: uppercase;
    letter-spacing: 0.005em;
  }

  .ev-meta {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.45;
    color: rgba(255, 252, 245, 0.78);
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .ev-meta + .ev-meta {
    margin-top: 4px;
  }
  .ev-meta-glyph {
    color: rgba(255, 252, 245, 0.5);
    font-size: 13px;
    flex: 0 0 auto;
  }

  .ev-desc {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.55;
    color: rgba(255, 252, 245, 0.86);
    margin: 14px 0 0;
  }

  .ev-cta {
    margin-top: 18px;
    /* Smaller than the global .btn-outline default — cards already
       carry visual weight; oversized CTAs would crowd a stack of them. */
    padding: 10px 20px;
    font-size: 12px;
    letter-spacing: 0.16em;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Empty state — terse, brand-voiced, single CTA hand-off. */
  .ev-empty .ev-empty-headline {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(28px, 6vw, 40px);
    color: var(--warm-white);
    text-transform: uppercase;
    letter-spacing: 0.005em;
    line-height: 1.05;
    margin: 0 0 16px;
  }

  /* Bottom hand-off section — slightly more compact than a normal
     t2-section since it's the page's third zone, not its second. */
  .ev-handoff {
    padding-top: 0;
  }
</style>
